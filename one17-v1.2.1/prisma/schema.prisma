// ============================================================================
// Zakat Advisory (invariant 26, spec: ../Portfolio Management/Zakat
// Assessment/). Per-client service, applies to ALL company clients (not
// only WM) whose investments exceed nisab. Reuses the WM claim-validation
// PATTERN (declare -> DIFFERENT verifier -> DECLARED->VERIFIED) via the
// shared WmCustodyFlag/WmVerificationTag enums, but on its OWN item table
// (ZakatDeclaredItem) rather than wm_client_asset directly, since Zakat
// subscribers are not necessarily WM clients — a hard FK to
// wm_client_profile would violate that scope.
// ============================================================================

// AMD-12 doctrine (invariant 16): governed, ACTIVATION-gated, never
// build-gated. Both fields ship NULL — no nisab-breach monitoring can fire,
// and no assessment can compute a due amount, until a Board/SSB-approved
// value is entered via updateNisabConfig() (never invented here; this is a
// Shariah determination, not a platform default).
model ZakatNisabConfig {
  id                   Int       @id @default(1)
  nisabGoldGrams       Decimal?  @map("nisab_gold_grams") @db.Decimal(10, 3)
  goldPricePerGramKobo BigInt?   @map("gold_price_per_gram_kobo")
  approvedByUserId     String?   @map("approved_by_user_id") @db.Uuid
  approvedAt           DateTime? @map("approved_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("zakat_nisab_config")
}

enum ZakatRateBasis {
  LUNAR // 2.5% — the classical lunar-year (Hijri) basis
  GREGORIAN // 2.577% — the workbook's own solar-year adjustment

  @@map("zakat_rate_basis")
}

// Invariant 26(c): "per-client service ... staff-side ACTIVATE/DEACTIVATE
// switch ... client elects basis at subscription." A deactivated client
// must get ZERO nisab-breach prompts — enforced by the monitor job checking
// isActive, not by capability alone.
model ZakatClientSubscription {
  investorId                String          @id @map("investor_id")
  isActive                  Boolean         @default(false) @map("is_active")
  rateBasisElection         ZakatRateBasis? @map("rate_basis_election")
  zakatAnniversaryGregorian DateTime?       @map("zakat_anniversary_gregorian")
  zakatAnniversaryHijri     String?         @map("zakat_anniversary_hijri")
  activatedByUserId         String          @map("activated_by_user_id") @db.Uuid
  activatedAt               DateTime        @default(now()) @map("activated_at")
  deactivatedByUserId       String?         @map("deactivated_by_user_id") @db.Uuid
  deactivatedAt             DateTime?       @map("deactivated_at")

  investor Investor             @relation(fields: [investorId], references: [investorId])
  runs     ZakatAssessmentRun[]

  @@map("zakat_client_subscription")
}

// Invariant 70(h)(i): the portal-request/staff-approve queue in front of
// the pre-existing activateSubscription staff toggle — mirrors
// WmHoldingActionRequest's own shape/precedent exactly (portal creates the
// row with NO capability gate since investorId is inherent ownership, not
// a delegated authority; staff action it under the SAME ZAKAT_ADVISORY
// INITIATE gate activateSubscription already enforces). consentAcknowledgedAt
// is the NDPA purpose-limitation consent captured at request time (70(h)(ii)
// last sentence: "consent language at subscription covers the advisory use
// in (iv)") -- a plain timestamp column here rather than a full
// PrivacyNoticeAcknowledgment-style table, since this consent is scoped
// to one specific request/service, not a platform-wide notice version.
model ZakatSubscriptionRequest {
  id                    String                         @id @default(uuid()) @db.Uuid
  investorId            String                         @map("investor_id")
  status                ZakatSubscriptionRequestStatus @default(PENDING)
  consentAcknowledgedAt DateTime                       @map("consent_acknowledged_at")
  requestedAt           DateTime                       @default(now()) @map("requested_at")
  approvedByUserId      String?                        @map("approved_by_user_id") @db.Uuid
  approvedAt            DateTime?                      @map("approved_at")

  investor Investor @relation(fields: [investorId], references: [investorId])

  @@map("zakat_subscription_request")
}

enum ZakatSubscriptionRequestStatus {
  PENDING
  APPROVED

  @@map("zakat_subscription_request_status")
}

enum ZakatAssessmentStatus {
  DRAFT // Sandbox stage — One17 balances auto-filled, client has not yet agreed
  CLIENT_AGREED // client agreed to proceed; completing remaining schedules
  AWAITING_SHARIAH_CERTIFICATION // submitted to the SSB workflow
  CERTIFIED // immutable from this point on

  @@map("zakat_assessment_status")
}

// One report_run-style immutable snapshot per assessment cycle (same
// discipline as WmRiskAssessmentRun / StakeholderReportRun elsewhere in
// this codebase). oneSeventeenBalancesSnapshot is AUTO-filled from the
// combined book at DRAFT creation (invariant 26c: "One17 balances
// AUTO-filled") — the client only ever declares the EXTERNAL schedules.
model ZakatAssessmentRun {
  id                           String                @id @default(uuid()) @db.Uuid
  investorId                   String                @map("investor_id")
  assessmentDateGregorian      DateTime              @map("assessment_date_gregorian")
  assessmentDateHijri          String                @map("assessment_date_hijri")
  rateBasis                    ZakatRateBasis        @map("rate_basis")
  status                       ZakatAssessmentStatus @default(DRAFT)
  oneSeventeenBalancesSnapshot Json                  @map("one_seventeen_balances_snapshot")
  netZakatableKobo             BigInt?               @map("net_zakatable_kobo")
  zakatDueKobo                 BigInt?               @map("zakat_due_kobo")
  workflowInstanceId           String?               @unique @map("workflow_instance_id") @db.Uuid
  certifiedByUserId            String?               @map("certified_by_user_id") @db.Uuid
  certifiedAt                  DateTime?             @map("certified_at")
  createdByUserId              String                @map("created_by_user_id") @db.Uuid
  createdAt                    DateTime              @default(now()) @map("created_at")

  subscription ZakatClientSubscription @relation(fields: [investorId], references: [investorId])
  items        ZakatDeclaredItem[]

  @@map("zakat_assessment_run")
}

enum ZakatScheduleType {
  CASH_BANK
  GOLD_SILVER
  INVESTMENT
  FIXED_ASSET
  RECEIVABLE
  LIABILITY

  @@map("zakat_schedule_type")
}

// Receivables carry a third zakatability state the other five schedules
// don't (workbook §06): a DOUBTFUL debt is excluded from the CURRENT
// period's Net Zakatable base — classical fiqh treats an uncertain
// receivable as zakat-deferred until actually collected — rather than
// silently included or silently dropped. Flagged as a judgment call in the
// evidence pack: the workbook does not specify a backdated multi-year
// catch-up formula, so this build does not invent one.
enum ZakatItemZakatability {
  ZAKATABLE
  NON_ZAKATABLE
  DOUBTFUL

  @@map("zakat_item_zakatability")
}

// The Zakat-domain equivalent of WmClientAsset — same DECLARED/VERIFIED
// claim-validation shape (reusing WmCustodyFlag/WmVerificationTag), scoped
// to a zakat_assessment_run instead of a wm_client_profile so non-WM
// clients can subscribe. ONE17-custody rows are AUTO-verified at creation
// (system-sourced, same as WM's ONE17_CUSTODY aggregate never going through
// claim-validation); EXTERNAL rows require a DIFFERENT verifier, exactly
// like WM_CLAIM_VALIDATION.
model ZakatDeclaredItem {
  id                   String                 @id @default(uuid()) @db.Uuid
  zakatAssessmentRunId String                 @map("zakat_assessment_run_id") @db.Uuid
  scheduleType         ZakatScheduleType      @map("schedule_type")
  description          String
  amountKobo           BigInt                 @map("amount_kobo")
  zakatability         ZakatItemZakatability
  custodyFlag          WmCustodyFlag          @map("custody_flag")
  verificationTag      WmVerificationTag      @default(DECLARED) @map("verification_tag")
  // Invariant 70(h)(ii): declaredByUserId is an AppUser UUID and stays NULL
  // for a client-portal declaration (a PortalClientUser/investorId is not
  // an AppUser and can never be a maker/checker actor) -- declarationSource
  // is the minimal added column that lets the audit/verification trail show
  // WHO declared even when it's the client: the item's own run.investorId
  // already identifies WHICH client, so a second FK column back to
  // PortalClientUser would be redundant, not more correct.
  declarationSource    ZakatDeclarationSource @default(STAFF) @map("declaration_source")
  declaredByUserId     String?                @map("declared_by_user_id") @db.Uuid
  verifiedByUserId     String?                @map("verified_by_user_id") @db.Uuid
  verifiedAt           DateTime?              @map("verified_at")
  workflowInstanceId   String?                @unique @map("workflow_instance_id") @db.Uuid
  createdAt            DateTime               @default(now()) @map("created_at")

  run ZakatAssessmentRun @relation(fields: [zakatAssessmentRunId], references: [id])

  @@map("zakat_declared_item")
}

enum ZakatDeclarationSource {
  STAFF
  CLIENT

  @@map("zakat_declaration_source")
}

// ============================================================================
// Portal auth realm (spec §7.5 / §6a — "SEPARATE AUTH REALM, absolute").
// Deliberately NOT AppUser/UserSession: a completely separate identity +
// session table so that neither session token can ever validate against the
// other realm's guard, by construction (not just by route convention) — the
// literal mechanism behind the "realm isolation" and "cross-client leak"
// adversarial cases.
// ============================================================================
// Invariant 39(d): re-scoped from WmClientProfile.investorId to
// Investor.investorId directly — every KYC-complete investor now gets
// portal access (auto-provisioned at Flow-A Stage-2 KYC_COMPLETE,
// mirroring the counterparty portal's COMPLETE_APPROVED trigger), not just
// WM admits. Since WmClientProfile.investorId already WAS Investor.
// investorId (1:1 PK==FK), every existing WM client's portal row remains
// valid under the new FK with no data migration needed — only the
// relation's target table changes.
model PortalClientUser {
  id                  String     @id @default(uuid()) @db.Uuid
  investorId          String     @unique @map("investor_id")
  passwordHash        String?    @map("password_hash")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  status              UserStatus @default(ACTIVE)
  // Invariant 57(b)(i) (CHECK15): set on the FIRST successful login only —
  // PortalAuthService.completeLogin() checks this before setting it, so a
  // null value is the "requires privacy-notice acknowledgment" gate signal.
  firstLoginAt        DateTime?  @map("first_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")

  investor Investor              @relation(fields: [investorId], references: [investorId])
  sessions PortalClientSession[]

  @@map("portal_client_user")
}

model PortalClientSession {
  id           String    @id @default(uuid()) @db.Uuid
  portalUserId String    @map("portal_user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  ipAddress    String?   @map("ip_address")

  portalUser PortalClientUser @relation(fields: [portalUserId], references: [id])

  @@index([portalUserId])
  @@map("portal_client_session")
}

// ============================================================================
// CHECK5 item 4 — PMS slot B (invariant 18, SDS §3/§4/§7). Slot A (schema +
// DRAFT seeds) already shipped: StrategicPillar/Objective, OrgUnit,
// EnterpriseKra, KpiDefinition, KpiWeightMatrix, CadreTierMap, Position,
// Employee, EmolumentStructure. This pass adds the engines: scoring
// workflows, incentive computation, behavioural gate, payroll run P-A.
// Hard rules (SDS §7) enforced structurally, not by convention: no KPI/
// weight/band/gate-rule/tax-rate/emolument literal in PmsService (config
// rows only, invariant 10); incentive computation is a pure function run
// once at APPROVED->INCENTIVE_COMPUTED and never re-run in place afterward
// (corrections = reversal + recompute); behavioural gate can only apply a
// <=100% factor, never >100%; payroll journals hit COMPANY only.
// ============================================================================

// SDS §1 role_scorecard: the base case (position -> org_unit+tier -> active
// KpiDefinition rows + ACTIVE KpiWeightMatrix rows) is a pure DERIVATION —
// computed live by PmsService.getRoleScorecard(), never stored, so it is
// always consistent with whatever KPI/weight config is currently ACTIVE.
// This table is ONLY the exception path: "individual overrides allowed with
// approval."
model RoleScorecardOverride {
  id                 String             @id @default(uuid()) @db.Uuid
  employeeId         String             @map("employee_id") @db.Uuid
  kpiDefinitionId    String             @map("kpi_definition_id") @db.Uuid
  overrideWeightPct  Decimal            @map("override_weight_pct") @db.Decimal(5, 2)
  reason             String
  status             GovernedItemStatus @default(DRAFT)
  createdByUserId    String             @map("created_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  employee      Employee      @relation(fields: [employeeId], references: [id])
  kpiDefinition KpiDefinition @relation(fields: [kpiDefinitionId], references: [id])

  @@map("role_scorecard_override")
}

// SDS §1 Level 6: "links a staff member's logged activity to a KPI."
model ActivityReport {
  id                  String   @id @default(uuid()) @db.Uuid
  employeeId          String   @map("employee_id") @db.Uuid
  kpiDefinitionId     String   @map("kpi_definition_id") @db.Uuid
  activityText        String   @map("activity_text")
  workflowInstanceRef String?  @map("workflow_instance_ref") @db.Uuid
  taskRef             String?  @map("task_ref")
  loggedAt            DateTime @default(now()) @map("logged_at")

  employee      Employee      @relation(fields: [employeeId], references: [id])
  kpiDefinition KpiDefinition @relation(fields: [kpiDefinitionId], references: [id])

  @@map("activity_report")
}

// SDS §3.1/§3.5: "appraisal ≠ incentive: separate cycle types" — ONE table,
// discriminated by cycleType, since both share the same OPEN->SCORING->
// VALIDATION->APPROVED shape; only INCENTIVE_CYCLE continues on to
// INCENTIVE_COMPUTED/PAID (ANNUAL_APPRAISAL stops at APPROVED — its output
// is promotion/notch recommendations, never a payout).
model AppraisalCycle {
  id          String         @id @default(uuid()) @db.Uuid
  cycleType   PmsCycleType   @map("cycle_type")
  orgUnitCode String?        @map("org_unit_code")
  periodStart DateTime       @map("period_start")
  periodEnd   DateTime       @map("period_end")
  status      PmsCycleStatus @default(OPEN)
  createdAt   DateTime       @default(now()) @map("created_at")

  scoreSubmissions      EmployeeScoreSubmission[]
  gateChecks            BehaviouralGateCheck[]
  incentiveResults      EmployeeIncentiveResult[]
  talentRecommendations TalentRecommendation[]

  @@map("appraisal_cycle")
}

enum PmsCycleType {
  INCENTIVE_CYCLE
  ANNUAL_APPRAISAL

  @@map("pms_cycle_type")
}

enum PmsCycleStatus {
  OPEN
  SCORING
  VALIDATION
  APPROVED
  INCENTIVE_COMPUTED
  PAID
  CLOSED

  @@map("pms_cycle_status")
}

// SDS §3.2 scoring chain (SoD): self -> supervisor -> SAU QA -> Chief ->
// CEO. Modeled as the standing WorkflowEngineService's multi-step
// ApprovalRule (PMS_SCORE_VALIDATION_STANDARD, 4 ordered steps, each a
// DIFFERENT requiredFunctionCode) — maker≠checker (self can never also be
// the approver) is the same generic guarantee every other workflow in this
// codebase relies on; per-instance-different-approver-per-step-role comes
// from the DIFFERENT function each step requires.
model EmployeeScoreSubmission {
  id                 String                @id @default(uuid()) @db.Uuid
  appraisalCycleId   String                @map("appraisal_cycle_id") @db.Uuid
  employeeId         String                @map("employee_id") @db.Uuid
  status             ScoreSubmissionStatus @default(SELF_SCORED)
  workflowInstanceId String?               @unique @map("workflow_instance_id") @db.Uuid
  submittedAt        DateTime              @default(now()) @map("submitted_at")

  appraisalCycle AppraisalCycle     @relation(fields: [appraisalCycleId], references: [id])
  employee       Employee           @relation(fields: [employeeId], references: [id])
  kpiScores      EmployeeKpiScore[]

  @@unique([appraisalCycleId, employeeId])
  @@map("employee_score_submission")
}

enum ScoreSubmissionStatus {
  SELF_SCORED
  VALIDATED
  REJECTED

  @@map("score_submission_status")
}

model EmployeeKpiScore {
  id                        String   @id @default(uuid()) @db.Uuid
  employeeScoreSubmissionId String   @map("employee_score_submission_id") @db.Uuid
  kpiDefinitionId           String   @map("kpi_definition_id") @db.Uuid
  selfScorePct              Decimal  @map("self_score_pct") @db.Decimal(5, 2)
  validatedScorePct         Decimal? @map("validated_score_pct") @db.Decimal(5, 2)
  evidenceRef               String?  @map("evidence_ref")
  createdAt                 DateTime @default(now()) @map("created_at")

  submission    EmployeeScoreSubmission @relation(fields: [employeeScoreSubmissionId], references: [id])
  kpiDefinition KpiDefinition           @relation(fields: [kpiDefinitionId], references: [id])

  @@unique([employeeScoreSubmissionId, kpiDefinitionId])
  @@map("employee_kpi_score")
}

// SDS §3.3: "Payout per block = allocation x band factor from
// incentive_band config" — governed, never hardcoded (invariant 10). Seed:
// >=90->100%, 80-89->80%, 70-79->60%, 60-69->40%, <60->0% (memo §D).
model IncentiveBandConfig {
  id          String   @id @default(uuid()) @db.Uuid
  minScorePct Decimal  @map("min_score_pct") @db.Decimal(5, 2)
  payoutPct   Decimal  @map("payout_pct") @db.Decimal(5, 2)
  sortOrder   Int      @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("incentive_band_config")
}

// SDS §3.4 behavioural gate: "each PASS/FAIL with evidence ref... Gate
// outcome (config): PASS -> full release; FAIL -> capped/deferred/
// suspended per severity." Governed severity->outcome map, never hardcoded.
model PmsGateSeverityConfig {
  id        String      @id @default(uuid()) @db.Uuid
  severity  String      @unique
  outcome   GateOutcome
  cappedPct Decimal?    @map("capped_pct") @db.Decimal(5, 2)
  createdAt DateTime    @default(now()) @map("created_at")

  taskDefaultGatePolicies        TaskDefaultGatePolicy[]
  attendanceLatenessGatePolicies AttendanceLatenessGatePolicy[]

  @@map("pms_gate_severity_config")
}

enum GateOutcome {
  FULL_RELEASE
  CAPPED
  DEFERRED
  SUSPENDED

  @@map("gate_outcome")
}

model BehaviouralGateCheck {
  id               String      @id @default(uuid()) @db.Uuid
  appraisalCycleId String      @map("appraisal_cycle_id") @db.Uuid
  employeeId       String      @map("employee_id") @db.Uuid
  attendanceOk     Boolean     @map("attendance_ok")
  ethicalConductOk Boolean     @map("ethical_conduct_ok")
  trendsViolation  Boolean     @default(false) @map("trends_violation")
  disciplinaryNote String?     @map("disciplinary_note")
  evidenceRef      String?     @map("evidence_ref")
  outcome          GateOutcome
  cappedPct        Decimal?    @map("capped_pct") @db.Decimal(5, 2)
  assessedByUserId String      @map("assessed_by_user_id") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at")

  appraisalCycle AppraisalCycle @relation(fields: [appraisalCycleId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])

  @@unique([appraisalCycleId, employeeId])
  @@map("behavioural_gate_check")
}

// SDS §3.3: "pure math, zero discretion after approval" — the immutable
// output, written ONCE when the cycle transitions APPROVED->
// INCENTIVE_COMPUTED (PmsService enforces the transition is one-way;
// "corrections = reversal + recompute" per SDS §7.2 means a NEW cycle/
// result, never an UPDATE to this row).
model EmployeeIncentiveResult {
  id                   String      @id @default(uuid()) @db.Uuid
  appraisalCycleId     String      @map("appraisal_cycle_id") @db.Uuid
  employeeId           String      @map("employee_id") @db.Uuid
  totalEmolumentKobo   BigInt      @map("total_emolument_kobo")
  incentivePoolKobo    BigInt      @map("incentive_pool_kobo")
  overallScorePct      Decimal     @map("overall_score_pct") @db.Decimal(5, 2)
  bandPayoutPct        Decimal     @map("band_payout_pct") @db.Decimal(5, 2)
  gateOutcome          GateOutcome @map("gate_outcome")
  preGateIncentiveKobo BigInt      @map("pre_gate_incentive_kobo")
  finalIncentiveKobo   BigInt      @map("final_incentive_kobo")
  classAllocationKobo  Json        @map("class_allocation_kobo")
  computedAt           DateTime    @default(now()) @map("computed_at")

  appraisalCycle AppraisalCycle @relation(fields: [appraisalCycleId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])

  @@unique([appraisalCycleId, employeeId])
  @@map("employee_incentive_result")
}

// SDS §4 P-A: "PAYE (Nigerian CRA rules as versioned tax_rule_config —
// FINCON validates before activation)." Bands are a Json array of
// {fromKobo, toKobo, ratePct} — the calculator reads this, never a literal
// rate/threshold in code (invariant 10).
model TaxRuleConfig {
  id                           String             @id @default(uuid()) @db.Uuid
  version                      Int
  consolidatedReliefFlatKobo   BigInt             @map("consolidated_relief_flat_kobo")
  consolidatedReliefPctOfGross Decimal            @map("consolidated_relief_pct_of_gross") @db.Decimal(5, 2)
  bands                        Json
  pensionEmployeePct           Decimal            @map("pension_employee_pct") @db.Decimal(5, 2)
  nhfPct                       Decimal            @map("nhf_pct") @db.Decimal(5, 2)
  status                       GovernedItemStatus @default(DRAFT)
  validatedByUserId            String?            @map("validated_by_user_id") @db.Uuid
  effectiveFrom                DateTime           @map("effective_from")
  createdAt                    DateTime           @default(now()) @map("created_at")

  payrollRuns PayrollRun[]

  @@unique([version])
  @@map("tax_rule_config")
}

// SDS §4 P-A: "payroll_run (immutable snapshot, report_run pattern) ->
// auto-journal to COMPANY GL." ledgerEntityCode always resolves to the
// single COMPANY entity — SDS §4 boundary: "payroll posts ONLY to the
// COMPANY ledger entity — never a fund/pool (invariant 5)."
model PayrollRun {
  id                 String           @id @default(uuid()) @db.Uuid
  periodMonth        Int              @map("period_month")
  periodYear         Int              @map("period_year")
  ledgerEntityCode   String           @map("ledger_entity_code")
  status             PayrollRunStatus @default(DRAFT)
  taxRuleConfigId    String           @map("tax_rule_config_id") @db.Uuid
  journalEntryId     String?          @map("journal_entry_id") @db.Uuid
  workflowInstanceId String?          @unique @map("workflow_instance_id") @db.Uuid
  generatedByUserId  String           @map("generated_by_user_id") @db.Uuid
  approvedByUserId   String?          @map("approved_by_user_id") @db.Uuid
  generatedAt        DateTime         @default(now()) @map("generated_at")

  taxRuleConfig TaxRuleConfig    @relation(fields: [taxRuleConfigId], references: [id])
  lines         PayrollRunLine[]

  @@unique([periodMonth, periodYear, ledgerEntityCode])
  @@map("payroll_run")
}

enum PayrollRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED

  @@map("payroll_run_status")
}

model PayrollRunLine {
  id            String @id @default(uuid()) @db.Uuid
  payrollRunId  String @map("payroll_run_id") @db.Uuid
  employeeId    String @map("employee_id") @db.Uuid
  grossKobo     BigInt @map("gross_kobo")
  payeKobo      BigInt @map("paye_kobo")
  pensionKobo   BigInt @map("pension_kobo")
  nhfKobo       BigInt @map("nhf_kobo")
  incentiveKobo BigInt @default(0) @map("incentive_kobo")
  netPayKobo    BigInt @map("net_pay_kobo")

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@map("payroll_run_line")
}

// Invariant 37(e), task #153: Talent Management + Reward & Welfare
// spec-lite. Welfare schemes and reward types are governed CONFIG catalogs
// (invariant 10 — no scheme/reward-type literal in code), plain
// INITIATE-gated CRUD like org_unit/position (not maker!=checker versioned
// like a financial threshold — the catalog itself carries no monetary
// commitment; the RECOMMENDATION that references it does, and THAT is what
// carries the approval workflow).
model WelfareScheme {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  recommendations TalentRecommendation[]

  @@unique([name])
  @@map("welfare_scheme")
}

model RewardType {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  recommendations TalentRecommendation[]

  @@unique([name])
  @@map("reward_type")
}

enum TalentRecommendationType {
  WELFARE
  REWARD

  @@map("talent_recommendation_type")
}

enum TalentRecommendationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("talent_recommendation_status")
}

// "Recommendations -> approval workflow" (invariant 37e) and "linked to
// appraisal outcomes" — appraisalCycleId is nullable because a welfare
// recommendation (e.g. a bereavement scheme) may have nothing to do with
// any appraisal cycle, while a reward recommendation typically cites the
// cycle whose EmployeeIncentiveResult motivated it.
model TalentRecommendation {
  id                  String                     @id @default(uuid()) @db.Uuid
  employeeId          String                     @map("employee_id") @db.Uuid
  recommendationType  TalentRecommendationType   @map("recommendation_type")
  welfareSchemeId     String?                    @map("welfare_scheme_id") @db.Uuid
  rewardTypeId        String?                    @map("reward_type_id") @db.Uuid
  appraisalCycleId    String?                    @map("appraisal_cycle_id") @db.Uuid
  justification       String
  status              TalentRecommendationStatus @default(PENDING)
  recommendedByUserId String                     @map("recommended_by_user_id") @db.Uuid
  approvedByUserId    String?                    @map("approved_by_user_id") @db.Uuid
  workflowInstanceId  String?                    @unique @map("workflow_instance_id") @db.Uuid
  createdAt           DateTime                   @default(now()) @map("created_at")

  employee       Employee        @relation(fields: [employeeId], references: [id])
  welfareScheme  WelfareScheme?  @relation(fields: [welfareSchemeId], references: [id])
  rewardType     RewardType?     @relation(fields: [rewardTypeId], references: [id])
  appraisalCycle AppraisalCycle? @relation(fields: [appraisalCycleId], references: [id])

  @@map("talent_recommendation")
}

// ============================================================================
// CHECK5 item 5, invariants 27/28 (CEO rulings, 4-Jul-2026): graduated
// dual-path onboarding + third-party payments + BD register + Wave-0
// catch-up. `lead` and `client_communication` were named as Wave-0 "build
// NOW" skeletons in invariant 17 but were never actually created in any
// prior pass — built here because invariant 27(c)'s BD register is
// explicitly defined as a read-only view OVER the lead skeleton, so it
// cannot be built without this catch-up.
// ============================================================================

model Lead {
  id                  String     @id @default(uuid()) @db.Uuid
  fullNameOrCompany   String     @map("full_name_or_company")
  contactEmail        String?    @map("contact_email")
  contactPhone        String?    @map("contact_phone")
  source              String?
  status              LeadStatus @default(NEW)
  // Nullable FK into Flow A per invariant 17's exact phrasing — set once the
  // lead's stage-1 Express registration produces an Investor row (BD
  // register's LEAD -> EXPRESS transition reads this, not a copy of state).
  convertedInvestorId String?    @unique @map("converted_investor_id")
  notes               String?
  createdByUserId     String     @map("created_by_user_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at")

  convertedInvestor    Investor?             @relation(fields: [convertedInvestorId], references: [investorId])
  createdBy            AppUser               @relation("LeadCreatedBy", fields: [createdByUserId], references: [id])
  clientCommunications ClientCommunication[]

  @@map("lead")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST

  @@map("lead_status")
}

// Wave-0 skeleton (invariant 17): every logged touchpoint with a lead,
// investor, or (later) counterparty — one shared log rather than a
// per-department table, since BD marketing (28b) and the investee portal's
// enquiry thread (28e) both need to write into the same place.
model ClientCommunication {
  id                   String                 @id @default(uuid()) @db.Uuid
  leadId               String?                @map("lead_id") @db.Uuid
  investorId           String?                @map("investor_id")
  counterpartyId       String?                @map("counterparty_id") @db.Uuid
  channel              String
  direction            CommunicationDirection
  subject              String?
  summary              String
  // Invariant 28(e): "routed to Portfolio/Compliance/Legal as tagged" — the
  // PlatformFunction code the enquiry is routed to; null for touches that
  // aren't a routed portal enquiry (marketing sends, BD calls, etc.).
  routedToFunctionCode String?                @map("routed_to_function_code")
  // Nullable: a portal-originated enquiry (investor or counterparty raising
  // it themselves) has no AppUser logger — only staff-logged touches
  // (calls, marketing sends) carry one.
  loggedByUserId       String?                @map("logged_by_user_id") @db.Uuid
  occurredAt           DateTime               @map("occurred_at")
  createdAt            DateTime               @default(now()) @map("created_at")

  lead         Lead?         @relation(fields: [leadId], references: [id])
  investor     Investor?     @relation(fields: [investorId], references: [investorId])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  loggedBy     AppUser?      @relation("CommunicationLoggedBy", fields: [loggedByUserId], references: [id])

  @@map("client_communication")
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND

  @@map("communication_direction")
}

// Invariant 27(a): governed, versioned config for the graduated-onboarding
// numeric parameters (deposit cap, stage-2 deadline) — CEO-ruled figures,
// seeded ACTIVE directly (same precedent as PMS's TAX_RULE_CONFIG_V1: a
// CEO-supplied number is the approval, not a placeholder awaiting one).
// Future changes to these figures go through a new version row, never a
// code edit (config-not-code, invariant 10).
model InvestorOnboardingConfig {
  id                           String             @id @default(uuid()) @db.Uuid
  version                      Int                @default(1)
  status                       GovernedItemStatus @default(ACTIVE)
  expressDepositCapKobo        BigInt             @map("express_deposit_cap_kobo")
  stage2CompletionDeadlineDays Int                @map("stage2_completion_deadline_days")
  boardResolutionRef           String?            @map("board_resolution_ref")
  approvedByUserId             String?            @map("approved_by_user_id") @db.Uuid
  createdAt                    DateTime           @default(now()) @map("created_at")

  @@map("investor_onboarding_config")
}

// Invariant 27(a): Stage-1 Express vs Stage-2 full KYC. Default is
// STAGE_1_EXPRESS — every new investor now enters through the express
// gate; Flow A's existing single-step onboard() continues to work for
// callers who go straight to full KYC (STAGE_2_COMPLETE), which is why this
// is additive to Investor rather than a breaking column.
enum InvestorOnboardingStage {
  STAGE_1_EXPRESS
  STAGE_2_COMPLETE

  @@map("investor_onboarding_stage")
}

// Invariant 27(a) Step 2-7 case file: the digitized 7-step Investor
// Onboarding Template (Business Development/One17 - Investor Onboarding
// Template.md). Per-metric grades and checklists are JSON (verbatim
// template shape, not query targets); the fields that branch actual
// business logic (accumulativeRiskProfile, eddRequired, mdDecision,
// ic1/ic2 outcome, workflowInstanceId) are typed columns. The IC1 -> Risk ->
// [MD] -> IC2 approval chain runs through WorkflowEngineService exactly
// like every other approval in this codebase — this row is the domain
// record the workflow's final step flips, not a parallel state machine.
model InvestorOnboardingCase {
  id         String @id @default(uuid()) @db.Uuid
  investorId String @unique @map("investor_id")

  // Step 2a/2b (Compliance)
  sanctionsScreenResult      SanctionsScreenResult? @map("sanctions_screen_result")
  sanctionsScreenedAt        DateTime?              @map("sanctions_screened_at")
  pepSanctionsGrid           Json?                  @map("pep_sanctions_grid")
  riskMetricGrades           Json?                  @map("risk_metric_grades")
  accumulativeRiskProfile    RiskProfileGrade?      @map("accumulative_risk_profile")
  eddRequired                Boolean?               @map("edd_required")
  complianceObservations     String?                @map("compliance_observations")
  complianceAssessedByUserId String?                @map("compliance_assessed_by_user_id") @db.Uuid
  complianceAssessedAt       DateTime?              @map("compliance_assessed_at")

  // Step 3 (Internal Control point 1)
  ic1Checklist Json?   @map("ic1_checklist")
  ic1Notes     String? @map("ic1_notes")

  // Step 5 (Risk Dept — EDD for High, periodic-review recommendation otherwise)
  eddChecklist            Json?              @map("edd_checklist")
  eddRecommendation       EddRecommendation? @map("edd_recommendation")
  eddConditionsOrBasis    String?            @map("edd_conditions_or_basis")
  periodicReviewFrequency String?            @map("periodic_review_frequency")
  // Invariant 51(b-vii) (CHECK13): mirrors CounterpartyOnboardingCase's own
  // field of the same name and purpose exactly.
  lastPeriodicReviewAt    DateTime?          @map("last_periodic_review_at")
  riskNotes               String?            @map("risk_notes")

  // Step 6 (MD — High Risk only)
  mdDecision           MdOnboardingDecision? @map("md_decision")
  mdConditionsOrReason String?               @map("md_conditions_or_reason")

  // Step 7 (Internal Control point 2 — consolidated)
  ic2Checklist Json?       @map("ic2_checklist")
  ic2Outcome   Ic2Outcome? @map("ic2_outcome")
  ic2Notes     String?     @map("ic2_notes")

  workflowInstanceId String?  @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  investor Investor @relation(fields: [investorId], references: [investorId])

  @@map("investor_onboarding_case")
}

enum SanctionsScreenResult {
  CLEAR
  FLAGGED

  @@map("sanctions_screen_result")
}

enum RiskProfileGrade {
  LOW
  MEDIUM_LOW
  HIGH

  @@map("risk_profile_grade")
}

enum EddRecommendation {
  APPROVE_WITH_CONDITIONS
  DECLINE

  @@map("edd_recommendation")
}

enum MdOnboardingDecision {
  APPROVED
  DECLINED

  @@map("md_onboarding_decision")
}

enum Ic2Outcome {
  SATISFACTORY
  UNSATISFACTORY

  @@map("ic2_outcome")
}

// Invariant 28(a): every inflow captures payer identity + declared
// relationship to the beneficiary customer. UNMATCHED sits in SUSPENSE
// (never orphan-credited) until mapped — reserved here for a future
// bank-statement ingestion path; DECLARED_MATCHED is what createTxn()
// writes today when a third-party payer is declared against a known
// productAccountId. Third-party inflows always flag Compliance visibility
// per 28a, including stage-1 express accounts (which amends invariant 27's
// own-account-only default to declaration-based).
model PaymentInflowLog {
  id                    String              @id @default(uuid()) @db.Uuid
  txnId                 String?             @unique @map("txn_id") @db.Uuid
  payerName             String              @map("payer_name")
  payerBankName         String?             @map("payer_bank_name")
  payerAccountNumber    String?             @map("payer_account_number")
  declaredRelationship  String              @map("declared_relationship")
  beneficiaryInvestorId String?             @map("beneficiary_investor_id")
  status                PaymentInflowStatus @default(DECLARED_MATCHED)
  complianceFlagged     Boolean             @default(true) @map("compliance_flagged")
  declaredByUserId      String?             @map("declared_by_user_id") @db.Uuid
  createdAt             DateTime            @default(now()) @map("created_at")

  txn         Txn?      @relation(fields: [txnId], references: [id])
  beneficiary Investor? @relation(fields: [beneficiaryInvestorId], references: [investorId])

  @@map("payment_inflow_log")
}

enum PaymentInflowStatus {
  DECLARED_MATCHED
  SUSPENSE
  COMPLIANCE_FLAGGED

  @@map("payment_inflow_status")
}

// Invariant 28(d): "investor stage-1 express AND investee/counterparty
// intake exposed as PUBLIC portal forms feeding the SAME internal
// workflows (inv 27) — no parallel paths ... nothing public writes beyond
// intake staging." A public/unauthenticated submission NEVER calls
// InvestorService.onboardExpress()/CounterpartyService.onboard() directly
// — it only creates this staging row. A staff member (holding the same
// INVESTOR_ONBOARDING/COUNTERPARTY_ONBOARDING capability Flow A/B already
// require) reviews and promotes it, which is the ONLY path that actually
// calls the real onboarding service methods — same workflow, same
// capability gate, an anonymous submitter never bypasses either.
model PublicIntakeSubmission {
  id                      String             @id @default(uuid()) @db.Uuid
  intakeType              PublicIntakeType   @map("intake_type")
  payload                 Json
  status                  PublicIntakeStatus @default(PENDING)
  submittedIp             String?            @map("submitted_ip")
  rejectionReason         String?            @map("rejection_reason")
  promotedByUserId        String?            @map("promoted_by_user_id") @db.Uuid
  promotedAt              DateTime?          @map("promoted_at")
  resultingInvestorId     String?            @map("resulting_investor_id")
  resultingCounterpartyId String?            @map("resulting_counterparty_id") @db.Uuid
  createdAt               DateTime           @default(now()) @map("created_at")

  promotedBy                   AppUser?                      @relation("PublicIntakePromotedBy", fields: [promotedByUserId], references: [id])
  privacyNoticeAcknowledgments PrivacyNoticeAcknowledgment[]

  @@map("public_intake_submission")
}

enum PublicIntakeType {
  INVESTOR_EXPRESS
  COUNTERPARTY

  @@map("public_intake_type")
}

enum PublicIntakeStatus {
  PENDING
  PROMOTED
  REJECTED

  @@map("public_intake_status")
}

// ============================================================================
// Invariant 57(b)(i) (CHECK15, NDPA/GAID compliance pack): versioned,
// governed privacy-notice text (Compliance-owned config — the builder never
// invents notice copy; noticeText below is a placeholder until Compliance/
// DPO supplies the final text per NDP Act GAID Article 7(j)/(l)/(m) and
// Schedule 9) plus a durable, timestamped, WHO/WHEN/WHICH-VERSION
// acknowledgment log — same "immutable evidence trail" discipline as
// AuditTrail/ReportRun, but a lighter append-only table (no DB trigger)
// since acknowledgments are never corrected, only superseded by a fresh one
// against a newer notice version.
// ============================================================================
model PrivacyNoticeConfig {
  id              String             @id @default(uuid()) @db.Uuid
  version         Int                @unique
  noticeText      String             @map("notice_text")
  status          GovernedItemStatus @default(DRAFT)
  effectiveFrom   DateTime?          @map("effective_from")
  createdByUserId String             @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")

  createdBy       AppUser                       @relation(fields: [createdByUserId], references: [id])
  acknowledgments PrivacyNoticeAcknowledgment[]

  @@map("privacy_notice_config")
}

model PrivacyNoticeAcknowledgment {
  id                       String               @id @default(uuid()) @db.Uuid
  noticeConfigId           String               @map("notice_config_id") @db.Uuid
  context                  PrivacyNoticeContext
  investorId               String?              @map("investor_id")
  counterpartyId           String?              @map("counterparty_id") @db.Uuid
  publicIntakeSubmissionId String?              @map("public_intake_submission_id") @db.Uuid
  acknowledgedAt           DateTime             @default(now()) @map("acknowledged_at")
  ipAddress                String?              @map("ip_address")

  noticeConfig           PrivacyNoticeConfig     @relation(fields: [noticeConfigId], references: [id])
  investor               Investor?               @relation(fields: [investorId], references: [investorId])
  counterparty           Counterparty?           @relation(fields: [counterpartyId], references: [id])
  publicIntakeSubmission PublicIntakeSubmission? @relation(fields: [publicIntakeSubmissionId], references: [id])

  @@map("privacy_notice_acknowledgment")
}

enum PrivacyNoticeContext {
  INVESTOR_ONBOARDING_STAGE_1
  INVESTOR_ONBOARDING_STAGE_2
  COUNTERPARTY_ONBOARDING
  INVESTOR_PORTAL_FIRST_LOGIN
  COUNTERPARTY_PORTAL_FIRST_LOGIN
  PUBLIC_INTAKE

  @@map("privacy_notice_context")
}

// ============================================================================
// Invariant 28(b): BD marketing suite. "Resource library on the document
// register (branded materials, newsletters, publications; versioned,
// approval before external use)" — MarketingResource is its OWN model
// (not a bare DocumentRegisterEntry row) because it needs the version/
// status/approval-workflow lifecycle DocumentRegisterEntry deliberately
// doesn't carry (that table is a flat evidence-attachment log used
// elsewhere). "Mass-mail distribution via the notification engine" — no
// real notification engine (SMTP/provider integration) exists anywhere in
// this codebase yet (see investor.service.ts's kycExpiryAlerts comment);
// MarketingService.approveSend() does the REAL, testable part (resolving
// subscribed recipients by segment, logging one client_communication row
// per recipient) and is honest that actual email delivery is an
// unbuilt integration, not faked.
// ============================================================================

model MarketingResource {
  id                 String             @id @default(uuid()) @db.Uuid
  title              String
  resourceType       String             @map("resource_type")
  fileReference      String             @map("file_reference")
  version            Int                @default(1)
  status             GovernedItemStatus @default(DRAFT)
  proposedByUserId   String             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  proposedBy AppUser         @relation("MarketingResourceProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy AppUser?        @relation("MarketingResourceApprovedBy", fields: [approvedByUserId], references: [id])
  sends      MarketingSend[]

  @@map("marketing_resource")
}

// Invariant 28(b): "public subscribe/unsubscribe, segment lists." A
// subscriber is deliberately NOT required to be a known Investor/Lead —
// mass-mail distribution lists are broader than the BD register.
// unsubscribeToken is the standard email-marketing safeguard: only the
// holder of the emailed link can unsubscribe that address, never an
// unauthenticated guess against a bare email string.
model MarketingSubscriber {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique
  fullName             String?   @map("full_name")
  segments             String[]  @default([])
  subscribed           Boolean   @default(true)
  unsubscribeToken     String    @unique @map("unsubscribe_token")
  subscribedAt         DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt       DateTime? @map("unsubscribed_at")
  // Invariant 57(b)(i) (CHECK15): "marketing subscription gains an explicit
  // CONSENT record (timestamp + notice version; unsubscribe already
  // exists)" — consentedAt/consentNoticeVersion are set at subscribe time,
  // never backfilled for pre-existing rows (a null pair on a legacy
  // subscriber honestly means "consent record predates this feature," not a
  // fabricated timestamp).
  consentedAt          DateTime? @map("consented_at")
  consentNoticeVersion Int?      @map("consent_notice_version")

  @@map("marketing_subscriber")
}

// Invariant 28(b): "Distribution of anything client-facing requires the
// standing approval chain." The actual dispatch (resolving recipients +
// logging client_communication) happens INSIDE approveSend(), not as a
// separate unguarded step — there is no path from DRAFT straight to a
// distributed mailing without maker != checker.
model MarketingSend {
  id                 String              @id @default(uuid()) @db.Uuid
  resourceId         String?             @map("resource_id") @db.Uuid
  subject            String
  body               String
  targetSegments     String[]            @map("target_segments")
  status             MarketingSendStatus @default(DRAFT)
  initiatedByUserId  String              @map("initiated_by_user_id") @db.Uuid
  approvedByUserId   String?             @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?             @unique @map("workflow_instance_id") @db.Uuid
  sentAt             DateTime?           @map("sent_at")
  recipientCount     Int?                @map("recipient_count")
  createdAt          DateTime            @default(now()) @map("created_at")

  resource    MarketingResource? @relation(fields: [resourceId], references: [id])
  initiatedBy AppUser            @relation("MarketingSendInitiatedBy", fields: [initiatedByUserId], references: [id])
  approvedBy  AppUser?           @relation("MarketingSendApprovedBy", fields: [approvedByUserId], references: [id])

  @@map("marketing_send")
}

enum MarketingSendStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  REJECTED

  @@map("marketing_send_status")
}

// ============================================================================
// CHECK5 item 5g — Invariant 28(e): investee/counterparty portal, the
// SECOND portal-realm persona. Mirrors PortalClientUser/PortalClientSession
// EXACTLY (separate tables, not a shared/discriminated one) — same
// precedent as CounterpartyOnboardingCase vs InvestorOnboardingCase: "kept
// separate so investor and counterparty data never cross-reference each
// other by accident." Same cookie/guard as the investor persona (one
// realm, isolated from ops) — PortalAuthService.validateSession() tries
// this table when the investor table has no match for the token.
// ============================================================================
model PortalCounterpartyUser {
  id                  String     @id @default(uuid()) @db.Uuid
  counterpartyId      String     @unique @map("counterparty_id") @db.Uuid
  passwordHash        String?    @map("password_hash")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  status              UserStatus @default(ACTIVE)
  // Invariant 57(b)(i) (CHECK15): same first-login gate as PortalClientUser.
  firstLoginAt        DateTime?  @map("first_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")

  counterparty Counterparty                @relation(fields: [counterpartyId], references: [id])
  sessions     PortalCounterpartySession[]

  @@map("portal_counterparty_user")
}

model PortalCounterpartySession {
  id           String    @id @default(uuid()) @db.Uuid
  portalUserId String    @map("portal_user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  ipAddress    String?   @map("ip_address")

  portalUser PortalCounterpartyUser @relation(fields: [portalUserId], references: [id])

  @@index([portalUserId])
  @@map("portal_counterparty_session")
}

// Invariant 28(e): "EXTENSION/restructuring requests (respecting the
// DB-enforced 1-restructure/1-month limits)". Scoped deliberately narrower
// than invariant 25(4)'s full payment-reminder-ladder/DPD/credit-bureau-sync
// engine (that's its own Check-6 build) — this is just the portal request +
// staff decision + the two literal caps invariant 28(e) names. A request
// beyond either cap is refused outright (no "exception workflow" escalation
// path exists yet — that belongs to the Check-6 engine, not invented here).
// No WorkflowEngineService instance: the requester is a portal principal
// with no AppUser/capability row, so the generic engine's
// initiatedByUserId-must-hold-INITIATE check cannot apply — this is a
// direct capability-gated staff decision instead (same shape as
// MarketingService.subscribe(), a public action paired with a
// capability-gated staff one).
// Invariant 25(4) extends this (Check-6 reminder-ladder tranche):
// obligationId scopes a restructure to a SPECIFIC repayment obligation
// ("max 1 restructure per TRANSACTION" — invariant 25(4)'s own wording) —
// nullable so the pre-existing invariant 28(e) counterparty-level portal
// flow (no obligation concept existed yet) keeps working unmodified; new
// requests raised against an obligation get the DB-enforced limit (a
// partial unique index, migration-authored — see
// 20260706140000_check6f_reminder_ladder's own comment) rather than a
// service-layer-only check. workflowInstanceId is set ONLY when the
// 1-restructure/1-month cap is exceeded and the request must go through
// the COUNTERPARTY_RESTRUCTURE_EXCEPTION workflow instead of the direct
// capability-gated decision path.
model CounterpartyRestructureRequest {
  id                 String                               @id @default(uuid()) @db.Uuid
  counterpartyId     String                               @map("counterparty_id") @db.Uuid
  obligationId       String?                              @map("obligation_id") @db.Uuid
  requestType        CounterpartyRestructureRequestType   @map("request_type")
  extensionMonths    Int?                                 @map("extension_months")
  reason             String
  status             CounterpartyRestructureRequestStatus @default(PENDING)
  decidedByUserId    String?                              @map("decided_by_user_id") @db.Uuid
  decisionNotes      String?                              @map("decision_notes")
  decidedAt          DateTime?                            @map("decided_at")
  workflowInstanceId String?                              @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime                             @default(now()) @map("created_at")

  counterparty Counterparty                     @relation(fields: [counterpartyId], references: [id])
  obligation   CounterpartyRepaymentObligation? @relation(fields: [obligationId], references: [id])
  decidedBy    AppUser?                         @relation("CounterpartyRestructureDecidedBy", fields: [decidedByUserId], references: [id])

  @@map("counterparty_restructure_request")
}

enum CounterpartyRestructureRequestType {
  EXTENSION
  RESTRUCTURE

  @@map("counterparty_restructure_request_type")
}

enum CounterpartyRestructureRequestStatus {
  PENDING
  APPROVED
  DECLINED

  @@map("counterparty_restructure_request_status")
}

enum FacilityApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  DECLINED
  DISBURSED

  @@map("facility_application_status")
}

// Invariant 28(e)(ii)/(iii): a NEW facility request initiated FROM THE
// PORTAL, feeding the SAME governance chain as onboarding (no parallel
// path) — reuses ONBOARDING_IC_REVIEW/ONBOARDING_RISK_REVIEW, a distinct
// workflowTypeCode so the Workflow Inbox tells a facility request apart
// from a first-time onboarding case (same reasoning
// CounterpartyOnboardingCase's own comment gives). `status` here is NEVER
// hand-set to mirror a workflow step — it only carries the two states
// beyond what WorkflowInstance already tracks (DRAFT before a staff member
// pushes it into the governance chain; DISBURSED, a separate staff action
// past APPROVED). The live progress-bar label invariant 28(e)(iii) calls
// for is DERIVED at read time from WorkflowInstance + the pending step's
// requiredFunctionCode — see CounterpartyService.deriveApplicationStage().
model CounterpartyFacilityApplication {
  id                    String                    @id @default(uuid()) @db.Uuid
  counterpartyId        String                    @map("counterparty_id") @db.Uuid
  requestedAmountKobo   BigInt                    @map("requested_amount_kobo")
  purpose               String
  status                FacilityApplicationStatus @default(DRAFT)
  workflowInstanceId    String?                   @unique @map("workflow_instance_id") @db.Uuid
  disbursedByUserId     String?                   @map("disbursed_by_user_id") @db.Uuid
  disbursedAt           DateTime?                 @map("disbursed_at")
  // Invariant 36(d): "facility amount, targeted return, profit/principal
  // repayment dates flow FROM fund-accounting postings (single source) ->
  // counterparty dashboard AND the associated fund-account receivables
  // dashboards — no dual entry, no drift." Captured by Fund Accounting
  // (FUND_ACCOUNTING_RECEIVABLES capability) via recordFundAccountingTerms,
  // distinct from the Portfolio Officer's own disbursement confirmation
  // above — repaymentObligations (already FK'd to this row) is the SAME
  // "profit/principal repayment dates" data both dashboards read, never
  // duplicated into a second table.
  targetedReturnPct     Decimal?                  @map("targeted_return_pct") @db.Decimal(6, 2)
  termsRecordedByUserId String?                   @map("terms_recorded_by_user_id") @db.Uuid
  termsRecordedAt       DateTime?                 @map("terms_recorded_at")
  createdAt             DateTime                  @default(now()) @map("created_at")

  counterparty    Counterparty @relation(fields: [counterpartyId], references: [id])
  disbursedBy     AppUser?     @relation("FacilityApplicationDisbursedBy", fields: [disbursedByUserId], references: [id])
  termsRecordedBy AppUser?     @relation("FacilityApplicationTermsRecordedBy", fields: [termsRecordedByUserId], references: [id])

  repaymentObligations CounterpartyRepaymentObligation[]
  investmentMemos      InvestmentMemo[]

  @@map("counterparty_facility_application")
}

enum InvestmentMemoStatus {
  DRAFT
  SUBMITTED
  CIO_APPROVED
  // Invariant 49(g)(iii) (CHECK11): the AT_OR_ABOVE_THRESHOLD chain's real
  // terminal approver is MD/CEO (steps: PM_VALIDATION -> CIO_APPROVAL ->
  // INVESTMENT_COMMITTEE_APPROVAL -> MD_APPROVAL) -- writing CIO_APPROVED
  // as the terminal status regardless of which step actually closed the
  // chain named a specific approver identity (CIO) that was wrong for
  // every at/above-threshold memo, a truth-in-registers defect distinct
  // from generic terminal labels like DISTRIBUTION's DECLARED/PAID.
  // CIO_APPROVED remains correct and unchanged for the BELOW_THRESHOLD
  // chain, whose real terminal approver genuinely is the CIO.
  MD_APPROVED
  CIO_REJECTED

  @@map("investment_memo_status")
}

// Invariant 36(f): "structured memo template (deal summary, structure/
// contract type, amounts, tenor, target return, risk notes, Shariah notes,
// collateral) attachable/insertable at the facility application as the
// Portfolio Officer's POINT OF REQUEST -> routes PO -> CIO approval ->
// subsequent stakeholders per approval matrix; memo versions in document
// register; approval comments bind to memo version; memo becomes part of
// the facility's permanent file." Versioned (one row per revision, never
// mutated after CIO decision) — same "supersede via a new row, never
// overwrite a decided one" discipline as every other governed-decision
// model in this codebase (AccountingFrameworkMap, RiskAppetiteMatrixVersion).
// targetReturnPct here is the PO's OWN proposed figure at request time —
// deliberately distinct from CounterpartyFacilityApplication.targetedReturnPct
// (invariant 36(d)'s Fund-Accounting-recorded actual, set only after
// disbursement) so the two "single source" doctrines never collide.
model InvestmentMemo {
  id                    String               @id @default(uuid()) @db.Uuid
  facilityApplicationId String               @map("facility_application_id") @db.Uuid
  version               Int
  dealSummary           String               @map("deal_summary")
  structureType         String               @map("structure_type")
  amountKobo            BigInt               @map("amount_kobo")
  tenorMonths           Int                  @map("tenor_months")
  targetReturnPct       Decimal              @map("target_return_pct") @db.Decimal(6, 2)
  riskNotes             String               @map("risk_notes")
  shariahNotes          String               @map("shariah_notes")
  collateralNotes       String               @map("collateral_notes")
  status                InvestmentMemoStatus @default(DRAFT)
  workflowInstanceId    String?              @unique @map("workflow_instance_id") @db.Uuid
  // Invariant 46(c) (CEO directive, 7-Jul-2026): "Investment Committee ...
  // committee approval records an icResolutionRef, same pattern as
  // strategy-layer's boardResolutionRef." Nullable -- only ever set once
  // the memo's amount is at/above the governed threshold and the IC step
  // is actually reached; below-threshold memos (PO -> PM -> CIO only) never
  // populate it.
  icResolutionRef       String?              @map("ic_resolution_ref")
  createdByUserId       String               @map("created_by_user_id") @db.Uuid
  createdAt             DateTime             @default(now()) @map("created_at")

  facilityApplication CounterpartyFacilityApplication @relation(fields: [facilityApplicationId], references: [id])
  createdBy           AppUser                         @relation("InvestmentMemoCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([facilityApplicationId, version])
  @@map("investment_memo")
}

// Invariant 46(c)/46(g)(i) (CEO directive, 7-Jul-2026): "thresholds are
// governed config, adjustable by authorized level through the standing
// approval workflow" -- the DoA-tier boundary for the investment memo
// chain (below threshold: PO -> PM validation -> CIO; at/above: PO -> PM
// validation -> CIO -> IC -> MD/CEO). Deliberately NOT baked into a static
// ApprovalRule.minAmountKobo/maxAmountKobo seed row (the mechanism
// DISTRIBUTION's tiers use) -- that would make the boundary a code/seed
// change, exactly what this CEO ruling says it must NOT be. Instead
// CounterpartyService.submitInvestmentMemoForCioApproval reads the current
// ACTIVE row live and selects the 'BELOW_THRESHOLD'/'AT_OR_ABOVE_THRESHOLD'
// scenario itself -- the same "scenario selects a rule outside the
// amount-tier logic entirely" mechanism DISTRIBUTION_LOSS/
// DISTRIBUTION_PENALTY_TO_CHARITY already use, just chosen by live config
// instead of a fixed scenario name.
model InvestmentMemoThresholdConfig {
  id                 String             @id @default(uuid()) @db.Uuid
  version            Int
  thresholdKobo      BigInt             @map("threshold_kobo")
  status             GovernedItemStatus @default(DRAFT)
  // Not a Prisma relation -- same pattern as most other workflowInstanceId
  // columns in this schema (see line ~3371's own comment): avoids bloating
  // WorkflowInstance's back-relation array for a link that's read by id,
  // not joined through.
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  createdByUserId    String             @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  createdBy  AppUser  @relation("InvMemoThresholdCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy AppUser? @relation("InvMemoThresholdApprovedBy", fields: [approvedByUserId], references: [id])

  @@unique([version])
  @@map("investment_memo_threshold_config")
}

enum RepaymentObligationStatus {
  PENDING
  PAID
  RESTRUCTURED
  DEFAULTED

  @@map("repayment_obligation_status")
}

// Invariant 25(4): the due-date-bearing installment the payment-reminder
// ladder keys off — no such concept existed in this codebase before this
// tranche (Txn has valueDate, not a repayment due date). facilityApplicationId
// is nullable since a repayment obligation can also be recorded for a
// pre-existing facility that predates this tranche.
model CounterpartyRepaymentObligation {
  id                    String                    @id @default(uuid()) @db.Uuid
  counterpartyId        String                    @map("counterparty_id") @db.Uuid
  facilityApplicationId String?                   @map("facility_application_id") @db.Uuid
  dueDate               DateTime                  @map("due_date")
  amountKobo            BigInt                    @map("amount_kobo")
  status                RepaymentObligationStatus @default(PENDING)
  paidAt                DateTime?                 @map("paid_at")
  paidByUserId          String?                   @map("paid_by_user_id") @db.Uuid
  createdByUserId       String                    @map("created_by_user_id") @db.Uuid
  createdAt             DateTime                  @default(now()) @map("created_at")

  counterparty        Counterparty                     @relation(fields: [counterpartyId], references: [id])
  facilityApplication CounterpartyFacilityApplication? @relation(fields: [facilityApplicationId], references: [id])
  restructureRequests CounterpartyRestructureRequest[]
  reminderNotices     PaymentReminderNoticeLog[]
  dispatchQueueItems  PaymentReminderDispatchQueue[]

  @@map("counterparty_repayment_obligation")
}

// Invariant 25(4): "Ladder (all steps = config rows)." dayOffset is signed
// relative to the obligation's dueDate (negative = before, 0 = due date,
// positive = grace-period day); isPostGraceDefault marks the ONE row
// (dayOffset = +6, past the T+5 grace window) that transitions the
// obligation to DEFAULTED rather than merely sending another notice — a
// config-driven transition, not a hardcoded "day 6" check in the sweep.
model PaymentReminderLadderConfig {
  id                      String   @id @default(uuid()) @db.Uuid
  dayOffset               Int      @map("day_offset")
  channels                Json
  notifyManagement        Boolean  @default(false) @map("notify_management")
  createsFollowUpCallTask Boolean  @default(false) @map("creates_follow_up_call_task")
  isPostGraceDefault      Boolean  @default(false) @map("is_post_grace_default")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  // Invariant 36(b): "ladder timing adjustable... changes versioned + audit-
  // logged." The CURRENT row is this table (effective NEXT sweep); the
  // VERSION history is the standing insert-only audit_trail (same doctrine
  // as every other simple governed-config update in this codebase, e.g.
  // WmFxConfig — a bespoke propose/approve version table is reserved for
  // Board-gated content, which this settings screen explicitly is NOT:
  // "AUTHORIZED LEVEL ONLY (capability + DoA)", not a Board resolution).
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([dayOffset])
  @@map("payment_reminder_ladder_config")
}

// Dedup guard — "reminder ladder fires per config" (once per rung per
// obligation), and the audit trail proving every notice was auto-logged to
// client_communication (invariant 25(4)'s own explicit requirement). Rows
// are created ONLY on actual dispatch (invariant 36(a) — officer-validated),
// never at generation time; see PaymentReminderDispatchQueue for the
// pending-validation staging state.
model PaymentReminderNoticeLog {
  id                    String   @id @default(uuid()) @db.Uuid
  obligationId          String   @map("obligation_id") @db.Uuid
  dayOffset             Int      @map("day_offset")
  clientCommunicationId String?  @map("client_communication_id") @db.Uuid
  sentAt                DateTime @default(now()) @map("sent_at")

  obligation CounterpartyRepaymentObligation @relation(fields: [obligationId], references: [id])

  @@unique([obligationId, dayOffset])
  @@map("payment_reminder_notice_log")
}

enum PaymentReminderDispatchStatus {
  PENDING_VALIDATION
  DISPATCHED
  REJECTED

  @@map("payment_reminder_dispatch_status")
}

// Invariant 36(a): "ladder EMAILS auto-generate but DISPATCH only after
// officer validation (one-click approve from queue); SMS/WhatsApp
// likewise post-validation." The sweep GENERATES a row here (client-facing
// message channels only — PHONE-CALL rungs and internal management
// notices bypass this queue entirely, since a call task IS the dispatch
// and an internal notice carries no client-facing risk to gate); an
// officer must approve before ClientCommunication/PaymentReminderNoticeLog
// are ever written.
model PaymentReminderDispatchQueue {
  id              String                        @id @default(uuid()) @db.Uuid
  obligationId    String                        @map("obligation_id") @db.Uuid
  dayOffset       Int                           @map("day_offset")
  channels        Json
  status          PaymentReminderDispatchStatus @default(PENDING_VALIDATION)
  generatedAt     DateTime                      @default(now()) @map("generated_at")
  decidedByUserId String?                       @map("decided_by_user_id") @db.Uuid
  decidedAt       DateTime?                     @map("decided_at")

  obligation CounterpartyRepaymentObligation @relation(fields: [obligationId], references: [id])
  decidedBy  AppUser?                        @relation(fields: [decidedByUserId], references: [id])

  @@unique([obligationId, dayOffset])
  @@map("payment_reminder_dispatch_queue")
}

// Invariant 28(f): complaint ticket — client-portal-raisable (investor OR
// counterparty, exactly one of investorId/counterpartyId set, DB CHECK
// enforced in the migration) or staff-logged-on-behalf (loggedByUserId
// set). slaDueAt/status feed both the SEC template B register export
// (regulatory-reporting.service.ts's COMPLAINT_REGISTER_ROWS AUTO key) and
// KRI CPL-03 (kri-engine.service.ts) — "complaint volume/aging = KRI feed".
// No WorkflowEngineService entry: resolution is an operational ticket
// lifecycle (owner/escalation/resolve), not a maker!=checker approval
// chain — nothing in inv 28(f) calls for dual signoff to close a ticket.
model Complaint {
  id                String          @id @default(uuid()) @db.Uuid
  investorId        String?         @map("investor_id")
  counterpartyId    String?         @map("counterparty_id") @db.Uuid
  category          String
  description       String
  status            ComplaintStatus @default(OPEN)
  receivedAt        DateTime        @default(now()) @map("received_at")
  slaDueAt          DateTime        @map("sla_due_at")
  ownerUserId       String?         @map("owner_user_id") @db.Uuid
  escalatedAt       DateTime?       @map("escalated_at")
  escalatedToUserId String?         @map("escalated_to_user_id") @db.Uuid
  resolvedAt        DateTime?       @map("resolved_at")
  resolutionNotes   String?         @map("resolution_notes")
  loggedByUserId    String?         @map("logged_by_user_id") @db.Uuid
  // Invariant 57(b)(ii) (CHECK15, NDPA/GAID): the Enquiries channel doubles
  // as the DSR (data-subject request) intake per the charter's own
  // instruction — a DSR is a tagged Complaint, not a parallel table. isDsr
  // is the Compliance-queue filter; dsrCategory is one of the NDP Act Part
  // VI rights (Articles 36-39); dsrLegalBasis is recorded at resolution and
  // is REQUIRED for DSR rows (erasure refusals citing SEC/AML retention are
  // lawful — the response, not silence, is the obligation).
  isDsr             Boolean         @default(false) @map("is_dsr")
  dsrCategory       DsrCategory?    @map("dsr_category")
  dsrLegalBasis     String?         @map("dsr_legal_basis")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  investor     Investor?     @relation(fields: [investorId], references: [investorId])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  owner        AppUser?      @relation("ComplaintOwner", fields: [ownerUserId], references: [id])
  escalatedTo  AppUser?      @relation("ComplaintEscalatedTo", fields: [escalatedToUserId], references: [id])
  loggedBy     AppUser?      @relation("ComplaintLoggedBy", fields: [loggedByUserId], references: [id])

  @@map("complaint")
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@map("complaint_status")
}

// Invariant 57(b)(ii): NDP Act GAID Part VI (Articles 36-39) data-subject
// rights, used to tag a Complaint as a DSR.
enum DsrCategory {
  ACCESS
  RECTIFICATION
  ERASURE
  OBJECTION
  PORTABILITY

  @@map("dsr_category")
}

// Governed config (invariant 10), same singleton-row shape as
// ComplaintSlaConfig immediately above. responseDays default of 30 is NOT
// an invented figure — it is transcribed directly from the GAID's own
// Schedule 9 (SNAG template): "You are to immediately address the
// complaint ... or within 30 days – whichever is earlier." Compliance/DPO
// may version a different figure once a formal DSR SLA is ratified.
model DsrResponseConfig {
  id                 Int                @id @default(1)
  version            Int                @default(1)
  status             GovernedItemStatus @default(ACTIVE)
  responseDays       Int                @default(30) @map("response_days")
  boardResolutionRef String?            @map("board_resolution_ref")
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  @@map("dsr_response_config")
}

// Invariant 57(b)(iii) (CHECK15): governed config mapping each data class to
// a retention period, statutory basis, and disposal treatment. Modeled
// after RiskAppetiteMatrixVersion's "never invent a value" pattern, NOT
// ComplaintSlaConfig's seeded-default pattern: retentionPeriodMonths ships
// NULL and status DRAFT until Compliance/DPO confirms a real figure —
// "retained indefinitely per financial-records law" is a VALID documented
// entry once confirmed; an unconfirmed NULL is honestly incomplete, never a
// guessed number. The exceptions are rows whose disposal treatment is
// already a structural FACT about this platform (e.g. AuditTrail is
// insert-only at the DB engine) — those are seeded ACTIVE because they
// describe existing enforced behavior, not a business policy choice.
model RetentionScheduleEntry {
  id                    String             @id @default(uuid()) @db.Uuid
  dataClass             String             @map("data_class")
  description           String?
  retentionPeriodMonths Int?               @map("retention_period_months")
  statutoryBasis        String?            @map("statutory_basis")
  disposalTreatment     String?            @map("disposal_treatment")
  status                GovernedItemStatus @default(DRAFT)
  confirmedByUserId     String?            @map("confirmed_by_user_id") @db.Uuid
  confirmedAt           DateTime?          @map("confirmed_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  confirmedBy AppUser? @relation(fields: [confirmedByUserId], references: [id])

  @@map("retention_schedule_entry")
}

// Invariant 57(b)(iv) (CHECK15): incident entry -> severity/eligibility
// assessment -> 72-hour NDPC notification tracking (Article 33/Section 40(2)
// of the NDP Act: "within 72 hours of becoming aware") + data-subject
// notification where required -> post-incident record. "Feeds the risk
// module" via KRI CPL-06 (kri-roster.ts), the same live-derived-count
// pattern CPL-03/CPL-05 already use — no row is written into
// RiskRegisterEntry directly (that table is board-approved risk categories,
// not an incident log).
model DataBreachRegisterEntry {
  id                               String               @id @default(uuid()) @db.Uuid
  discoveredAt                     DateTime             @map("discovered_at")
  discoveredByUserId               String               @map("discovered_by_user_id") @db.Uuid
  description                      String
  affectedDataClasses              String[]             @map("affected_data_classes")
  estimatedAffectedSubjects        Int?                 @map("estimated_affected_subjects")
  severity                         BreachSeverity       @default(UNASSESSED)
  likelyHighRisk                   Boolean?             @map("likely_high_risk")
  assessmentNotes                  String?              @map("assessment_notes")
  assessedAt                       DateTime?            @map("assessed_at")
  assessedByUserId                 String?              @map("assessed_by_user_id") @db.Uuid
  // NDP Act Section 40(2): computed at creation as discoveredAt + 72 hours —
  // never re-derived from "now," so the deadline doesn't silently drift.
  ndpcNotificationDeadline         DateTime             @map("ndpc_notification_deadline")
  ndpcNotifiedAt                   DateTime?            @map("ndpc_notified_at")
  ndpcNotifiedByUserId             String?              @map("ndpc_notified_by_user_id") @db.Uuid
  dataSubjectsNotificationRequired Boolean?             @map("data_subjects_notification_required")
  dataSubjectsNotifiedAt           DateTime?            @map("data_subjects_notified_at")
  status                           BreachRegisterStatus @default(OPEN)
  postIncidentNotes                String?              @map("post_incident_notes")
  closedAt                         DateTime?            @map("closed_at")
  closedByUserId                   String?              @map("closed_by_user_id") @db.Uuid
  createdAt                        DateTime             @default(now()) @map("created_at")

  discoveredBy   AppUser  @relation("BreachDiscoveredBy", fields: [discoveredByUserId], references: [id])
  assessedBy     AppUser? @relation("BreachAssessedBy", fields: [assessedByUserId], references: [id])
  ndpcNotifiedBy AppUser? @relation("BreachNdpcNotifiedBy", fields: [ndpcNotifiedByUserId], references: [id])
  closedBy       AppUser? @relation("BreachClosedBy", fields: [closedByUserId], references: [id])

  @@map("data_breach_register_entry")
}

enum BreachSeverity {
  UNASSESSED
  LOW
  MODERATE
  HIGH
  CRITICAL

  @@map("breach_severity")
}

enum BreachRegisterStatus {
  OPEN
  ASSESSED
  NDPC_NOTIFIED
  DATA_SUBJECTS_NOTIFIED
  CLOSED

  @@map("breach_register_status")
}

// Invariant 61(b)/(c) (CEO ruling, 9-Jul-2026, CHECK15): Executive
// Oversight Mode -- MD_CEO (or a role the governed policy below later
// extends this to) can view an investor/counterparty's own read-only
// record surface, every session logged. Deliberately a SEPARATE table from
// the real PortalClientSession/PortalCounterpartySession -- an oversight
// "session" is never usable as a portal login and never touches those
// tables at all, so there is structurally no path for an oversight grant
// to be replayed as real client access.
enum OversightPrincipalType {
  INVESTOR
  COUNTERPARTY

  @@map("oversight_principal_type")
}

// One row per oversight viewing session -- doubles as both the session
// record AND the "who viewed whom, when, duration" standing register
// invariant 61(b) calls for (startedAt/endedAt is the full audit shape;
// no separate log table needed).
model ExecOversightSession {
  id             String                 @id @default(uuid()) @db.Uuid
  principalType  OversightPrincipalType @map("principal_type")
  investorId     String?                @map("investor_id")
  counterpartyId String?                @map("counterparty_id") @db.Uuid
  viewedByUserId String                 @map("viewed_by_user_id") @db.Uuid
  startedAt      DateTime               @default(now()) @map("started_at")
  endedAt        DateTime?              @map("ended_at")
  ipAddress      String?                @map("ip_address")

  investor     Investor?     @relation(fields: [investorId], references: [investorId])
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id])
  viewedByUser AppUser       @relation(fields: [viewedByUserId], references: [id])

  @@index([viewedByUserId])
  @@index([investorId])
  @@index([counterpartyId])
  @@map("exec_oversight_session")
}

// Invariant 61(c) ("the dial"): "oversight-mode grant and any future
// narrowing of executive visibility are governed config changes through
// the standing approval route (never a code change) ... every widening/
// narrowing is versioned and audit-trailed." Same versioned DRAFT->ACTIVE
// shape as RiskAppetiteMatrixVersion. grantedRoleCodes is checked by
// ExecOversightService IN ADDITION TO the static EXEC_OVERSIGHT RBAC
// capability (defense in depth) -- narrowing this list takes effect
// immediately on approval, no redeploy required, unlike RBAC role_
// permission grants which remain a seed/deploy-time change.
model ExecOversightPolicy {
  id               String             @id @default(uuid()) @db.Uuid
  version          Int
  status           GovernedItemStatus @default(DRAFT)
  grantedRoleCodes Json               @map("granted_role_codes")
  proposedByUserId String             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId String?            @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?          @map("approved_at")
  createdAt        DateTime           @default(now()) @map("created_at")

  proposedByUser AppUser  @relation("ExecOversightPolicyProposedBy", fields: [proposedByUserId], references: [id])
  approvedByUser AppUser? @relation("ExecOversightPolicyApprovedBy", fields: [approvedByUserId], references: [id])

  @@unique([version])
  @@map("exec_oversight_policy")
}

// Governed config (invariant 10: no hardcoded thresholds) — single ACTIVE
// row seeded directly, same precedent as InvestorOnboardingConfig/
// TaxRuleConfig ("a CEO-supplied number is the approval, not a placeholder
// awaiting one"). amberThresholdPct reuses invariant 25's own literal
// "70%-elapsed -> AMBER" figure (the CEO's own number for exactly this
// elapsed-window-escalation shape), not an invented threshold.
model ComplaintSlaConfig {
  id                 Int                @id @default(1)
  version            Int                @default(1)
  status             GovernedItemStatus @default(ACTIVE)
  slaDays            Int                @map("sla_days")
  amberThresholdPct  Int                @map("amber_threshold_pct")
  boardResolutionRef String?            @map("board_resolution_ref")
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  @@map("complaint_sla_config")
}

// Check-5B item 1: the platform scheduler framework's run-log. Job
// DEFINITIONS (code, cadence, what it invokes) live in code
// (scheduler.types.ts's roster) per "config carries vocabulary, code
// carries resolution" — there is no governed business threshold here, just
// wiring — but every EXECUTION is real operational history, hence a table,
// not a log file. scheduledFor is the slot the job was due for (not
// necessarily "now" — a catch-up run's scheduledFor is the missed slot,
// startedAt is when it actually ran).
model ScheduledJobRun {
  id                String                @id @default(uuid()) @db.Uuid
  jobCode           String                @map("job_code")
  scheduledFor      DateTime              @map("scheduled_for")
  startedAt         DateTime              @map("started_at")
  completedAt       DateTime?             @map("completed_at")
  status            ScheduledJobRunStatus
  isCatchUp         Boolean               @default(false) @map("is_catch_up")
  // Check-6A item 2 (invariant 32): a run triggered by ICT's manual RE-RUN
  // console action, distinct from a normal scheduled fire or a catch-up —
  // the console's "does this failure/recovery story reconcile" view reads
  // this alongside isCatchUp.
  isManualRerun     Boolean               @default(false) @map("is_manual_rerun")
  triggeredByUserId String?               @map("triggered_by_user_id") @db.Uuid
  resultSummary     Json?                 @map("result_summary")
  errorMessage      String?               @map("error_message")
  createdAt         DateTime              @default(now()) @map("created_at")

  triggeredBy AppUser? @relation("ScheduledJobRunTriggeredBy", fields: [triggeredByUserId], references: [id])

  @@index([jobCode, scheduledFor])
  @@map("scheduled_job_run")
}

enum ScheduledJobRunStatus {
  RUNNING
  SUCCEEDED
  FAILED

  @@map("scheduled_job_run_status")
}

// RES-001 F-02 (CHECK23, v1.0.2): "make backup.ps1 failures visible to the
// app" — the CEO's own words: "a silently failing backup is the worst
// kind." One row per backup.ps1 invocation, reported by the script itself
// via POST /ops/backup-runs/report (a shared-secret-token-gated, session-
// less endpoint — the Windows Scheduled Task running backup.ps1 has no
// staff session to authenticate with). Read side (GET /ops/backup-runs)
// feeds F-03's health view. No FK to AppUser/anything — this is an
// infra-operational fact reported by a script, not a user-attributed
// domain action.
model BackupRun {
  id               String          @id @default(uuid()) @db.Uuid
  dbName           String          @map("db_name")
  startedAt        DateTime        @map("started_at")
  completedAt      DateTime        @map("completed_at")
  status           BackupRunStatus
  dumpSizeBytes    BigInt?         @map("dump_size_bytes")
  offMachineCopyOk Boolean?        @map("off_machine_copy_ok")
  errorMessage     String?         @map("error_message")
  reportedAt       DateTime        @default(now()) @map("reported_at")

  @@index([startedAt])
  @@map("backup_run")
}

enum BackupRunStatus {
  SUCCEEDED
  FAILED

  @@map("backup_run_status")
}

// Check-6A item 2 (invariant 32): one row per job code — the console's
// pause/resume state. Pausing a NON-consequential job is direct (ICT,
// unilateral); pausing a CONSEQUENTIAL job (accruals, KRI batch, integrity
// check) only ever flips isPaused here via SchedulerService.
// approvePauseRequest(), itself only reachable from a WorkflowInstance
// reaching APPROVED (SCHEDULER_JOB_PAUSE workflow type, DoA-gated) — there
// is deliberately no direct "just set isPaused=true" path for a
// consequential job. Resuming is always unilateral (ICT) — restoring
// normal service is the safe direction, same reasoning as
// DelegationOfAuthority's unilateral revocation.
model ScheduledJobPauseState {
  jobCode                 String    @id @map("job_code")
  isPaused                Boolean   @default(false) @map("is_paused")
  pausedAt                DateTime? @map("paused_at")
  pausedByUserId          String?   @map("paused_by_user_id") @db.Uuid
  pauseReason             String?   @map("pause_reason")
  pauseWorkflowInstanceId String?   @map("pause_workflow_instance_id") @db.Uuid
  resumedAt               DateTime? @map("resumed_at")
  resumedByUserId         String?   @map("resumed_by_user_id") @db.Uuid
  updatedAt               DateTime  @updatedAt @map("updated_at")

  pausedBy  AppUser? @relation("SchedulerJobPausedBy", fields: [pausedByUserId], references: [id])
  resumedBy AppUser? @relation("SchedulerJobResumedBy", fields: [resumedByUserId], references: [id])

  @@map("scheduled_job_pause_state")
}

// Invariant 37(f): "authorized users can ADD a scheduled job from the JOB
// CATALOG (registered job types w/ config), REMOVE/retire, and toggle
// automation per job." The catalog of registered job TYPES is code
// (SchedulerService.buildJobs() — each has a real run() closure wired to
// a specific engine, so a genuinely arbitrary runtime-authored job isn't
// possible without re-architecting job dispatch into a generic registry).
// What this table adds is the ACTIVE/RETIRED membership of a code-defined
// job type in the running roster. Absence of a row for a jobCode means
// ACTIVE (today's behavior, unchanged) — a row only exists once a job has
// actually been retired at least once, so this migration touches zero
// existing job behavior.
model ScheduledJobRegistration {
  jobCode                  String    @id @map("job_code")
  isRetired                Boolean   @default(false) @map("is_retired")
  registeredAt             DateTime? @map("registered_at")
  registeredByUserId       String?   @map("registered_by_user_id") @db.Uuid
  retiredAt                DateTime? @map("retired_at")
  retiredByUserId          String?   @map("retired_by_user_id") @db.Uuid
  retireReason             String?   @map("retire_reason")
  retireWorkflowInstanceId String?   @map("retire_workflow_instance_id") @db.Uuid
  updatedAt                DateTime  @updatedAt @map("updated_at")

  registeredBy AppUser? @relation("SchedulerJobRegisteredBy", fields: [registeredByUserId], references: [id])
  retiredBy    AppUser? @relation("SchedulerJobRetiredBy", fields: [retiredByUserId], references: [id])

  @@map("scheduled_job_registration")
}

// ============================================================================
// Check-6B item 2: AI Services Layer foundation (invariant 33, amended (e)
// plus new (f) -- CEO ruling 2026-07-06). One17AIService is the SOLE door
// to any AI capability; every model below backs one of the four gates or
// the gateway's own mechanics (caching, token budgets, kill switch,
// immutable interaction log). Provider slot ships EMPTY (FinCon
// contracting pending); every flag ships OFF (invariant 33e).
// ============================================================================

// Gate 1: global per-capability on/off. One row per AI capability code
// (AI_CHAT, AI_SUMMARIZE, ... -- see seed.ts). Flipping is a DoA-governed
// workflow (AI_CAPABILITY_FLAG_TOGGLE); the separate AiKillSwitch below
// overrides ALL flags instantly and is unilateral (ICT-executable), same
// emergency-stop precedent as DelegationOfAuthority revocation.
model AiCapabilityFlag {
  capabilityCode     String   @id @map("capability_code")
  isEnabled          Boolean  @default(false) @map("is_enabled")
  updatedByUserId    String?  @map("updated_by_user_id") @db.Uuid
  workflowInstanceId String?  @map("workflow_instance_id") @db.Uuid
  updatedAt          DateTime @updatedAt @map("updated_at")

  updatedBy AppUser? @relation(fields: [updatedByUserId], references: [id])

  @@map("ai_capability_flag")
}

// Singleton (id=1). Overrides every AiCapabilityFlag instantly regardless
// of individual state -- checked FIRST, before gate 1, in the gateway.
model AiKillSwitch {
  id                Int      @id @default(1)
  isActive          Boolean  @default(false) @map("is_active")
  activatedByUserId String?  @map("activated_by_user_id") @db.Uuid
  reason            String?
  updatedAt         DateTime @updatedAt @map("updated_at")

  activatedBy AppUser? @relation(fields: [activatedByUserId], references: [id])

  @@map("ai_kill_switch")
}

// Gate 3: capability x context. Outside its permitted context, a granted
// capability is silent (invariant 33f-3) -- e.g. AI_SHARIAH_ASSIST usable
// ONLY inside a Shariah-review workflow step; AI_REPORT_DRAFT only within
// a report workspace (a stakeholder_report_run in DRAFT); org_unit scoping
// where a capability is department-bound.
model AiCapabilityContextRule {
  capabilityCode           String        @id @map("capability_code")
  contextType              AiContextType @map("context_type")
  requiredWorkflowTypeCode String?       @map("required_workflow_type_code")
  requiredOrgUnitCode      String?       @map("required_org_unit_code")

  requiredOrgUnit OrgUnit? @relation(fields: [requiredOrgUnitCode], references: [code])

  @@map("ai_capability_context_rule")
}

enum AiContextType {
  NONE
  WORKFLOW_STEP
  REPORT_WORKSPACE
  ORG_UNIT_SCOPED

  @@map("ai_context_type")
}

// Invariant 33(e), amended: COMMERCIAL provider strategy under a TIERED
// MODEL POLICY -- mid-tier default, frontier tier reserved for
// AI_SHARIAH_ASSIST + AI_REPORT_DRAFT. providerName/modelName are the
// actual vendor slot -- ships NULL (empty) until FinCon completes
// contracting; tier itself is real, decided config.
model AiTieredModelPolicy {
  capabilityCode String      @id @map("capability_code")
  tier           AiModelTier
  providerName   String?     @map("provider_name")
  modelName      String?     @map("model_name")

  @@map("ai_tiered_model_policy")
}

enum AiModelTier {
  MID_TIER
  FRONTIER_TIER

  @@map("ai_model_tier")
}

// Invariant 73(b) (CHECK27): the AI gateway's own credential store -- same
// standing adapter pattern as Payment/Bureau/Attendance/Calendar (write-only
// masked secret, propose/approve maker!=checker, inactive until approved).
// providerSlot 1/2/3 map by convention to Anthropic Claude / OpenAI / a
// third tenant-named vendor; providerName here is the value
// AiTieredModelPolicy.providerName should match so a capability's tier
// config resolves to a REAL credentialed vendor, never a bare label.
// isActive stays false until a tenant explicitly activates -- invariant
// 33(e)'s "all flags ship OFF" extended to per-tenant, not One17-blocked.
model AiProviderCredential {
  id                 String  @id @default(uuid()) @db.Uuid
  providerSlot       Int     @unique @map("provider_slot")
  providerName       String  @map("provider_name")
  apiKey             String? @map("api_key")
  // Base URL override -- required for the config-defined third slot (any
  // OpenAI-compatible or self-hosted endpoint), unused/null for the two
  // named vendors' default endpoints.
  baseUrl            String? @map("base_url")
  isActive           Boolean @default(false) @map("is_active")
  configuredByUserId String? @map("configured_by_user_id") @db.Uuid

  pendingProviderName      String?  @map("pending_provider_name")
  pendingApiKey            String?  @map("pending_api_key")
  pendingBaseUrl           String?  @map("pending_base_url")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_provider_credential")
}

// Per-department token budget, metered through the budget module (org_unit
// is the existing cost-centre anchor, Budget Spec §1). Exhausted budget =
// graceful refusal, SAU-visible (via listBudgets/queryable log) -- never a
// crash, never silently unmetered spend.
model AiTokenBudget {
  id             String @id @default(uuid()) @db.Uuid
  orgUnitCode    String @map("org_unit_code")
  periodYear     Int    @map("period_year")
  periodMonth    Int    @map("period_month")
  tokenLimit     Int    @map("token_limit")
  tokensConsumed Int    @default(0) @map("tokens_consumed")

  orgUnit OrgUnit @relation(fields: [orgUnitCode], references: [code])

  @@unique([orgUnitCode, periodYear, periodMonth])
  @@map("ai_token_budget")
}

// The curated, versioned, governed AI vocabulary invariant 22 named and
// never built (data_point_catalog) -- closed here as part of the AI
// foundation. Gate 4 (data scope) checks the ASKING USER against a data
// point's requiredFunctionCode/requiredLevel before including it in any
// assembled AI context -- the classic RAG leak, precluded structurally: the
// gateway never reads a raw table, only catalog-registered, capability-
// gated points.
model DataPointCatalog {
  code                 String              @id
  label                String
  description          String
  requiredFunctionCode String              @map("required_function_code")
  requiredLevel        String              @map("required_level")
  sourceType           DataPointSourceType @map("source_type")
  // REPORT_RUN_FIELD: a figures-JSON key on a specific report_run-shaped
  // row. LIVE_QUERY: a name in One17AIService's own small, explicit
  // resolver whitelist (never a free-form query the model could steer).
  sourceRef            String              @map("source_ref")
  // Invariant 57(b)(v) (CHECK15): honest classification of whether this
  // data point's value can carry personal data (name, contact, BVN/NIN,
  // bank account, address, DOB, etc.) — not an AI judgment, a data-catalog
  // fact set once per point. Feeds AiInteractionLog.
  // personalDataPointCodesIncluded so every AI invocation carries an
  // auditable minimization record of exactly which personal-data points
  // were actually sent to the vendor.
  containsPersonalData Boolean             @default(false) @map("contains_personal_data")
  status               GovernedItemStatus  @default(ACTIVE)
  createdAt            DateTime            @default(now()) @map("created_at")

  @@map("data_point_catalog")
}

enum DataPointSourceType {
  REPORT_RUN_FIELD
  LIVE_QUERY

  @@map("data_point_source_type")
}

// Invariant 33(d): immutable -- insert-only via DB trigger (same pattern as
// audit_trail/report_run), including REFUSALS (invariant 33f closing line:
// "Every gate decision logged in ai_interaction_log (incl. refusals)").
model AiInteractionLog {
  id                             String               @id @default(uuid()) @db.Uuid
  askingUserId                   String               @map("asking_user_id") @db.Uuid
  capabilityCode                 String               @map("capability_code")
  promptText                     String               @map("prompt_text")
  requestedDataPointCodes        Json                 @map("requested_data_point_codes")
  includedDataPointCodes         Json                 @map("included_data_point_codes")
  excludedDataPointCodes         Json                 @map("excluded_data_point_codes")
  // Invariant 57(b)(v) (CHECK15): the subset of includedDataPointCodes
  // whose DataPointCatalog row is containsPersonalData=true -- the
  // auditable data-minimization record for this invocation. Never a
  // separate inclusion decision; resolveDataPoints() already only includes
  // an explicitly requested, capability-gated point, this field just makes
  // which of those were personal data directly queryable without a join.
  personalDataPointCodesIncluded Json                 @default("[]") @map("personal_data_point_codes_included")
  contextJson                    Json?                @map("context_json")
  gate1FlagEnabled               Boolean              @map("gate1_flag_enabled")
  gate2Granted                   Boolean              @map("gate2_granted")
  gate3ContextOk                 Boolean              @map("gate3_context_ok")
  killSwitchActive               Boolean              @map("kill_switch_active")
  tokenBudgetOk                  Boolean              @map("token_budget_ok")
  outcome                        AiInteractionOutcome
  refusalReason                  String?              @map("refusal_reason")
  responseText                   String?              @map("response_text")
  aiDrafted                      Boolean              @default(false) @map("ai_drafted")
  cacheHit                       Boolean              @default(false) @map("cache_hit")
  tokensCharged                  Int                  @default(0) @map("tokens_charged")
  createdAt                      DateTime             @default(now()) @map("created_at")

  askingUser AppUser @relation(fields: [askingUserId], references: [id])

  @@map("ai_interaction_log")
}

enum AiInteractionOutcome {
  ALLOWED
  REFUSED

  @@map("ai_interaction_outcome")
}

// Response caching (invariant 33e). cacheKey is a SHA-256 hex digest of
// (capabilityCode, prompt, resolved context) -- never the raw prompt stored
// as a lookup key, same don't-store-what-you-don't-need discipline as
// UserSession.tokenHash.
model AiResponseCache {
  cacheKey       String   @id @map("cache_key")
  capabilityCode String   @map("capability_code")
  responseText   String   @map("response_text")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@map("ai_response_cache")
}

// ============================================================================
// Check-6B item 2: Stakeholder Reporting module (invariant 24).
// ============================================================================

// department/reportType are free text (config vocabulary, invariant 19 --
// FINCON per-entity + consolidated; PORTFOLIO per-fund + collective; BD;
// extensible by config), not a fixed platform enum. figures are LOCKED
// numbers (drawn from data_point_catalog/report_run -- the AI never
// computes or invents one, invariant 33b); aiDraftedNarrative is the ONLY
// AI-touched field, always AI_DRAFTED-tagged, always subject to the SAME
// maker-not-checker approval below before it can be distributed.
model StakeholderReportRun {
  id                 String                   @id @default(uuid()) @db.Uuid
  department         String
  reportType         String                   @map("report_type")
  periodStart        DateTime                 @map("period_start") @db.Date
  periodEnd          DateTime                 @map("period_end") @db.Date
  figures            Json
  aiDraftedNarrative String?                  @map("ai_drafted_narrative")
  aiInteractionLogId String?                  @map("ai_interaction_log_id") @db.Uuid
  status             StakeholderReportStatus  @default(DRAFT)
  audienceClass      StakeholderAudienceClass @map("audience_class")
  generatedByUserId  String                   @map("generated_by_user_id") @db.Uuid
  approvedByUserId   String?                  @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?                  @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime                 @default(now()) @map("created_at")

  generatedBy   AppUser                      @relation("StakeholderReportGeneratedBy", fields: [generatedByUserId], references: [id])
  approvedBy    AppUser?                     @relation("StakeholderReportApprovedBy", fields: [approvedByUserId], references: [id])
  distributions StakeholderDistributionLog[]

  @@map("stakeholder_report_run")
}

enum StakeholderReportStatus {
  DRAFT
  APPROVED
  DISTRIBUTED

  @@map("stakeholder_report_status")
}

enum StakeholderAudienceClass {
  INTERNAL
  CLIENT
  REGULATOR
  // Invariant 37(c)(iv): "Board Papers flow: Management Reports,
  // Presentations, Memo Requests routed per DoA... stakeholder-reporting
  // BOARD audience class, CS distributes." Reuses this SAME module rather
  // than a parallel one — reportType (already free text, invariant 19)
  // carries "Management Report"/"Presentation"/"Memo Request" as content,
  // not a new schema concept.
  BOARD

  @@map("stakeholder_audience_class")
}

// Invariant 24: immutable distribution_log (insert-only, DB trigger).
// signOffByUserId is mandatory for CLIENT/REGULATOR audience (checked in
// the service, since the rule is audience-conditional, not a fixed NOT
// NULL column) -- CLIENT/REGULATOR audience requires MD/delegated sign-off
// per DoA.
model StakeholderDistributionLog {
  id                     String                   @id @default(uuid()) @db.Uuid
  stakeholderReportRunId String                   @map("stakeholder_report_run_id") @db.Uuid
  audienceClass          StakeholderAudienceClass @map("audience_class")
  distributedByUserId    String                   @map("distributed_by_user_id") @db.Uuid
  signOffByUserId        String?                  @map("sign_off_by_user_id") @db.Uuid
  recipientDescription   String                   @map("recipient_description")
  distributedAt          DateTime                 @default(now()) @map("distributed_at")

  stakeholderReportRun StakeholderReportRun @relation(fields: [stakeholderReportRunId], references: [id])
  distributedBy        AppUser              @relation("StakeholderDistributionDistributedBy", fields: [distributedByUserId], references: [id])
  signOffBy            AppUser?             @relation("StakeholderDistributionSignOffBy", fields: [signOffByUserId], references: [id])

  @@map("stakeholder_distribution_log")
}

// Invariant 36(c): "Credit-bureau integration = gateway pattern (like the AI
// layer): BureauGateway with up to 3 vendor API provider slots (config);
// officer-triggered assessment via BUTTON only — NO auto-generation of
// bureau pulls." Up to 3 rows (providerSlot 1-3); at most one isActive at a
// time is a service-layer rule, not a DB constraint (a future multi-vendor
// comparison mode is plausible without a migration).
model BureauProvider {
  id              String   @id @default(uuid()) @db.Uuid
  providerSlot    Int      @unique @map("provider_slot")
  name            String
  apiConfig       Json     @map("api_config")
  costPerPullKobo BigInt   @map("cost_per_pull_kobo")
  isActive        Boolean  @default(false) @map("is_active")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  updatedAt       DateTime @updatedAt @map("updated_at")

  updatedBy AppUser?        @relation(fields: [updatedByUserId], references: [id])
  pulls     BureauPullLog[]

  @@map("bureau_provider")
}

// Invariant 36(c): "bureau search FREQUENCY/INTERVAL limits + provider
// settings live under the RISK MANAGEMENT tool (Risk owns bureau policy)."
// Singleton row (id=1), same governed-config pattern as
// TaskEscalationConfig — versioned via updatedAt + audit_trail, not a
// bespoke version table (the same doctrine as the payment-reminder ladder
// settings screen, invariant 36b).
model BureauPolicyConfig {
  id              Int      @id @default(1)
  minIntervalDays Int      @map("min_interval_days")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  updatedAt       DateTime @updatedAt @map("updated_at")

  updatedBy AppUser? @relation(fields: [updatedByUserId], references: [id])

  @@map("bureau_policy_config")
}

// Every pull logged (consent verified at onboarding via
// Counterparty.creditBureauConsentAt, cost-per-pull visible). resultSummary
// is an honest placeholder until a vendor is contracted (same disclosure
// pattern as One17AIService.buildResponse — never a fabricated score).
model BureauPullLog {
  id             String   @id @default(uuid()) @db.Uuid
  counterpartyId String   @map("counterparty_id") @db.Uuid
  providerId     String   @map("provider_id") @db.Uuid
  pulledByUserId String   @map("pulled_by_user_id") @db.Uuid
  costKobo       BigInt   @map("cost_kobo")
  resultSummary  String   @map("result_summary")
  pulledAt       DateTime @default(now()) @map("pulled_at")

  counterparty Counterparty   @relation(fields: [counterpartyId], references: [id])
  provider     BureauProvider @relation(fields: [providerId], references: [id])
  pulledBy     AppUser        @relation(fields: [pulledByUserId], references: [id])

  @@index([counterpartyId])
  @@map("bureau_pull_log")
}

// Invariant 55(a) (CHECK12, CEO directive 8-Jul-2026): 4th gateway on the
// standing adapter pattern -- same <=3 vendor-slot shape as BureauProvider,
// service-enforced not DB-enforced (matches that model's own documented
// precedent). webhookSecret is stored in plaintext (no crypto-at-rest
// utility exists anywhere in this codebase -- confirmed by grep before
// building this; go-live gate 5 in invariant 55(d) already names "secrets
// vault" as an outstanding human-side hardening item, so this is a known,
// charter-acknowledged gap, not a silently introduced one). What IS
// delivered here is the read-side guarantee: PaymentGatewayService never
// returns the raw secret through any API response, only a masked preview
// -- see QUESTIONS_FOR_REVIEW.md.
// Invariant 55(a) CEO ruling (9-Jul-2026): "provider/custodian-account
// configuration follows the standing gateway pattern -- Settings area,
// capability-gated, changes MD-approved like the AI flags." Unlike the AI
// flag's single boolean, a provider/custodian config change is multi-field,
// so approval can't just "flip current state" -- the proposed values are
// staged on pending* columns and copied onto the live fields only once
// PAYMENT_GATEWAY_POLICY APPROVE (MD_CEO) resolves the workflow, mirroring
// the investor-bank-account-change staging shape (invariant 51a-i) more
// than the AI toggle's atomic-flip shape.
model PaymentGatewayProvider {
  id                       String   @id @default(uuid()) @db.Uuid
  providerSlot             Int      @unique @map("provider_slot")
  name                     String
  webhookSecret            String   @map("webhook_secret")
  // Invariant 73(b) (CHECK27): vendor-specific OUTBOUND API credentials
  // (e.g. Flutterwave/Monnify secret keys used for settlement-verification
  // calls, distinct from the webhook signing secret above) -- a free-form
  // JSON bag, same convention as BureauProvider.apiConfig, since each of
  // Paystack/Flutterwave/Monnify/Paymish shapes this differently and the
  // adapter (not the schema) owns interpreting it.
  apiConfig                Json?    @map("api_config")
  isActive                 Boolean  @default(false) @map("is_active")
  configuredByUserId       String   @map("configured_by_user_id") @db.Uuid
  updatedAt                DateTime @updatedAt @map("updated_at")
  pendingName              String?  @map("pending_name")
  pendingWebhookSecret     String?  @map("pending_webhook_secret")
  pendingApiConfig         Json?    @map("pending_api_config")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid

  configuredBy      AppUser                   @relation(fields: [configuredByUserId], references: [id])
  pendingProposedBy AppUser?                  @relation("PaymentGatewayProviderPendingProposedBy", fields: [pendingProposedByUserId], references: [id])
  configWorkflow    WorkflowInstance?         @relation(fields: [configWorkflowInstanceId], references: [id])
  custodianAccounts ProductCustodianAccount[]
  inflows           PaymentGatewayInflow[]

  @@map("payment_gateway_provider")
}

// One custodian account per (provider, product) -- "product-specific
// CUSTODIAN ACCOUNTS configured per product ... so clients deposit
// DIRECTLY into the target fund's custodian account, deliberately
// bypassing any CLIENT_MONEY wallet stage" (CEO ruling, invariant 55a).
// referenceCodePrefix is what makes a reference-coded bank transfer
// matchable without a live gateway checkout: an investor's own reference
// for this product is `${referenceCodePrefix}-${investorId}`, surfaced to
// them on the portal deposit screen.
model ProductCustodianAccount {
  id                            String   @id @default(uuid()) @db.Uuid
  providerId                    String   @map("provider_id") @db.Uuid
  productCode                   String   @map("product_code")
  custodianBankName             String   @map("custodian_bank_name")
  custodianAccountNumber        String   @map("custodian_account_number")
  referenceCodePrefix           String   @map("reference_code_prefix")
  isActive                      Boolean  @default(false) @map("is_active")
  createdByUserId               String   @map("created_by_user_id") @db.Uuid
  createdAt                     DateTime @default(now()) @map("created_at")
  // Same MD-approved staging shape as PaymentGatewayProvider above -- a
  // custodian account never goes live (isActive true) until the config
  // workflow resolves APPROVED, since it names the bank account real
  // client money settles into.
  pendingCustodianBankName      String?  @map("pending_custodian_bank_name")
  pendingCustodianAccountNumber String?  @map("pending_custodian_account_number")
  pendingReferenceCodePrefix    String?  @map("pending_reference_code_prefix")
  pendingIsActive               Boolean? @map("pending_is_active")
  pendingProposedByUserId       String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId      String?  @unique @map("config_workflow_instance_id") @db.Uuid

  provider          PaymentGatewayProvider @relation(fields: [providerId], references: [id])
  product           Product                @relation(fields: [productCode], references: [code])
  createdBy         AppUser                @relation(fields: [createdByUserId], references: [id])
  pendingProposedBy AppUser?               @relation("ProductCustodianAccountPendingProposedBy", fields: [pendingProposedByUserId], references: [id])
  configWorkflow    WorkflowInstance?      @relation(fields: [configWorkflowInstanceId], references: [id])
  inflows           PaymentGatewayInflow[]

  @@unique([providerId, productCode])
  @@map("product_custodian_account")
}

// Invariant 55(a): every webhook settlement lands here FIRST (staging
// row, same doctrine as PublicIntakeSubmission -- write only a claim,
// consequential writes happen through a second, governed step), never
// directly into SubscriptionRequest/Txn/ProductAccount. UNMATCHED rows
// ARE the suspense queue -- there is no separate table for it (queryable
// by status, same "always-visible, never silently dropped" doctrine as
// ScheduledJobRun's FAILED rows). gatewayEventRef is the webhook
// idempotency key -- a retried webhook delivery is a no-op, never a
// double-booked deposit.
model PaymentGatewayInflow {
  id                          String                            @id @default(uuid()) @db.Uuid
  providerId                  String                            @map("provider_id") @db.Uuid
  custodianAccountId          String?                           @map("custodian_account_id") @db.Uuid
  gatewayEventRef             String                            @unique @map("gateway_event_ref")
  amountKobo                  BigInt                            @map("amount_kobo")
  settledAt                   DateTime                          @map("settled_at")
  narration                   String?                           @map("narration")
  rawPayload                  Json                              @map("raw_payload")
  status                      PaymentGatewayInflowStatus        @default(UNMATCHED)
  matchedInvestorId           String?                           @map("matched_investor_id")
  matchedByUserId             String?                           @map("matched_by_user_id") @db.Uuid
  matchedAt                   DateTime?                         @map("matched_at")
  subscriptionRequestId       String?                           @unique @map("subscription_request_id") @db.Uuid
  reversalRedemptionRequestId String?                           @unique @map("reversal_redemption_request_id") @db.Uuid
  rejectionReason             String?                           @map("rejection_reason")
  lastAttemptError            String?                           @map("last_attempt_error")
  createdAt                   DateTime                          @default(now()) @map("created_at")
  // CEO ruling (9-Jul-2026): "rejections/refunds require a second officer."
  // A REJECT/REVERSAL decision is PROPOSED (status unchanged) then only
  // takes effect once a second PAYMENT_GATEWAY_SUSPENSE holder approves --
  // decisionType tells approveInflowDecision() which branch to execute.
  pendingDecisionType         PaymentGatewayInflowDecisionType? @map("pending_decision_type")
  pendingRejectionReason      String?                           @map("pending_rejection_reason")
  decisionProposedByUserId    String?                           @map("decision_proposed_by_user_id") @db.Uuid
  decisionWorkflowInstanceId  String?                           @unique @map("decision_workflow_instance_id") @db.Uuid

  provider            PaymentGatewayProvider   @relation(fields: [providerId], references: [id])
  custodianAccount    ProductCustodianAccount? @relation(fields: [custodianAccountId], references: [id])
  matchedInvestor     Investor?                @relation(fields: [matchedInvestorId], references: [investorId])
  matchedBy           AppUser?                 @relation("PaymentGatewayInflowMatchedBy", fields: [matchedByUserId], references: [id])
  subscriptionRequest SubscriptionRequest?     @relation("PaymentGatewayInflowSubscription", fields: [subscriptionRequestId], references: [id])
  reversalRequest     SubscriptionRequest?     @relation("PaymentGatewayInflowReversal", fields: [reversalRedemptionRequestId], references: [id])
  decisionProposedBy  AppUser?                 @relation("PaymentGatewayInflowDecisionProposedBy", fields: [decisionProposedByUserId], references: [id])
  decisionWorkflow    WorkflowInstance?        @relation(fields: [decisionWorkflowInstanceId], references: [id])

  @@index([status])
  @@map("payment_gateway_inflow")
}

enum PaymentGatewayInflowDecisionType {
  REJECT
  REVERSAL

  @@map("payment_gateway_inflow_decision_type")
}

enum PaymentGatewayInflowStatus {
  UNMATCHED
  MATCHED
  PROMOTED
  REVERSED
  REJECTED

  @@map("payment_gateway_inflow_status")
}

// ============================================================================
// Invariant 65 (CHECK18): Fund Obligations Schedule + payout instruction
// pipeline + the unified Tax Configuration framework (VAT/WHT/Stamp Duty).
// ============================================================================

enum ProfitPaymentInterval {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  AT_MATURITY

  @@map("profit_payment_interval")
}

// Invariant 65(b): FA compiles a payout batch from the Fund Obligations
// Schedule for a selected period -> routed as a MEMO REQUEST through the
// standing DoA chain (amountKobo on the WorkflowInstance drives the
// amount-tiered escalation, same mechanism every other DoA-gated batch in
// this codebase already uses) -> on approval, the bank instruction letter
// auto-generates via the EXISTING 52(c) LetterService (a new LetterType,
// zero new letter-engine code). The approved line list is immutable — any
// change is a new compilation, never an edit to an approved batch.
model PayoutCompilationBatch {
  id                              String            @id @default(uuid()) @db.Uuid
  batchNumber                     String            @unique @map("batch_number")
  periodLabel                     String            @map("period_label")
  status                          PayoutBatchStatus @default(DRAFT)
  totalGrossKobo                  BigInt            @map("total_gross_kobo")
  totalWhtKobo                    BigInt            @default(0) @map("total_wht_kobo")
  totalNetKobo                    BigInt            @map("total_net_kobo")
  compiledByUserId                String            @map("compiled_by_user_id") @db.Uuid
  workflowInstanceId              String?           @unique @map("workflow_instance_id") @db.Uuid
  bankInstructionLetterInstanceId String?           @unique @map("bank_instruction_letter_instance_id") @db.Uuid
  paidAt                          DateTime?         @map("paid_at")
  paidByUserId                    String?           @map("paid_by_user_id") @db.Uuid
  createdAt                       DateTime          @default(now()) @map("created_at")

  compiledBy                    AppUser                 @relation("PayoutBatchCompiledBy", fields: [compiledByUserId], references: [id])
  workflowInstance              WorkflowInstance?       @relation(fields: [workflowInstanceId], references: [id])
  bankInstructionLetterInstance LetterInstance?         @relation(fields: [bankInstructionLetterInstanceId], references: [id])
  lines                         PayoutCompilationLine[]

  @@map("payout_compilation_batch")
}

enum PayoutBatchStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  INSTRUCTION_ISSUED
  PAID

  @@map("payout_batch_status")
}

// One row per investor per batch, frozen at compilation time — invariant
// 65(c)(ii): WHT computed here from the version effective ON THE PAYOUT'S
// TRANSACTION DATE, gross/wht/net immutable once the parent batch is
// APPROVED (a later rate-version change never touches an approved line).
model PayoutCompilationLine {
  id                 String  @id @default(uuid()) @db.Uuid
  batchId            String  @map("batch_id") @db.Uuid
  investorId         String  @map("investor_id")
  productAccountId   String? @map("product_account_id") @db.Uuid
  ndMandateAccountId String? @map("nd_mandate_account_id") @db.Uuid
  grossKobo          BigInt  @map("gross_kobo")
  whtKobo            BigInt  @default(0) @map("wht_kobo")
  netKobo            BigInt  @map("net_kobo")
  whtExempt          Boolean @default(false) @map("wht_exempt")
  whtRateVersionId   String? @map("wht_rate_version_id") @db.Uuid

  batch            PayoutCompilationBatch @relation(fields: [batchId], references: [id])
  investor         Investor               @relation(fields: [investorId], references: [investorId])
  productAccount   ProductAccount?        @relation(fields: [productAccountId], references: [id])
  ndMandateAccount NdMandateAccount?      @relation(fields: [ndMandateAccountId], references: [id])
  whtRateVersion   TaxRateVersion?        @relation(fields: [whtRateVersionId], references: [id])

  @@map("payout_compilation_line")
}

enum TaxType {
  WHT
  VAT
  STAMP_DUTY

  @@map("tax_type")
}

// Invariant 65(c)(i): "one governed Tax Configuration area" — WHT, VAT, and
// Stamp Duty as SIBLINGS of the existing PAYE TaxRuleConfig, same
// versioned-config family (version Int, effectiveFrom, propose->approve,
// GovernedItemStatus). `rates` is a Json array whose shape depends on
// taxType (the calculator reads this, never a literal rate in code,
// invariant 10) — WHT: [{category: 'INDIVIDUAL'|'CORPORATE', incomeType,
// ratePct}]; VAT: [{serviceOrFeeType, ratePct}]; STAMP_DUTY:
// [{instrumentType, mode: 'RATE'|'FLAT', ratePct?, flatKobo?}]. Ships with
// NO versions at all (not even a DRAFT) until Finance proposes real,
// FinCon-sourced values — TaxService's own "no ACTIVE version" refusal is
// what renders the "not configured" banner, the same honest-absence
// pattern as AttendanceService.runTTLockSync for an uncontracted vendor.
// A new version's effectiveFrom is NEVER retroactive on an
// already-approved PayoutCompilationLine/FeeInvoice/VendorInvoice/
// StampDutyAssessment — those already recorded which version priced them.
model TaxRateVersion {
  id                 String             @id @default(uuid()) @db.Uuid
  taxType            TaxType            @map("tax_type")
  version            Int
  rates              Json
  status             GovernedItemStatus @default(DRAFT)
  effectiveFrom      DateTime           @map("effective_from")
  proposedByUserId   String             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  proposedBy       AppUser           @relation("TaxRateVersionProposedBy", fields: [proposedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  payoutLines           PayoutCompilationLine[]
  recognizedVatInvoices VendorInvoice[]
  feeInvoices           FeeInvoice[]
  stampDutyAssessments  StampDutyAssessment[]

  @@unique([taxType, version])
  @@map("tax_rate_version")
}

// Invariant 65(c)(i): "exemptions per investor." A standing flag, not
// per-payout — WHTExempt on a PayoutCompilationLine is derived from this
// at compilation time and then frozen on the line (never re-checked
// retroactively if the exemption is later revoked).
model InvestorTaxExemption {
  id              String   @id @default(uuid()) @db.Uuid
  investorId      String   @map("investor_id")
  taxType         TaxType  @map("tax_type")
  reason          String
  grantedByUserId String   @map("granted_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  investor  Investor @relation(fields: [investorId], references: [investorId])
  grantedBy AppUser  @relation(fields: [grantedByUserId], references: [id])

  @@unique([investorId, taxType])
  @@map("investor_tax_exemption")
}

// Invariant 65(c)(ii): OUTPUT VAT — One17's own fee/advisory invoices to a
// counterparty or investor (distinct from VendorInvoice's INPUT VAT
// recognition on a procurement vendor invoice below). No prior invoicing
// concept existed for One17's own billing; this is the minimal new model
// the charter's "VAT — on One17 fee/advisory invoices" requires.
model FeeInvoice {
  id               String   @id @default(uuid()) @db.Uuid
  invoiceNumber    String   @unique @map("invoice_number")
  counterpartyId   String?  @map("counterparty_id") @db.Uuid
  investorId       String?  @map("investor_id")
  description      String
  feeAmountKobo    BigInt   @map("fee_amount_kobo")
  vatKobo          BigInt   @default(0) @map("vat_kobo")
  vatRateVersionId String?  @map("vat_rate_version_id") @db.Uuid
  totalKobo        BigInt   @map("total_kobo")
  invoiceDate      DateTime @map("invoice_date") @db.Date
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  counterparty   Counterparty?   @relation(fields: [counterpartyId], references: [id])
  investor       Investor?       @relation(fields: [investorId], references: [investorId])
  vatRateVersion TaxRateVersion? @relation(fields: [vatRateVersionId], references: [id])
  createdBy      AppUser         @relation(fields: [createdByUserId], references: [id])

  @@map("fee_invoice")
}

// Invariant 65(c)(ii): Stamp Duty "on configured instrument types at their
// creation/execution events" — an append-only assessment log. `entityType`
// names the platform record the duty was assessed against (e.g.
// 'counterparty_facility_application', 'nd_mandate_account'); which
// instrumentType keys are actually "configured" lives entirely in the
// ACTIVE StampDuty TaxRateVersion.rates Json — never a hardcoded list here.
model StampDutyAssessment {
  id               String   @id @default(uuid()) @db.Uuid
  instrumentType   String   @map("instrument_type")
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  dutyKobo         BigInt   @map("duty_kobo")
  taxRateVersionId String   @map("tax_rate_version_id") @db.Uuid
  assessedByUserId String   @map("assessed_by_user_id") @db.Uuid
  assessedAt       DateTime @default(now()) @map("assessed_at")

  taxRateVersion TaxRateVersion @relation(fields: [taxRateVersionId], references: [id])
  assessedBy     AppUser        @relation(fields: [assessedByUserId], references: [id])

  @@map("stamp_duty_assessment")
}

// Invariant 65(c)(iii): "each tax type carries its own payable account ...
// postings PARKED until the mapping signs, computation/display live
// immediately." One row per TaxType, seeded with payableAccountCode: null
// — TaxService checks this before attempting any journal posting and
// refuses honestly (never invents an account code) until FinCon confirms
// one and Finance/ICT records it here.
model TaxGlMapping {
  id                 String    @id @default(uuid()) @db.Uuid
  taxType            TaxType   @unique @map("tax_type")
  payableAccountCode String?   @map("payable_account_code")
  configuredByUserId String?   @map("configured_by_user_id") @db.Uuid
  configuredAt       DateTime? @map("configured_at")

  configuredBy AppUser? @relation(fields: [configuredByUserId], references: [id])

  @@map("tax_gl_mapping")
}

// Invariant 65(c)(iii): "REMITTANCE AUTOMATION per tax type and authority
// ... due-date rules in config." Ships with ZERO rows — the scheduled
// auto-creation job finds no due-date config and does nothing (an honest
// no-op) until Compliance/Finance configures a real FIRS/state due-date
// rule; the platform never invents a remittance deadline.
model TaxRemittanceDueDateConfig {
  id            String  @id @default(uuid()) @db.Uuid
  taxType       TaxType @map("tax_type")
  authority     String
  dayOfMonthDue Int     @map("day_of_month_due")
  isActive      Boolean @default(true) @map("is_active")

  @@unique([taxType, authority])
  @@map("tax_remittance_due_date_config")
}

model TaxRemittanceBatch {
  id                 String              @id @default(uuid()) @db.Uuid
  taxType            TaxType             @map("tax_type")
  authority          String
  periodLabel        String              @map("period_label")
  totalKobo          BigInt              @map("total_kobo")
  status             TaxRemittanceStatus @default(PENDING)
  dueDate            DateTime            @map("due_date")
  workflowInstanceId String?             @unique @map("workflow_instance_id") @db.Uuid
  letterInstanceId   String?             @unique @map("letter_instance_id") @db.Uuid
  remittedAt         DateTime?           @map("remitted_at")
  remittedByUserId   String?             @map("remitted_by_user_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")

  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  letterInstance   LetterInstance?   @relation(fields: [letterInstanceId], references: [id])

  @@map("tax_remittance_batch")
}

enum TaxRemittanceStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  INSTRUCTION_ISSUED
  REMITTED

  @@map("tax_remittance_status")
}

// Invariant 66 (CHECK20): the Activation Console's own persisted state.
// Every STEP's status is computed live by probes against real data (invariant
// 66b: "DETECTED FROM DATA, NEVER SELF-ATTESTED") -- nothing about step
// completion is stored here. Only two genuine one-time ACTIONS need
// persistence: activating (a singleton event, same shape as AiKillSwitch),
// and skipping a step (invariant 66c: "a skipped step stays visibly amber on
// the console after activation, never forgotten" -- skip state must survive
// past activation, so it can't be inferred from "activatedAt is null").
model ActivationState {
  id                Int       @id @default(1)
  activatedAt       DateTime? @map("activated_at")
  activatedByUserId String?   @map("activated_by_user_id") @db.Uuid

  activatedBy AppUser? @relation(fields: [activatedByUserId], references: [id])

  @@map("activation_state")
}

// One row per skipped step -- only SKIPPABLE steps (invariant 66c: gateways,
// template sub-steps) may carry a row here; ActivationConsoleService refuses
// to skip a REQUIRED step. A step reappearing green later (the operator
// returns and configures it) does not delete this row automatically -- the
// row is historical evidence that it was once skipped, cleared explicitly.
model ActivationStepSkip {
  id              String   @id @default(uuid()) @db.Uuid
  stepCode        String   @unique @map("step_code")
  skippedAt       DateTime @default(now()) @map("skipped_at")
  skippedByUserId String   @map("skipped_by_user_id") @db.Uuid

  skippedBy AppUser @relation(fields: [skippedByUserId], references: [id])

  @@map("activation_step_skip")
}

// ============================================================================
// Invariant 72 -- SCREENING GATEWAY (v1.2 flagship, CHECK26). "Bring the
// lists home, never scrape search portals" -- five candidate source
// adapters, each a governed config row + parser. Architecture verified
// live against each publisher's real, current, official download surface
// before this schema was written (never guessed):
//   OFAC (Treasury Sanctions List Service): official CSV/XML, no auth.
//   UN Security Council Consolidated List: official XML/PDF/HTML, no auth.
//   UK Sanctions List (FCDO, absorbed the retired OFSI Consolidated List
//     28-Jan-2026): official CSV/ODS/XML/PDF at static gov.uk URLs, no auth.
//   EU Financial Sanctions Files (FSF): official XML/CSV/PDF, gated behind
//     an EU-Login-issued TOKEN embedded in the download URL -- a governed
//     config field, not scraping.
//   Nigerian NFIU/NSC sanctions list: PARKED at launch (isParked=true on
//     its ScreeningListSource row) -- live-verified nigsac.gov.ng (the NFIU
//     secretariat's own sanctions page) publishes designations as HTML
//     accordion narrative panels plus occasional per-designation dated PDF
//     circulars, NOT a single consolidated machine-readable file. This is
//     exactly the case invariant 72(a) itself anticipates ("park any source
//     whose access model differs from expectation -- never scrape as a
//     workaround"), not an oversight -- see CHECK26_EVIDENCE.md.
// ============================================================================

enum ScreeningListSourceCode {
  OFAC
  UN_SC
  UK_SANCTIONS
  EU_FSF
  NG_NFIU

  @@map("screening_list_source_code")
}

enum ScreeningListFileFormat {
  CSV
  XML

  @@map("screening_list_file_format")
}

// One governed row per candidate source. isParked sources (NG_NFIU at
// launch) can never be set isActive -- enforced in service code, not a DB
// CHECK, matching this codebase's standing "exactly one of two states,
// enforced in service code" convention elsewhere (DistributionLineItem,
// DocumentRegisterEntry). Config changes (URL, token, active/parked) are
// staged pending*/configWorkflowInstanceId, MD-approved -- mirrors
// AttendanceProvider exactly, since which list source feeds a sanctions
// stage-gate is at least as consequential as an attendance adapter choice.
model ScreeningListSource {
  id           String                  @id @default(uuid()) @db.Uuid
  sourceCode   ScreeningListSourceCode @unique @map("source_code")
  name         String
  fileFormat   ScreeningListFileFormat @map("file_format")
  downloadUrl  String                  @map("download_url")
  // e.g. EU FSF's { "tokenParam": "token", "token": "..." } appended as a
  // query string at download time -- never logged/exposed raw in any API
  // response (see ScreeningGatewayService.serializeListSource).
  extraConfig  Json?                   @map("extra_config")
  isActive     Boolean                 @default(false) @map("is_active")
  isParked     Boolean                 @default(false) @map("is_parked")
  parkedReason String?                 @map("parked_reason")

  lastSuccessfulDownloadAt DateTime? @map("last_successful_download_at")
  lastListVersion          String?   @map("last_list_version")
  lastAttemptAt            DateTime? @map("last_attempt_at")
  lastAttemptStatus        String?   @map("last_attempt_status")

  pendingDownloadUrl       String?  @map("pending_download_url")
  pendingExtraConfig       Json?    @map("pending_extra_config")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid
  configuredByUserId       String?  @map("configured_by_user_id") @db.Uuid
  updatedAt                DateTime @updatedAt @map("updated_at")

  entries   ScreeningListEntry[]
  downloads ScreeningListDownloadLog[]

  @@map("screening_list_source")
}

// The normalized local screening table (invariant 72(a)) -- one row per
// sanctioned party per source, replaced wholesale on each successful
// download of that source (delete-then-recreate inside one transaction;
// simpler and safer than diffing thousands of upstream rows for a
// nightly batch, and downloadLog/lastListVersion already give freshness
// + version evidence independent of entry-row history).
model ScreeningListEntry {
  id             String                  @id @default(uuid()) @db.Uuid
  sourceCode     ScreeningListSourceCode @map("source_code")
  sourceRecordId String                  @map("source_record_id")
  primaryName    String                  @map("primary_name")
  aliases        Json                    @map("aliases")
  dateOfBirth    String?                 @map("date_of_birth")
  nationality    String?
  entityType     String?                 @map("entity_type")
  programme      String?
  listVersion    String                  @map("list_version")
  rawDetail      Json                    @map("raw_detail")
  createdAt      DateTime                @default(now()) @map("created_at")

  source ScreeningListSource @relation(fields: [sourceCode], references: [sourceCode])
  hits   ScreeningHit[]

  @@unique([sourceCode, sourceRecordId])
  @@index([primaryName])
  @@map("screening_list_entry")
}

// Per-download-attempt log -- the list-freshness KRI (invariant 72(a))
// reads MAX(attemptedAt) WHERE status='SUCCEEDED' per source from this
// table; download failures alert via the notification engine at the
// point of failure (ScreeningGatewayService.runListDownloadSweep), this
// table is the durable trail behind that alert.
model ScreeningListDownloadLog {
  id           String                  @id @default(uuid()) @db.Uuid
  sourceCode   ScreeningListSourceCode @map("source_code")
  attemptedAt  DateTime                @default(now()) @map("attempted_at")
  status       String
  recordCount  Int?                    @map("record_count")
  listVersion  String?                 @map("list_version")
  errorMessage String?                 @map("error_message")

  source ScreeningListSource @relation(fields: [sourceCode], references: [sourceCode])

  @@map("screening_list_download_log")
}

// Invariant 72(c): the three provider modes on the standing gateway
// pattern. Singleton governed dial (id=1), Risk/Compliance-owned,
// selecting which mode ACTUALLY performs a screening run at the stage
// gate -- LOCAL_LISTS reads ScreeningListEntry, COMMERCIAL calls a
// CommercialScreeningProvider slot (built, unwired -- see
// ScreeningGatewayService.runCommercialScreen's honest-placeholder
// posture, same doctrine as BureauGatewayService.triggerPull), MANUAL
// requires an officer attestation + DocumentRegisterEntry evidence
// upload before the gate will pass.
enum ScreeningProviderMode {
  LOCAL_LISTS
  COMMERCIAL
  MANUAL

  @@map("screening_provider_mode")
}

model ScreeningGatewayConfig {
  id                  Int                   @id @default(1)
  activeProviderMode  ScreeningProviderMode @default(LOCAL_LISTS) @map("active_provider_mode")
  matchThresholdScore Int                   @default(80) @map("match_threshold_score")
  redThresholdScore   Int                   @default(95) @map("red_threshold_score")
  // Invariant 75(b) (CHECK28, v1.2.1 audit remediation, audit finding
  // CF-02): "re-screens ... whenever the run exceeds an APPROVED FRESHNESS
  // AGE (governed config)." The Risk/Compliance-owned freshness ceiling
  // ScreeningGatewayService.ensureScreened compares a prior LOCAL_LISTS run
  // against -- a run older than this, even with an unchanged fingerprint,
  // never satisfies the gate. 90 days (quarterly) is the default, same
  // cadence as this platform's own KYC periodic-review cycle (CHECK13
  // 51(b-vii)), not a vendor-mandated number.
  freshnessMaxAgeDays Int                   @default(90) @map("freshness_max_age_days")
  updatedByUserId     String?               @map("updated_by_user_id") @db.Uuid
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@map("screening_gateway_config")
}

// Commercial provider slots -- "built but unwired" per the CEO's own
// wording: schema + config UI exist, contracting is a FinCon/Compliance
// human item, and runCommercialScreen refuses honestly (never fabricates
// a result) until a real slot is both isActive and holds an apiKey.
// Same staged pending*/configWorkflowInstanceId shape as
// AttendanceProvider/PaymentGatewayProvider.
model CommercialScreeningProvider {
  id                 String  @id @default(uuid()) @db.Uuid
  providerSlot       Int     @unique @map("provider_slot")
  name               String
  apiKey             String? @map("api_key")
  isActive           Boolean @default(false) @map("is_active")
  configuredByUserId String? @map("configured_by_user_id") @db.Uuid

  pendingName              String?  @map("pending_name")
  pendingApiKey            String?  @map("pending_api_key")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("commercial_screening_provider")
}

enum ScreeningSubjectType {
  INVESTOR
  COUNTERPARTY

  @@map("screening_subject_type")
}

// GREEN/AMBER/RED per invariant 72(b)'s own naming -- AMBER/RED both
// require adjudication (the split is a display/severity band only, drawn
// at ScreeningGatewayConfig.redThresholdScore); nothing branches on
// AMBER vs RED except the badge color. One ScreeningRun per screening
// event, entity-agnostic (subjectType/subjectId) so investor and
// counterparty onboarding share one engine, one adjudication path, one
// smoke suite -- closing the gap CHECK26's own research confirmed:
// counterparty onboarding had no equivalent to InvestorScreeningRecord
// before this invariant.
model ScreeningRun {
  id                   String                @id @default(uuid()) @db.Uuid
  subjectType          ScreeningSubjectType  @map("subject_type")
  subjectId            String                @map("subject_id")
  subjectNameScreened  String                @map("subject_name_screened")
  providerMode         ScreeningProviderMode @map("provider_mode")
  screenedAt           DateTime              @default(now()) @map("screened_at")
  thresholdUsed        Int                   @map("threshold_used")
  // { OFAC: "v2026-07-10", UN_SC: "v2026-07-08", ... } -- the version
  // stamp IS the audit evidence a GREEN record carries (invariant 72(b)).
  listVersionsScreened Json                  @map("list_versions_screened")
  outcome              String                @map("outcome")
  initiatedByUserId    String?               @map("initiated_by_user_id") @db.Uuid
  // Invariant 75(b) (CHECK28, CF-02 remediation): the SCREENING FINGERPRINT
  // this run was produced against -- normalized subject name + active
  // source codes/list-versions + match/red threshold, pipe-joined (see
  // ScreeningGatewayService.computeCurrentFingerprint). ensureScreened
  // compares this against a freshly computed current fingerprint; ANY
  // difference (name correction, list update, threshold change, a newly-
  // activated source) means this run no longer reflects current inputs
  // and can never satisfy the gate, however recent it is. Null for
  // MANUAL/COMMERCIAL-mode runs -- the fingerprint concept only applies to
  // the LOCAL_LISTS auto-screen ensureScreened drives.
  fingerprint String? @map("fingerprint")

  hits ScreeningHit[]

  @@index([subjectType, subjectId])
  @@map("screening_run")
}

enum ScreeningHitAdjudicationOutcome {
  TRUE_MATCH
  FALSE_POSITIVE

  @@map("screening_hit_adjudication_outcome")
}

// One row per candidate match a run produced. listEntryId is null for a
// MANUAL-mode declared hit (no local list row exists to point at -- the
// officer's own search produced it). Never auto-block, never auto-clear
// (invariant 72(e)): status stays OPEN, and blocks the subject's
// onboarding gate, until an adjudication is APPROVED through the
// standing workflow engine (adjudicator != initiator enforced by
// WorkflowEngineService.approveNextStep itself, for free). Mandatory
// written rationale is enforced in service code (a required, non-empty
// string parameter), not by the generic engine, matching
// PaymentGatewayService.proposeRejectInflow's precedent.
model ScreeningHit {
  id             String  @id @default(uuid()) @db.Uuid
  screeningRunId String  @map("screening_run_id") @db.Uuid
  listEntryId    String? @map("list_entry_id") @db.Uuid
  matchedName    String  @map("matched_name")
  matchScore     Int     @map("match_score")
  status         String  @default("OPEN")

  pendingOutcome             ScreeningHitAdjudicationOutcome? @map("pending_outcome")
  pendingRationale           String?                          @map("pending_rationale")
  decisionProposedByUserId   String?                          @map("decision_proposed_by_user_id") @db.Uuid
  decisionWorkflowInstanceId String?                          @unique @map("decision_workflow_instance_id") @db.Uuid

  adjudicatedOutcome   ScreeningHitAdjudicationOutcome? @map("adjudicated_outcome")
  adjudicatedRationale String?                          @map("adjudicated_rationale")
  adjudicatedByUserId  String?                          @map("adjudicated_by_user_id") @db.Uuid
  adjudicatedAt        DateTime?                        @map("adjudicated_at")
  createdAt            DateTime                         @default(now()) @map("created_at")

  run       ScreeningRun        @relation(fields: [screeningRunId], references: [id])
  listEntry ScreeningListEntry? @relation(fields: [listEntryId], references: [id])

  @@map("screening_hit")
}
