// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// First table built (Phase 1 Build Plan step 2). INSERT-only: enforced by a
// BEFORE UPDATE/DELETE trigger in migration.sql (see that file for why REVOKE
// alone is not sufficient against an owner/superuser role). Every other
// module writes here; nothing here is ever migrated away without a very good
// reason, since the trigger + hash chain are what make this an audit trail
// rather than a table that happens to log things.
model AuditTrail {
  id           BigInt      @default(autoincrement())
  occurredAt   DateTime    @default(now()) @map("occurred_at") @db.Timestamptz(6)
  actorUserId  String?     @map("actor_user_id") @db.Uuid
  actorRole    String?     @map("actor_role")
  action       AuditAction
  entityType   String      @map("entity_type")
  entityId     String      @map("entity_id")
  workflowStep String?     @map("workflow_step")
  before       Json?
  after        Json?
  ipAddress    String?     @map("ip_address")
  sessionId    String?     @map("session_id") @db.Uuid
  requestId    String?     @map("request_id") @db.Uuid
  previousHash String?     @map("previous_hash") @db.Char(64)
  tamperHash   String      @map("tamper_hash") @db.Char(64)

  @@id([id, occurredAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([occurredAt])
  @@map("audit_trail")
}

// Singleton row that serializes hash-chain computation across concurrent
// writers. Not itself part of the immutable log — it's allowed to be
// updated, it just tracks "what was the last tamperHash written".
model AuditChainState {
  id        Int      @id @default(1)
  lastHash  String?  @map("last_hash") @db.Char(64)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("audit_chain_state")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  EXECUTE
  LOGIN
  LOGIN_FAILED
  PERMISSION_DENIED
  // Invariant 49(b2) (CHECK11 advisor ruling): the atomicity-sweep
  // compensating-cleanup pattern (invariant 49a) deletes a row a service
  // just created when workflow.initiate() throws afterward -- clean, but
  // silent unless the attempt itself leaves a trace. Capability-ineligible
  // failures already audit-log via PERMISSION_DENIED inside initiate()
  // itself; this action covers every OTHER failure cause (missing/
  // misconfigured ApprovalRule, a raw DB error on workflowInstance.create)
  // that would otherwise vanish along with the row it's compensating for.
  INITIATE_FAILED_COMPENSATED
  // Invariant 40(d) (CHECK17): "unlock event for a TERMINATED employee
  // raises a SECURITY alert, not an attendance record" -- a distinct action
  // from PERMISSION_DENIED (which is about a live actor's own capability
  // failure) so the two never conflate in the Audit Trail Viewer's filters.
  SECURITY_ALERT

  @@map("audit_action")
}

// Build Plan step 3: users + RBAC + segregation of duties. Per CLAUDE.md's
// reconciliation ruling (2026-07-04): SRS v1.0 §3 roles are the MVP seed,
// but nothing here is hard-coded to a role name — Role/PlatformFunction/
// RolePermission/RoleConflict are ordinary rows, not Prisma/Postgres enums,
// so BD/RSK/OPS/etc. arrive later as INSERTs, not migrations. AppUser
// identity only; staff authentication (password/SSO) is a later concern.
model AppUser {
  id                  String     @id @default(uuid()) @db.Uuid
  email               String     @unique
  displayName         String     @map("display_name")
