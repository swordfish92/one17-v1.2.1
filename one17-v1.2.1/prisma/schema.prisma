  verifiedByUserId   String?                    @map("verified_by_user_id") @db.Uuid
  createdAt          DateTime                   @default(now()) @map("created_at")

  investor   Investor @relation(fields: [investorId], references: [investorId])
  uploadedBy AppUser  @relation("KycDocumentUploadedBy", fields: [uploadedByUserId], references: [id])
  verifiedBy AppUser? @relation("KycDocumentVerifiedBy", fields: [verifiedByUserId], references: [id])

  @@map("investor_kyc_document")
}

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED

  @@map("document_verification_status")
}

// Manual Screening Procedure §3's checklist, digitized as configuration —
// not a hardcoded array in InvestorService — so adding/retiring a list
// (e.g. moving off manual screening per §7's review triggers, or a future
// commercial provider's own list set) is a data row, same "config not code"
// principle as RolePermission/ApprovalRule/ProductParameters. Seeded once
// (see seed.ts) with the six items §3 names; InvestorService.recordScreening
// requires every ACTIVE item to be covered before accepting a screening
// record — see that method's comment for why this can't just be a free
// JSON blob.
model ScreeningChecklistItem {
  id          String   @id @default(uuid()) @db.Uuid
  itemCode    String   @unique @map("item_code")
  description String
  sortOrder   Int      @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("screening_checklist_item")
}

// Manual Screening Procedure §4's exact evidence template: "investor_ref ·
// full legal name + known aliases · date of screening · lists checked with
// version/date · search terms used · result · screener · countersigner (if
// required) · notes." §2: "Where the initiating officer and Compliance are
// the same person, the result must be countersigned by the CEO" — enforced
// in InvestorService (needs to compare against the investor's
// onboardedByUserId, which a table constraint can't see), not here.
model InvestorScreeningRecord {
  id                  String          @id @default(uuid()) @db.Uuid
  investorId          String          @map("investor_id")
  screenedAt          DateTime        @default(now()) @map("screened_at")
  listsChecked        Json            @map("lists_checked")
  searchTermsUsed     String          @map("search_terms_used")
  result              ScreeningResult
  screenerUserId      String          @map("screener_user_id") @db.Uuid
  countersignerUserId String?         @map("countersigner_user_id") @db.Uuid
  notes               String?

  investor      Investor @relation(fields: [investorId], references: [investorId])
  screener      AppUser  @relation("ScreeningScreenedBy", fields: [screenerUserId], references: [id])
  countersigner AppUser? @relation("ScreeningCountersignedBy", fields: [countersignerUserId], references: [id])

  @@map("investor_screening_record")
}

enum ScreeningResult {
  NO_MATCH
  POTENTIAL_MATCH
  MATCH

  @@map("screening_result")
}

// Data Dictionary §1 "investor_bank_accounts" (TPL_02). SRS §4.5.1/AMD:
// redemption pays only to a registered, verified bank account.
model InvestorBankAccount {
  id                 String                     @id @default(uuid()) @db.Uuid
  investorId         String                     @map("investor_id")
  bankName           String                     @map("bank_name")
  accountNumber      String                     @map("account_number")
  accountName        String                     @map("account_name")
  // TPL_02 columns beyond the original Wave-0 shape.
  accountType        String?                    @map("account_type")
  currency           String?                    @default("NGN")
  isPrimary          Boolean                    @default(false) @map("is_primary")
  verificationStatus DocumentVerificationStatus @default(PENDING) @map("verification_status")
  verifiedByUserId   String?                    @map("verified_by_user_id") @db.Uuid
  createdAt          DateTime                   @default(now()) @map("created_at")
  // Invariant 51(a-i) (CHECK12): accounts created via the governed change
  // flow start ACTIVE-but-not-yet-payable until coolingOffEndsAt elapses --
  // this is the field the redemption payout gate actually reads (see
  // LedgerService.createTxn's REDEMPTION branch). Pre-existing accounts
  // (onboarding-captured, migration-loaded) default to ACTIVE/null and are
  // deliberately left un-retrofitted -- this is a NEW control on the CHANGE
  // path, not a retroactive tightening of already-payable accounts.
  status             InvestorBankAccountStatus  @default(ACTIVE)
  coolingOffEndsAt   DateTime?                  @map("cooling_off_ends_at")

  investor      Investor                          @relation(fields: [investorId], references: [investorId])
  verifiedBy    AppUser?                          @relation("BankAccountVerifiedBy", fields: [verifiedByUserId], references: [id])
  changeRequest InvestorBankAccountChangeRequest? @relation("ResultingFromChangeRequest")

  @@map("investor_bank_account")
}

enum InvestorBankAccountStatus {
  ACTIVE
  SUPERSEDED

  @@map("investor_bank_account_status")
}

// Invariant 51(a-i) (CHECK12, advisor BA lifecycle-gap register, Tier 1 --
// "THE fraud-critical item"): a governed change to WHERE an investor's
// redemption proceeds get paid. Deliberately staff-mediated (Client
// Services/RM captures the client's signed instruction + evidence), not a
// portal self-service action -- self-service bank-detail change is the
// classic account-takeover vector this control exists to prevent.
// Lifecycle: submit w/ document evidence (DocumentRegisterEntry, entityType
// 'investor_bank_account_change_request') -> 2-step governed workflow
// (APPROVAL then independent REVERIFICATION -- maker≠checker enforced
// generically by WorkflowEngineService, distinct capabilities per step) ->
// on final approval, the new InvestorBankAccount row is created ACTIVE with
// coolingOffEndsAt = now + config days, but NOT yet primary -- the old
// primary keeps paying until the window elapses and
// InvestorService.settleDueBankAccountChanges lazily swaps primacy +
// supersedes the old account. Nothing is payable to the new account before
// that swap (see LedgerService.createTxn's REDEMPTION branch).
model InvestorBankAccountChangeRequest {
  id                     String                  @id @default(uuid()) @db.Uuid
  investorId             String                  @map("investor_id")
  proposedBankName       String                  @map("proposed_bank_name")
  proposedAccountNumber  String                  @map("proposed_account_number")
  proposedAccountName    String                  @map("proposed_account_name")
  proposedAccountType    String?                 @map("proposed_account_type")
  proposedCurrency       String?                 @map("proposed_currency")
  status                 BankAccountChangeStatus @default(PENDING)
  requestedByUserId      String                  @map("requested_by_user_id") @db.Uuid
  workflowInstanceId     String?                 @unique @map("workflow_instance_id") @db.Uuid
  reVerifiedByUserId     String?                 @map("re_verified_by_user_id") @db.Uuid
  reVerifiedAt           DateTime?               @map("re_verified_at")
  // Free text: the reverifier records HOW they independently confirmed the
  // client actually requested this (e.g. outbound call to the number
  // already on file, never a number supplied with the request itself).
  reVerificationNotes    String?                 @map("re_verification_notes")
  coolingOffEndsAt       DateTime?               @map("cooling_off_ends_at")
  resultingBankAccountId String?                 @unique @map("resulting_bank_account_id") @db.Uuid
  rejectionNotes         String?                 @map("rejection_notes")
  createdAt              DateTime                @default(now()) @map("created_at")

  investor             Investor             @relation(fields: [investorId], references: [investorId])
  requestedBy          AppUser              @relation("BankChangeRequestedBy", fields: [requestedByUserId], references: [id])
  reVerifiedBy         AppUser?             @relation("BankChangeReVerifiedBy", fields: [reVerifiedByUserId], references: [id])
  workflowInstance     WorkflowInstance?    @relation(fields: [workflowInstanceId], references: [id])
  resultingBankAccount InvestorBankAccount? @relation("ResultingFromChangeRequest", fields: [resultingBankAccountId], references: [id])

  @@map("investor_bank_account_change_request")
}

enum BankAccountChangeStatus {
  PENDING
  COOLING_OFF
  COMPLETED
  REJECTED

  @@map("bank_account_change_status")
}

// Same precedent as InvestorOnboardingConfig (invariant 27a): a CEO-ruled
// number, versioned/ACTIVE-queried, seeded directly (the number IS the
// approval). Read-time guard only (no scheduled flip) -- matches how
// stage2DeadlineAt is enforced, see InvestorService.settleDueBankAccountChanges.
model InvestorBankAccountChangeConfig {
  id                 String             @id @default(uuid()) @db.Uuid
  version            Int                @default(1)
  status             GovernedItemStatus @default(ACTIVE)
  coolingOffDays     Int                @map("cooling_off_days")
  boardResolutionRef String?            @map("board_resolution_ref")
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  @@map("investor_bank_account_change_config")
}

// Invariant 51(a-ii) (CHECK12, advisor BA lifecycle-gap register, Tier 1):
// "governed post-onboarding updates (address, phone, email), Compliance
// acknowledgment, same shape as EMPLOYEE_PERSONAL_RECORD_CHANGE" -- CLAUDE.
// md's own text, verbatim. Deliberately the LIGHT-weight shape (no document
// evidence, no reverification, no cooling-off) -- that machinery belongs to
// 51(a-i)'s fraud-critical bank-account change, not this one. Only the
// fields the maker actually proposed (non-null) get applied on approval,
// same truthy-patch pattern as ProfileService.acknowledgeChange -- there is
// no way to null out a field via this flow, matching that precedent.
model InvestorContactAmendmentRequest {
  id                                 String                         @id @default(uuid()) @db.Uuid
  investorId                         String                         @map("investor_id")
  proposedContactEmail               String?                        @map("proposed_contact_email")
  proposedContactPhone               String?                        @map("proposed_contact_phone")
  proposedRegisteredAddress          String?                        @map("proposed_registered_address")
  proposedTaxIdentificationNumber    String?                        @map("proposed_tax_identification_number")
  proposedSourceOfFunds              String?                        @map("proposed_source_of_funds")
  proposedOccupationOrBusinessNature String?                        @map("proposed_occupation_or_business_nature")
  status                             InvestorContactAmendmentStatus @default(PENDING)
  requestedByUserId                  String                         @map("requested_by_user_id") @db.Uuid
  workflowInstanceId                 String?                        @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes                     String?                        @map("rejection_notes")
  createdAt                          DateTime                       @default(now()) @map("created_at")

  investor         Investor          @relation(fields: [investorId], references: [investorId])
  requestedBy      AppUser           @relation("InvestorContactAmendmentRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("investor_contact_amendment_request")
}

enum InvestorContactAmendmentStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("investor_contact_amendment_status")
}

// Invariant 51(b-v) (CHECK13, BA lifecycle-gap register Tier 2): "investor
// exit/closure (final statement, status, dormancy rules)." Two distinct
// transitions share one governed request shape, mirroring
// InvestorContactAmendmentRequest: MATURITY_TRANSITION (ACTIVE -> MATURED,
// the investor's mandate/product has run its course but the relationship
// isn't closed) and FINAL_EXIT (ACTIVE or MATURED -> EXITED, the terminal
// state InvestorFundStatus's own comment already named as the end of the
// forward-only chain). "Final statement" needs no new machinery --
// StatementService.generateStatementPdf never gates on Investor.fundStatus,
// so every account stays fully statement-able after EXITED; this workflow's
// job is only the zero-open-holdings GATE and the status flip itself.
model InvestorExitRequest {
  id                 String                    @id @default(uuid()) @db.Uuid
  investorId         String                    @map("investor_id")
  exitType           InvestorExitType          @map("exit_type")
  status             InvestorExitRequestStatus @default(PENDING)
  requestedByUserId  String                    @map("requested_by_user_id") @db.Uuid
  workflowInstanceId String?                   @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes     String?                   @map("rejection_notes")
  createdAt          DateTime                  @default(now()) @map("created_at")

  investor         Investor          @relation(fields: [investorId], references: [investorId])
  requestedBy      AppUser           @relation("InvestorExitRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("investor_exit_request")
}

enum InvestorExitType {
  MATURITY_TRANSITION
  FINAL_EXIT

  @@map("investor_exit_type")
}

enum InvestorExitRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("investor_exit_request_status")
}

// Governed singleton, same shape/precedent as TaskEscalationConfig /
// CalendarReminderConfig -- the months-inactive threshold is a policy call
// flagged in QUESTIONS_FOR_REVIEW.md for CEO/Compliance confirmation, not
// silently invented; ships with a documented default so the sweep has
// something real to run against from day one.
model InvestorDormancyConfig {
  id                      Int      @id @default(1)
  monthsInactiveThreshold Int      @default(12) @map("months_inactive_threshold")
  updatedByUserId         String?  @map("updated_by_user_id") @db.Uuid
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("investor_dormancy_config")
}

// Invariant 51(b-viii) (CHECK13): "ongoing sanctions re-screening batch over
// the live book (frequency in governed config)." No automated screening
// provider exists anywhere in this codebase today (confirmed: onboarding-
// time InvestorScreeningRecord rows are entered from a MANUAL check, not
// computed by any adapter) -- inventing a fake pass/fail here would violate
// the platform's own AWAITING-MATRIX "never fake, never hidden" doctrine.
// So the batch's real job is DETECTION, not determination: flag which
// investors are due, feed a real Task to Compliance, let them perform the
// actual re-screen through the EXISTING InvestorService.recordScreening
// path (already callable post-onboarding, no change needed there).
model InvestorSanctionsRescreeningConfig {
  id              Int      @id @default(1)
  frequencyMonths Int      @default(12) @map("frequency_months")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("investor_sanctions_rescreening_config")
}

// Invariant 51(b-ix) (CHECK13): "bank reconciliation (parallel-run monthly
// closes need it)." No external bank-feed integration exists anywhere in
// this codebase -- statement lines are entered manually (a real bank feed
// is a future vendor-integration project, not invented here) and matched
// against JournalEntryLine postings on the same cash/bank GL account.
// matchLine/unmatchLine are single-actor clerical attribution (same
// standing as PaymentGatewayInflow.manualMatch -- pairing an already-real
// figure to its ledger counterpart is not a money-destroying decision),
// but PeriodService.requestPeriodClose gates HARD on zero UNMATCHED lines
// dated within the period being closed, per the CEO's own "now needed for
// the first monthly close" framing -- an advisory-only dashboard would not
// have satisfied that instruction.
model BankStatementLine {
  id                        String                  @id @default(uuid()) @db.Uuid
  ledgerEntityCode          String                  @map("ledger_entity_code")
  glAccountCode             String                  @map("gl_account_code")
  statementDate             DateTime                @map("statement_date")
  description               String
  amountKobo                BigInt                  @map("amount_kobo")
  externalRef               String?                 @map("external_ref")
  status                    BankStatementLineStatus @default(UNMATCHED)
  matchedJournalEntryLineId String?                 @unique @map("matched_journal_entry_line_id") @db.Uuid
  matchedByUserId           String?                 @map("matched_by_user_id") @db.Uuid
  matchedAt                 DateTime?               @map("matched_at")
  uploadedByUserId          String                  @map("uploaded_by_user_id") @db.Uuid
  createdAt                 DateTime                @default(now()) @map("created_at")

  ledgerEntity            LedgerEntity      @relation(fields: [ledgerEntityCode], references: [code])
  matchedJournalEntryLine JournalEntryLine? @relation(fields: [matchedJournalEntryLineId], references: [id])
  matchedBy               AppUser?          @relation("BankStatementLineMatchedBy", fields: [matchedByUserId], references: [id])
  uploadedBy              AppUser           @relation("BankStatementLineUploadedBy", fields: [uploadedByUserId], references: [id])

  @@map("bank_statement_line")
}

enum BankStatementLineStatus {
  UNMATCHED
  MATCHED

  @@map("bank_statement_line_status")
}

// ============================================================================
// Phase 3: migration (TPL_01-07/08-10 loaders) and replay-harness targets.
// ============================================================================

// TPL_06 Counterparties — banks, obligors, and other non-investor parties a
// historical transaction or exposure references. Kept intentionally minimal
// (this is a migration/exposure register, not a full KYC subject) — the
// enterprise_limit is the Risk-facing figure the Migration Data Standards
// template carries, in kobo per invariant #2.
model Counterparty {
  id                      String    @id @default(uuid()) @db.Uuid
  legalName               String    @map("legal_name")
  counterpartyType        String    @map("counterparty_type")
  rcNumber                String?   @map("rc_number")
  country                 String?
  internalRating          String?   @map("internal_rating")
  enterpriseLimitKobo     BigInt?   @map("enterprise_limit_kobo")
  limitCurrency           String?   @map("limit_currency")
  // TPL_06 v2 (Mandatory Integrity Review correction 21a-iv): Shariah
  // certification tracking for counterparties feeding compliance control
  // C13 ("no new deployment on expired certs") — a service-layer gate at
  // deployment time, not a DB CHECK, since "today's date > expiry" is not a
  // static invariant.
  shariahCertRef          String?   @map("shariah_cert_ref")
  shariahCertExpiry       DateTime? @map("shariah_cert_expiry")
  // Phase 4 §2 (counterparty default stress model, F-CR-06/07): real
  // PD/forced-sale inputs so EL = EAD x PD x LGD and LGD = (EAD -
  // ForcedSale)/EAD compute from live data, not invented scenario numbers.
  // Nullable — most counterparties in this build have neither yet (no
  // credit-assessment workflow exists to populate them), which the stress
  // service treats as "insufficient data for this counterparty" rather than
  // defaulting to a guessed rate.
  probabilityOfDefaultPct Decimal?  @map("probability_of_default_pct") @db.Decimal(6, 4)
  forcedSaleValueKobo     BigInt?   @map("forced_sale_value_kobo")
  notes                   String?
  migrationSourceRef      String?   @unique @map("migration_source_ref")
  createdAt               DateTime  @default(now()) @map("created_at")

  // Invariant 27(b): the digitized 7-step Investee Onboarding Template.
  // onboardingStatus defaults to DRAFT for NEW (live-onboarded) rows; the
  // migration accompanying this field backfills every PRE-EXISTING
  // (migration-loaded) counterparty to COMPLETE_APPROVED — this gate is
  // forward-looking (new deployments), not a retroactive freeze on
  // counterparties already in active use before this workflow existed.
  onboardingStatus          CounterpartyOnboardingStatus @default(DRAFT) @map("onboarding_status")
  purposeOfFinancing        String?                      @map("purpose_of_financing")
  amountSoughtKobo          BigInt?                      @map("amount_sought_kobo")
  expectedSourceOfRepayment String?                      @map("expected_source_of_repayment")
  // Invariant 27(b) addition: credit-bureau consent captured at Step 1 (per
  // the payment-reminders process doc's credit-bureau sync).
  creditBureauConsentAt     DateTime?                    @map("credit_bureau_consent_at")
  onboardedByUserId         String?                      @map("onboarded_by_user_id") @db.Uuid

  // Invariant 28(e): second portal-realm persona. contactEmail is the
  // portal login credential (mirrors Investor.contactEmail); provisioning
  // happens once onboardingStatus reaches COMPLETE_APPROVED (mirrors WM's
  // Flow-C auto-provisioning at KYC completion). restructuringRequestsEnabled
  // is the staff-side per-counterparty toggle invariant 28(e) calls for.
  contactEmail                 String?   @unique @map("contact_email")
  portalProvisionedAt          DateTime? @map("portal_provisioned_at")
  restructuringRequestsEnabled Boolean   @default(true) @map("restructuring_requests_enabled")

  // Invariant 36(a): "file-ownership as data" — the officer who processed/
  // manages this investee's application, so system-generated deliverables
  // (payment-reminder call tasks, credit-bureau sync tasks) route to the
  // real owner rather than a role-wide broadcast. Nullable: existing
  // counterparties predate this field; falls back to a PORT_MGR broadcast
  // when unset (documented exception, not silently dropped).
  fileManagingOfficerUserId String? @map("file_managing_officer_user_id") @db.Uuid

  // Invariant 51(b-vi) (CHECK13): "counterparty closure/write-off workflow
  // driving the existing IMPAIRMENT_CHARGE event under approval." A
  // SEPARATE axis from onboardingStatus (which only ever gates the initial
  // onboarding template, DRAFT->...->COMPLETE_APPROVED/DECLINED) -- this is
  // the post-onboarding account-lifecycle state.
  accountStatus CounterpartyAccountStatus @default(OPEN) @map("account_status")

  transactions                 Txn[]
  communications               ClientCommunication[]
  onboardedBy                  AppUser?                          @relation("CounterpartyOnboardedBy", fields: [onboardedByUserId], references: [id])
  fileManagingOfficer          AppUser?                          @relation("CounterpartyFileManagingOfficer", fields: [fileManagingOfficerUserId], references: [id])
  onboardingCase               CounterpartyOnboardingCase?
  portalUser                   PortalCounterpartyUser?
  restructureRequests          CounterpartyRestructureRequest[]
  writeOffRequests             CounterpartyWriteOffRequest[]
  complaints                   Complaint[]
  privacyNoticeAcknowledgments PrivacyNoticeAcknowledgment[]
  facilityApplications         CounterpartyFacilityApplication[]
  repaymentObligations         CounterpartyRepaymentObligation[]
  bureauPulls                  BureauPullLog[]
  documentUploads              DocumentRegisterEntry[]
  letterInstances              LetterInstance[]
  execOversightSessions        ExecOversightSession[]
  feeInvoices                  FeeInvoice[]

  @@map("counterparty")
}

enum CounterpartyOnboardingStatus {
  DRAFT
  IN_REVIEW
  COMPLETE_APPROVED
  DECLINED

  @@map("counterparty_onboarding_status")
}

enum CounterpartyAccountStatus {
  OPEN
  WRITTEN_OFF
  CLOSED

  @@map("counterparty_account_status")
}

// Invariant 51(b-vi): single-approval shape (FIN_ADMIN, who already holds
// JOURNAL_ENTRIES INITIATE -- see EventJournalService.generateAndRequestPosting's
// own capability requirement -- rather than inventing a second capability
// grant just to let a different approver fire the journal). Maker!=checker
// still holds structurally (the proposer is never FIN_ADMIN's own approval
// step), and the resulting impairment journal itself still lands in
// PENDING_APPROVAL, requiring a genuinely different checker via the
// standing LedgerService.approveJournalPosting flow before it posts --
// two real independent human decisions, not one. Approver-seat choice
// flagged in QUESTIONS_FOR_REVIEW.md since Risk/MD sign-off is a plausible
// alternative for something this P&L-significant.
model CounterpartyWriteOffRequest {
  id                    String                     @id @default(uuid()) @db.Uuid
  counterpartyId        String                     @map("counterparty_id") @db.Uuid
  writeOffAmountKobo    BigInt                     @map("write_off_amount_kobo")
  ledgerEntityCode      String                     @map("ledger_entity_code")
  investmentAccountCode String                     @map("investment_account_code")
  reason                String
  status                CounterpartyWriteOffStatus @default(PENDING)
  requestedByUserId     String                     @map("requested_by_user_id") @db.Uuid
  workflowInstanceId    String?                    @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes        String?                    @map("rejection_notes")
  // Deliberately NOT a formal relation (mirrors JournalEntry.interEntityRef's
  // own documented reasoning for a plain string over a cross-cutting FK) --
  // this is a lookup convenience for the request's own detail view, not a
  // join any query needs to walk.
  postedJournalEntryId  String?                    @map("posted_journal_entry_id") @db.Uuid
  createdAt             DateTime                   @default(now()) @map("created_at")

  counterparty     Counterparty      @relation(fields: [counterpartyId], references: [id])
  requestedBy      AppUser           @relation("CounterpartyWriteOffRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("counterparty_write_off_request")
}

enum CounterpartyWriteOffStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("counterparty_write_off_status")
}

// Mirrors InvestorOnboardingCase's shape exactly (same template family,
// same IC1 -> Risk -> [MD] -> IC2 chain) — kept as a separate model rather
// than a polymorphic shared table so investor and counterparty case data
// never cross-reference each other by accident.
model CounterpartyOnboardingCase {
  id             String @id @default(uuid()) @db.Uuid
  counterpartyId String @unique @map("counterparty_id") @db.Uuid

  pepSanctionsGrid           Json?             @map("pep_sanctions_grid")
  riskMetricGrades           Json?             @map("risk_metric_grades")
  accumulativeRiskProfile    RiskProfileGrade? @map("accumulative_risk_profile")
  eddRequired                Boolean?          @map("edd_required")
  complianceObservations     String?           @map("compliance_observations")
  complianceAssessedByUserId String?           @map("compliance_assessed_by_user_id") @db.Uuid
  complianceAssessedAt       DateTime?         @map("compliance_assessed_at")

  ic1Checklist Json?   @map("ic1_checklist")
  ic1Notes     String? @map("ic1_notes")

  eddChecklist            Json?              @map("edd_checklist")
  eddRecommendation       EddRecommendation? @map("edd_recommendation")
  eddConditionsOrBasis    String?            @map("edd_conditions_or_basis")
  periodicReviewFrequency String?            @map("periodic_review_frequency")
  // Invariant 51(b-vii) (CHECK13): the consumption side of
  // periodicReviewFrequency -- null until Compliance's first post-
  // onboarding review; the sweep treats "due" as
  // lastPeriodicReviewAt (or onboarding-complete date if never reviewed)
  // + frequency having elapsed.
  lastPeriodicReviewAt    DateTime?          @map("last_periodic_review_at")
  // Invariant 27(b): approved exposure limit set AT the Risk step, feeding
  // control C20 — written onto Counterparty.enterpriseLimitKobo, not
  // duplicated here; this is the free-text rationale only.
  riskNotes               String?            @map("risk_notes")

  mdDecision           MdOnboardingDecision? @map("md_decision")
  mdConditionsOrReason String?               @map("md_conditions_or_reason")

  ic2Checklist Json?       @map("ic2_checklist")
  ic2Outcome   Ic2Outcome? @map("ic2_outcome")
  ic2Notes     String?     @map("ic2_notes")

  workflowInstanceId String?  @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])

  @@map("counterparty_onboarding_case")
}

// TPL_04 Product Accounts — the missing link Core Schema Skeleton always
// intended between an Investor and a Product (Build Plan step 5's Product
// catalogue and step 6's Investor master were built independently; this is
// where they finally meet, per the Migration Data Standards' load-order
// step 4). One row per investor's holding in one product — the exact
// "same investor in both products" overlap case the migration template's
// demo rows deliberately exercise (MIG-INV-0001 in both TPL_04 rows).
// psrInvestorPct/psrMudaribPct are the ACCOUNT's own PSR split when it
// differs from the pool default carried on ProductParameters (AMD-01/02)
// — nullable, since UNIT_NAV (Halal Fund) accounts never carry one.
model ProductAccount {
  id                       String                 @id @default(uuid()) @db.Uuid
  investorId               String                 @map("investor_id")
  productCode              String                 @map("product_code")
  startDate                DateTime               @map("start_date")
  maturityDate             DateTime?              @map("maturity_date")
  principalOrCommittedKobo BigInt                 @map("principal_or_committed_kobo")
  currency                 String                 @default("NGN")
  targetReturnPctBenchmark Decimal?               @map("target_return_pct_benchmark") @db.Decimal(6, 4)
  psrInvestorPct           Decimal?               @map("psr_investor_pct") @db.Decimal(6, 4)
  psrMudaribPct            Decimal?               @map("psr_mudarib_pct") @db.Decimal(6, 4)
  unitsHeld                Decimal?               @map("units_held") @db.Decimal(18, 4)
  mandateTermsRef          String?                @map("mandate_terms_ref")
  // Phase 4 §2 (portfolio-stress model, DQ-14 correction): the field named
  // in Data Dictionary §4 Dev Notes — Σ(exposure WHERE liquidity_class=
  // 'Level 3') / total, computed from THIS field, never the workbook's
  // wrong severe+extreme-loss cells. Free text (Level 1/2/3), nullable —
  // most accounts have no classification yet (no asset-class questionnaire
  // exists in onboarding), honestly excluded from the ratio rather than
  // defaulted to a class.
  liquidityClass           String?                @map("liquidity_class")
  // TPL_04 v2 (Mandatory Integrity Review correction 21a-iii): client-level
  // elections, nullable — dripElection (AUTO/MANUAL/NONE) is Halal Fund-only
  // per amendment 26; rolloverElection (ROLLOVER/REDEEM/PENDING) is
  // Mudarabah-pool-only and feeds compliance control C15. Neither applies to
  // the other product, so both stay nullable rather than split into two
  // tables — same one-row-per-holding shape as the PSR pair above.
  dripElection             String?                @map("drip_election")
  rolloverElection         String?                @map("rollover_election")
  status                   ProductAccountStatus   @default(ACTIVE)
  notes                    String?
  migrationSourceRef       String?                @unique @map("migration_source_ref")
  // Invariant 65(a) (CHECK18): set in the SAME FA deposit-confirmation step
  // as targetReturnPctBenchmark/maturityDate above (invariant 62h) --
  // drives the Fund Obligations Schedule's projected-payout computation
  // (target x interval). Nullable until that step runs, same as the two
  // fields it joins.
  profitPaymentInterval    ProfitPaymentInterval? @map("profit_payment_interval")
  createdAt                DateTime               @default(now()) @map("created_at")

  investor               Investor                @relation(fields: [investorId], references: [investorId])
  product                Product                 @relation(fields: [productCode], references: [code])
  txns                   Txn[]
  distributionLineItems  DistributionLineItem[]
  certificates           Certificate[]
  letterInstances        LetterInstance[]
  payoutCompilationLines PayoutCompilationLine[]

  @@map("product_account")
}

enum ProductAccountStatus {
  ACTIVE
  MATURED
  CLOSED

  @@map("product_account_status")
}

// Invariant 42(a) (CHECK9): the staging row behind SubscriptionService's
// governed front door. Mirrors JournalEntry's DRAFT-then-approve shape —
// WorkflowInstance.entityId references THIS row (which exists at initiate
// time), never a not-yet-created ProductAccount. Only the approval step
// (SubscriptionService.approveSubscription/approveRedemption) writes the
// real ProductAccount + cash-leg Txn (+ NdMandateAccount for MANDATE
// products) and stamps resultProductAccountId/resultNdMandateAccountId —
// so a rejected or still-pending request never has a live holding sitting
// behind it. unitsHeld is computed and stamped HERE at approval time from
// the NAV published for effectiveDate (forward-pricing: never the
// initiator-supplied figure, never the NAV as of initiation) — HF products
// only; POOL/MANDATE requests leave it null (invariant 44a: no unit
// concept off the unit-NAV engine).
model SubscriptionRequest {
  id                       String                    @id @default(uuid()) @db.Uuid
  requestType              SubscriptionRequestType   @map("request_type")
  investorId               String                    @map("investor_id")
  productCode              String                    @map("product_code")
  amountKobo               BigInt                    @map("amount_kobo")
  effectiveDate            DateTime                  @map("effective_date")
  status                   SubscriptionRequestStatus @default(PENDING)
  computedUnits            Decimal?                  @map("computed_units") @db.Decimal(18, 4)
  navPerUnitUsed           Decimal?                  @map("nav_per_unit_used") @db.Decimal(18, 4)
  resultProductAccountId   String?                   @map("result_product_account_id") @db.Uuid
  resultNdMandateAccountId String?                   @map("result_nd_mandate_account_id") @db.Uuid
  rejectionReason          String?                   @map("rejection_reason")
  initiatedByUserId        String                    @map("initiated_by_user_id") @db.Uuid
  workflowInstanceId       String?                   @unique @map("workflow_instance_id") @db.Uuid
  createdAt                DateTime                  @default(now()) @map("created_at")
  decidedAt                DateTime?                 @map("decided_at")

  investor              Investor              @relation(fields: [investorId], references: [investorId])
  product               Product               @relation(fields: [productCode], references: [code])
  initiator             AppUser               @relation("SubscriptionRequestInitiator", fields: [initiatedByUserId], references: [id])
  workflow              WorkflowInstance?     @relation(fields: [workflowInstanceId], references: [id])
  gatewayInflowOrigin   PaymentGatewayInflow? @relation("PaymentGatewayInflowSubscription")
  gatewayInflowReversed PaymentGatewayInflow? @relation("PaymentGatewayInflowReversal")

  @@map("subscription_request")
}

enum SubscriptionRequestType {
  SUBSCRIPTION
  REDEMPTION

  @@map("subscription_request_type")
}

enum SubscriptionRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("subscription_request_status")
}

// Generic migration staging — TPL_01-10 all land here first (Migration Data
// Standards: "Filled templates come back to this folder -> I run validation
// against every rule above -> exceptions list -> you correct or explain ->
// clean load"). One shared staging shape for all ten templates rather than
// ten bespoke tables: rawData is the row exactly as the CSV presented it
// (column names as keys, string values), so a template's own header row is
// the schema — adding an eleventh template later is new MigrationService
// gate logic, not a migration. Promotion is idempotent by design: a batch
// can be re-validated and re-promoted any number of times without side
// effects (upsert on migrationSourceRef throughout), matching the seeding
// discipline established at M1 (closes-D8 pattern).
model MigrationBatch {
  id               String               @id @default(uuid()) @db.Uuid
  tplCode          String               @map("tpl_code")
  fileName         String               @map("file_name")
  uploadedByUserId String               @map("uploaded_by_user_id") @db.Uuid
  status           MigrationBatchStatus @default(STAGED)
  totalRows        Int                  @map("total_rows")
  validRows        Int?                 @map("valid_rows")
  rejectedRows     Int?                 @map("rejected_rows")
  promotedRows     Int?                 @map("promoted_rows")
  createdAt        DateTime             @default(now()) @map("created_at")
  validatedAt      DateTime?            @map("validated_at")
  promotedAt       DateTime?            @map("promoted_at")

  uploadedBy AppUser               @relation(fields: [uploadedByUserId], references: [id])
  rows       MigrationStagingRow[]

  @@map("migration_batch")
}

enum MigrationBatchStatus {
  STAGED
  VALIDATED
  PROMOTED

  @@map("migration_batch_status")
}

model MigrationStagingRow {
  id               String           @id @default(uuid()) @db.Uuid
  batchId          String           @map("batch_id") @db.Uuid
  rowNumber        Int              @map("row_number")
  rawData          Json             @map("raw_data")
  isDemoRow        Boolean          @default(false) @map("is_demo_row")
  status           StagingRowStatus @default(PENDING)
  // One entry per failed gate: { gate: string, reason: string }. Empty array
  // once VALID. Named "every rejected row and why" per the CEO instruction.
  rejectionReasons Json             @default("[]") @map("rejection_reasons")
  promotedEntityId String?          @map("promoted_entity_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  batch MigrationBatch @relation(fields: [batchId], references: [id])

  @@unique([batchId, rowNumber])
  @@map("migration_staging_row")
}

enum StagingRowStatus {
  PENDING
  VALID
  REJECTED
  PROMOTED

  @@map("staging_row_status")
}

// ============================================================================
// Replay harness (item 2 of the post-Check-2 instruction): "completes BEFORE
// engine code — it is the acceptance mechanism, so it exists before the
// thing it accepts." Ingests the workbook CSV history (Halal Fund
// transactions, NAV history, Mudarabah investor transactions/placements)
// into staging, with INGESTION AND RECONCILIATION COUNTS ONLY — engine
// computation (recomputing NAV/allocations and comparing to published
// values) is Phase 3 sealed-engine work (tasks 39/40/42), which reads this
// staged data directly rather than the live operational tables, since the
// workbook history predates and is independent of the TPL_01-10 migration
// load. Same generic-staging shape as MigrationBatch/MigrationStagingRow,
// deliberately kept separate: promotion semantics differ (this never
// promotes into Investor/Txn/ProductAccount — it stays staged for the
// engines to read and compare against, per "engine computation stays
// Phase 3").
// ============================================================================
model ReplayBatch {
  id               String   @id @default(uuid()) @db.Uuid
  sourceCode       String   @map("source_code")
  fileName         String   @map("file_name")
  totalRows        Int      @map("total_rows")
  ingestedByUserId String   @map("ingested_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  ingestedBy AppUser           @relation(fields: [ingestedByUserId], references: [id])
  rows       ReplaySourceRow[]

  @@map("replay_batch")
}

model ReplaySourceRow {
  id        String   @id @default(uuid()) @db.Uuid
  batchId   String   @map("batch_id") @db.Uuid
  rowNumber Int      @map("row_number")
  rawData   Json     @map("raw_data")
  createdAt DateTime @default(now()) @map("created_at")

  batch ReplayBatch @relation(fields: [batchId], references: [id])

  @@unique([batchId, rowNumber])
  @@map("replay_source_row")
}

// ============================================================================
// PMS/Payroll SDS v1 §§1-2 — "the strategy spine" + org/emolument extension.
// Slot A only (SDS §8): schema + DRAFT seed content. No scoring workflow, no
// incentive engine, no behavioural gate, no payroll run — those are
// "after Check-2 / alongside Phase 3" per the SDS's own build sequencing.
// AMD-12 pattern throughout: ships as FRAMEWORK, values entered at
// activation through governed workflows (SDS §5's activation checklist).
// ============================================================================

// Level 1 (memo §2). code is the natural key, same "config not code" pattern
// as Role/PlatformFunction — a future pillar is a data row.
model StrategicPillar {
  code               String             @id
  name               String
  description        String?
  status             GovernedItemStatus @default(DRAFT)
  createdAt          DateTime           @default(now()) @map("created_at")
  // Invariant 28(c): the strategy layer OWNS this existing PMS strategy-
  // spine row — explanation is the staff-comprehension text the invariant
  // requires on every governance artifact; boardResolutionRef is set the
  // moment a Board resolution attaches a change (StrategyLayerService.
  // updatePillarGovernance), same evidence-attachment discipline as every
  // other Board-gated version in this codebase.
  explanation        String?            @map("explanation")
  boardResolutionRef String?            @map("board_resolution_ref")
  // Invariant 51(c2) (CHECK12): governed creation was seed-only until now --
  // these three mirror StrategyStatement's own propose/approve columns so a
  // pillar's ORIGIN (who proposed, who approved, which workflow instance)
  // is traceable the same way, even though the row itself stays single-row-
  // per-code (status DRAFT/ACTIVE/SUPERSEDED) rather than StrategyStatement's
  // insert-only multi-row versioning -- there's no meaningful "prior version"
  // of a pillar/objective to retain, only a governance-gated creation.
  proposedByUserId   String?            @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid

  objectiveMap PillarObjectiveMap[]

  @@map("strategic_pillar")
}

// Level 2 (memo §3).
model StrategicObjective {
  code               String             @id
  name               String
  status             GovernedItemStatus @default(DRAFT)
  createdAt          DateTime           @default(now()) @map("created_at")
  explanation        String?            @map("explanation")
  boardResolutionRef String?            @map("board_resolution_ref")
  // Invariant 51(c2) (CHECK12): see the matching comment on StrategicPillar.
  proposedByUserId   String?            @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid

  pillarMap PillarObjectiveMap[]
  kraMap    KraObjectiveMap[]

  @@map("strategic_objective")
}

// Invariant 19 (SaaS trajectory): the statement-type VOCABULARY is governed
// config, not a fixed enum — a future tenant (or a One17 governance change)
// adds a new artifact type ("Tagline", "5-Year Plan") as a data row, never
// a migration. allowsMultipleActive replaces what would otherwise be a
// hardcoded "CORE_VALUE is special" string check in the service — CORE_VALUE
// is simply the one seeded row with allowsMultipleActive=true (a list of
// values, not one singular statement a new version replaces).
model StrategyStatementTypeConfig {
  code                 String   @id
  label                String
  description          String?
  allowsMultipleActive Boolean  @default(false) @map("allows_multiple_active")
  sortOrder            Int      @default(0) @map("sort_order")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")

  statements StrategyStatement[]

  @@map("strategy_statement_type_config")
}

// Invariant 52(a) (CHECK12): "single governed asset, versioned ... applied
// to EVERY client-facing PDF the platform emits." One global ACTIVE row at
// a time (no per-product-class dimension, unlike RegulatorTemplate) --
// versioned exactly like RiskAppetiteMatrixVersion: propose DRAFT -> MD_CEO
// approve -> ACTIVE, prior global ACTIVE row superseded. Content fields are
// governed config per the invariant's own text ("not hardcoded") -- the
// business-text ones (address/RC number/SEC registration line/footer
// disclaimer) are CoSec's content to supply, seeded here with placeholder
// markers, never invented (see QUESTIONS_FOR_REVIEW.md). companyName and
// the brand palette are already-established facts elsewhere in this
// codebase (invariant 46h2), not new business content.
model LetterheadTemplate {
  id                   String             @id @default(uuid()) @db.Uuid
  version              Int
  status               GovernedItemStatus @default(DRAFT)
  companyName          String             @map("company_name")
  addressLine1         String             @map("address_line1")
  addressLine2         String?            @map("address_line2")
  rcNumber             String             @map("rc_number")
  secRegistrationLine  String             @map("sec_registration_line")
  brandPrimaryColorHex String             @map("brand_primary_color_hex")
  brandAccentColorHex  String             @map("brand_accent_color_hex")
  brandDeepColorHex    String             @map("brand_deep_color_hex")
  footerDisclaimer     String             @map("footer_disclaimer")
  proposedByUserId     String?            @map("proposed_by_user_id") @db.Uuid
  approvedByUserId     String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId   String?            @unique @map("workflow_instance_id") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at")

  @@unique([version])
  @@map("letterhead_template")
}

// Invariant 52(b)/(c) (CHECK12): "TEMPLATE MANAGEMENT FUNCTION (explicit
// CEO requirement): upload/replace/adjust certificate (and letter)
// templates through a governed template registry -- versioned,
// capability-gated, maker!=checker on activation." One shared registry
// keyed by (templateType, templateKey) rather than two near-identical
// tables -- certificates key on product class (HF_UNIT_NAV/POOL_ND_PSR/
// ND_WAKALAH), letters (52c) will key on letter type. Only wording/
// disclaimer content is template-governed here; the MANDATORY per-class
// data fields (units+NAV, principal+tenor+PSR+target-return+capital-at-
// risk, fee+expected-profit) are standing 44(a) law enforced structurally
// in code, never template-editable.
model DocumentTemplate {
  id                 String               @id @default(uuid()) @db.Uuid
  templateType       DocumentTemplateType @map("template_type")
  templateKey        String               @map("template_key")
  version            Int
  status             GovernedItemStatus   @default(DRAFT)
  // CERTIFICATE templates use disclaimerText/secRuleDisclaimer (both
  // required by CertificateService.proposeTemplate at the app layer).
  // LETTER templates (52c) use bodyTemplate instead -- the merge-field
  // letter body -- and leave the disclaimer pair null; nullable here
  // because Prisma has no per-enum-value column requirement, so the
  // "required for this type" rule is enforced in each type's own service,
  // not the schema.
  disclaimerText     String?              @map("disclaimer_text")
  secRuleDisclaimer  String?              @map("sec_rule_disclaimer")
  bodyTemplate       String?              @map("body_template")
  proposedByUserId   String?              @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?              @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?              @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at")

  certificatesIssued Certificate[]
  letterInstances    LetterInstance[]

  @@unique([templateType, templateKey, version])
  @@map("document_template")
}

enum DocumentTemplateType {
  CERTIFICATE
  LETTER

  @@map("document_template_type")
}

// Invariant 52(b): "Issuance is IMMEDIATE and AUTOMATIC at subscription
// approval ... for HF, Pool, and ND Mandate." QUEUED (no ACTIVE template
// yet for the class -- "the booking itself NEVER fails") -> ISSUED (PDF
// rendered, certificateNumber drawn from the governed sequence, immutable
// from that point). dataSnapshot freezes the point-in-time mandatory
// content at issuance/queue time, so a later NAV/PSR change on the account
// never retroactively alters an already-issued certificate.
model Certificate {
  id                      String                  @id @default(uuid()) @db.Uuid
  certificateNumber       String?                 @unique @map("certificate_number")
  investorId              String                  @map("investor_id")
  productAccountId        String?                 @map("product_account_id") @db.Uuid
  ndMandateAccountId      String?                 @map("nd_mandate_account_id") @db.Uuid
  productClass            CertificateProductClass @map("product_class")
  status                  CertificateStatus       @default(QUEUED)
  dataSnapshot            Json                    @map("data_snapshot")
  pdfBytes                Bytes?                  @map("pdf_bytes")
  documentRegisterEntryId String?                 @map("document_register_entry_id") @db.Uuid
  templateId              String?                 @map("template_id") @db.Uuid
  issuedAt                DateTime?               @map("issued_at")
  createdAt               DateTime                @default(now()) @map("created_at")

  investor         Investor          @relation(fields: [investorId], references: [investorId])
  productAccount   ProductAccount?   @relation(fields: [productAccountId], references: [id])
  ndMandateAccount NdMandateAccount? @relation(fields: [ndMandateAccountId], references: [id])
  template         DocumentTemplate? @relation(fields: [templateId], references: [id])

  @@map("certificate")
}

enum CertificateProductClass {
  HF_UNIT_NAV
  POOL_ND_PSR
  ND_WAKALAH

  @@map("certificate_product_class")
}

enum CertificateStatus {
  QUEUED
  ISSUED

  @@map("certificate_status")
}

// Invariant 52(c) (CHECK12): "governed letter-template registry (merge
// fields from investor/counterparty/product/account data), generation ->
// maker!=checker approval for client-facing issuance -> dispatch via email
// w/ communication-log entry -> stored in document register." Unlike
// certificates (system-triggered, auto-issue), letters are a discrete
// STAFF action every time -- generate() renders the merge-filled body and
// opens a workflow; a DIFFERENT user's approval is what actually issues
// it. No QUEUED state: if no ACTIVE template exists for the letter type,
// generate() refuses outright rather than queuing (there is no later
// "auto-fires" moment for a letter the way there is for a subscription
// approval).
model LetterInstance {
  id                      String               @id @default(uuid()) @db.Uuid
  letterType              String               @map("letter_type")
  templateId              String               @map("template_id") @db.Uuid
  investorId              String?              @map("investor_id")
  counterpartyId          String?              @map("counterparty_id") @db.Uuid
  productAccountId        String?              @map("product_account_id") @db.Uuid
  ndMandateAccountId      String?              @map("nd_mandate_account_id") @db.Uuid
  mergedBody              String               @map("merged_body")
  status                  LetterInstanceStatus @default(PENDING_APPROVAL)
  generatedByUserId       String               @map("generated_by_user_id") @db.Uuid
  approvedByUserId        String?              @map("approved_by_user_id") @db.Uuid
  workflowInstanceId      String?              @unique @map("workflow_instance_id") @db.Uuid
  pdfBytes                Bytes?               @map("pdf_bytes")
  documentRegisterEntryId String?              @map("document_register_entry_id") @db.Uuid
  rejectionNotes          String?              @map("rejection_notes")
  issuedAt                DateTime?            @map("issued_at")
  createdAt               DateTime             @default(now()) @map("created_at")

  template           DocumentTemplate        @relation(fields: [templateId], references: [id])
  investor           Investor?               @relation(fields: [investorId], references: [investorId])
  counterparty       Counterparty?           @relation(fields: [counterpartyId], references: [id])
  productAccount     ProductAccount?         @relation(fields: [productAccountId], references: [id])
  ndMandateAccount   NdMandateAccount?       @relation(fields: [ndMandateAccountId], references: [id])
  payoutBatch        PayoutCompilationBatch?
  taxRemittanceBatch TaxRemittanceBatch?

  @@map("letter_instance")
}

enum LetterInstanceStatus {
  PENDING_APPROVAL
  REJECTED
  ISSUED

  @@map("letter_instance_status")
}

// Invariant 28(c): vision/mission/core-values/3-yr-outlook — governance
// artifacts the strategy layer adds ALONGSIDE the existing pillars/
// objectives above, versioned exactly like RiskAppetiteMatrixVersion
// (propose DRAFT -> Board-resolution-gated approve -> ACTIVE, prior ACTIVE
// row of the SAME statementType superseded unless its type config allows
// multiple concurrent actives).
model StrategyStatement {
  id                 String             @id @default(uuid()) @db.Uuid
  statementTypeCode  String             @map("statement_type_code")
  content            String
  explanation        String?
  status             GovernedItemStatus @default(DRAFT)
  boardResolutionRef String?            @map("board_resolution_ref")
  proposedByUserId   String             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  effectiveFrom      DateTime?          @map("effective_from")
  createdAt          DateTime           @default(now()) @map("created_at")

  statementType StrategyStatementTypeConfig @relation(fields: [statementTypeCode], references: [code])
  proposedBy    AppUser                     @relation("StrategyStatementProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy    AppUser?                    @relation("StrategyStatementApprovedBy", fields: [approvedByUserId], references: [id])

  @@map("strategy_statement")
}

// Invariant 28(c): "PUBLISH-to-staff with read-acknowledgment tracking."
// SAU administers this tracking (their KRA) — StrategyLayerService.
// getAcknowledgmentStatus() is the read surface SAU's tracking screen uses.
model StrategyPublication {
  id                String   @id @default(uuid()) @db.Uuid
  summary           String
  publishedByUserId String   @map("published_by_user_id") @db.Uuid
  publishedAt       DateTime @default(now()) @map("published_at")

  publishedBy     AppUser                  @relation(fields: [publishedByUserId], references: [id])
  acknowledgments StrategyAcknowledgment[]

  @@map("strategy_publication")
}

model StrategyAcknowledgment {
  id             String   @id @default(uuid()) @db.Uuid
  publicationId  String   @map("publication_id") @db.Uuid
  appUserId      String   @map("app_user_id") @db.Uuid
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  publication StrategyPublication @relation(fields: [publicationId], references: [id])
  appUser     AppUser             @relation(fields: [appUserId], references: [id])

  @@unique([publicationId, appUserId])
  @@map("strategy_acknowledgment")
}

// Memo §3's causal table (M:N — e.g. Diversification -> both Brand Equity
// and Improving Profitability).
model PillarObjectiveMap {
  pillarCode    String @map("pillar_code")
  objectiveCode String @map("objective_code")

  pillar    StrategicPillar    @relation(fields: [pillarCode], references: [code])
  objective StrategicObjective @relation(fields: [objectiveCode], references: [code])

  @@id([pillarCode, objectiveCode])
  @@map("pillar_objective_map")
}

// One row per department (memo's "org_unit" — Portfolio/BD/FinCon/
// CorpServices/Risk/Technology/SAU/CoSec), same natural-key-string pattern
// used everywhere else in this schema for governed lookup lists.
model OrgUnit {
  code                   String  @id
  name                   String
  // Budget/Procurement Spec §1: Company Secretary & Legal and Risk & Audit
  // carry dotted-line reporting to the Board alongside their solid-line
  // reporting to MD — data (the org_unit's own reportsTo, not modeled here,
  // remains implicit in the org chart), not a code-level special case.
  secondaryReportingLine String? @map("secondary_reporting_line")

  kras                       EnterpriseKra[]
  positions                  Position[]
  weightRows                 KpiWeightMatrix[]
  aiCapabilityContextRules   AiCapabilityContextRule[]
  aiTokenBudgets             AiTokenBudget[]
  departmentHeadDesignations DepartmentHeadDesignation[]

  @@map("org_unit")
}

// Level 3 (memo §6 four-column table): one row per KRA, owned by a dept.
model EnterpriseKra {
  code        String             @id
  name        String
  orgUnitCode String             @map("org_unit_code")
  status      GovernedItemStatus @default(DRAFT)
  createdAt   DateTime           @default(now()) @map("created_at")

  orgUnit        OrgUnit           @relation(fields: [orgUnitCode], references: [code])
  objectiveMap   KraObjectiveMap[]
  kpiDefinitions KpiDefinition[]

  @@map("enterprise_kra")
}

model KraObjectiveMap {
  kraCode       String @map("kra_code")
  objectiveCode String @map("objective_code")

  kra       EnterpriseKra      @relation(fields: [kraCode], references: [code])
  objective StrategicObjective @relation(fields: [objectiveCode], references: [code])

  @@id([kraCode, objectiveCode])
  @@map("kra_objective_map")
}

// Level 4 (KPI Breakdown doc, verbatim per tier). One KRA -> up to three
// tiered KPIs (Junior/Senior/Chief), each with its own class/objective/
// example-activity text — exactly the doc's per-department tables.
model KpiDefinition {
  id                 String             @id @default(uuid()) @db.Uuid
  kraCode            String             @map("kra_code")
  tier               PmsTier
  kpiText            String             @map("kpi_text")
  kpiClass           KpiClass           @map("kpi_class")
  objectiveText      String?            @map("objective_text")
  exampleActivity    String?            @map("example_activity")
  measurementBasis   MeasurementBasis   @default(MANUAL) @map("measurement_basis")
  frequency          String?
  status             GovernedItemStatus @default(DRAFT)
  createdAt          DateTime           @default(now()) @map("created_at")
  // Invariant 51(c2) (CHECK12): see the matching comment on StrategicPillar
  // -- KPI definitions were seed-only (no propose/approve service) before
  // this build, same gap.
  proposedByUserId   String?            @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid

  kra EnterpriseKra @relation(fields: [kraCode], references: [code])

  roleScorecardOverrides RoleScorecardOverride[]
  activityReports        ActivityReport[]
  kpiScores              EmployeeKpiScore[]
  taggedTasks            Task[]

  @@unique([kraCode, tier])
  @@map("kpi_definition")
}

enum PmsTier {
  JUNIOR
  SENIOR
  CHIEF

  @@map("pms_tier")
}

enum KpiClass {
  CORE
  STRATEGIC
  SECONDARY
  PROCESS_INTEGRITY

  @@map("kpi_class")
}

enum MeasurementBasis {
  AUTO
  MANUAL
  HYBRID

  @@map("measurement_basis")
}

enum GovernedItemStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("governed_item_status")
}

// Memo's 7 weight tables (+ Technology, seeded DRAFT with the FinCon profile
// per CEO ruling "adopt similar weighting structure" — SDS §1 gap-fill).
// VERSIONED + GOVERNED per the 4-Jul-2026 CEO ruling: "follows the
// ProductParameters pattern — insert-only versions, full audit trail, and
// after initial activation any change requires CEO approval through the
// workflow engine." Same shape as ProductParameters/RiskAppetiteMatrixVersion:
// createdBy/approvedBy/workflowInstanceId, insert-only, never updated in
// place. CHECK constraint (hand-authored migration) enforces "Sigma per
// dept x tier = 100%" only across ACTIVE rows of the same (org_unit, tier,
// version) group — see the PMS migration.
model KpiWeightMatrix {
  id                 String             @id @default(uuid()) @db.Uuid
  orgUnitCode        String             @map("org_unit_code")
  tier               PmsTier
  kpiClass           KpiClass           @map("kpi_class")
  weightPct          Decimal            @map("weight_pct") @db.Decimal(5, 2)
  version            Int
  status             GovernedItemStatus @default(DRAFT)
  createdByUserId    String?            @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  orgUnit OrgUnit @relation(fields: [orgUnitCode], references: [code])

  @@unique([orgUnitCode, tier, kpiClass, version])
  @@map("kpi_weight_matrix")
}

// SDS §2: "Tier mapping for KPI purposes ... is data (cadre_tier_map), not
// code." Cadre ladder from Salary_Structure workbook.
model CadreTierMap {
  cadre String  @id
  tier  PmsTier

  @@map("cadre_tier_map")
}

// SDS §2: "position gains cadre + notch." Position didn't exist before PMS
// (Phase 1/2 had no HR module) — this is its first appearance.
model Position {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  orgUnitCode String   @map("org_unit_code")
  cadre       String
  notch       Int
  createdAt   DateTime @default(now()) @map("created_at")

  orgUnit            OrgUnit                     @relation(fields: [orgUnitCode], references: [code])
  employees          Employee[]
  onboardingRequests EmployeeOnboardingRequest[]

  @@unique([title, orgUnitCode])
  @@map("position")
}

// SDS §2: "employee master ... ONE identity law applies: employee != a
// second user master; it extends it." appUserId nullable — "drivers/
// cleaners may have no system login." performanceIncentivePct defaults to
// the memo's 25% at-risk pool; overridable per employee since the memo
// frames it as a general default, not an immutable constant.
model Employee {
  id                      String         @id @default(uuid()) @db.Uuid
  // CEO ruling 4-Jul (invariant 29a): "employee names split SURNAME /
  // FIRST_NAME / MIDDLE_NAME (never a single full_name field —
  // consistency with valid IDs; TPL_08 v2 reshaped accordingly)."
  surname                 String         @map("surname")
  firstName               String         @map("first_name")
  middleName              String?        @map("middle_name")
  positionId              String         @map("position_id") @db.Uuid
  orgUnitCode             String         @map("org_unit_code")
  reportsToId             String?        @map("reports_to_id") @db.Uuid
  appUserId               String?        @unique @map("app_user_id") @db.Uuid
  hireDate                DateTime       @map("hire_date")
  status                  EmployeeStatus @default(ACTIVE)
  performanceIncentivePct Decimal        @default(25.00) @map("performance_incentive_pct") @db.Decimal(5, 2)
  migrationSourceRef      String?        @unique @map("migration_source_ref")
  createdAt               DateTime       @default(now()) @map("created_at")

  position  Position   @relation(fields: [positionId], references: [id])
  reportsTo Employee?  @relation("EmployeeReportsTo", fields: [reportsToId], references: [id])
  reports   Employee[] @relation("EmployeeReportsTo")
  appUser   AppUser?   @relation(fields: [appUserId], references: [id])

  roleScorecardOverrides       RoleScorecardOverride[]
  activityReports              ActivityReport[]
  scoreSubmissions             EmployeeScoreSubmission[]
  gateChecks                   BehaviouralGateCheck[]
  incentiveResults             EmployeeIncentiveResult[]
  payrollRunLines              PayrollRunLine[]
  personalRecord               EmployeePersonalRecord?
  talentRecommendations        TalentRecommendation[]
  personalRecordChangeRequests EmployeePersonalRecordChangeRequest[]
  assignedTasks                Task[]                                @relation("TaskAssignee")
  onboardingResultOf           EmployeeOnboardingRequest?            @relation("EmployeeOnboardingResult")
  offboardingRequests          EmployeeOffboardingRequest[]
  incentivePctChangeRequests   EmployeeIncentivePctChangeRequest[]
  taskSubmissionsMade          TaskSubmission[]                      @relation("TaskSubmissionSubmitter")
  taskSubmissionsToDecide      TaskSubmission[]                      @relation("TaskSubmissionSupervisor")
  leaveEntitlements            LeaveEntitlement[]
  leaveApplications            LeaveApplication[]                    @relation("LeaveApplicant")
  leaveReliefFor               LeaveApplication[]                    @relation("LeaveReliefOfficer")
  attendanceEvents             AttendanceEvent[]
  attendanceExceptionRequests  AttendanceExceptionRequest[]
  attendanceLockUserMappings   AttendanceLockUserMapping[]
  departmentHeadDesignations   DepartmentHeadDesignation[]

  @@map("employee")
}

// Invariant 74(b) (CHECK27, v1.2): a first-class, governed "who leads this
// org unit" marker -- held by the PERSON (Employee) regardless of cadre, so
// a Manager who is the senior-most officer in a department qualifies just
// as a Chief would. Deliberately versioned/status-driven (DRAFT->ACTIVE->
// SUPERSEDED), same shape as RiskAppetiteMatrixVersion, rather than a
// mutate-in-place boolean flag -- effective-dating and "moves cleanly when
// leadership changes" both require a real history, not a single row a new
// assignment silently overwrites. HR_ADMIN proposes (INITIATE), MD_CEO
// approves (APPROVE) -- see DEPARTMENT_HEAD_DESIGNATION capability/
// workflow type in seed.ts. On approval, DepartmentHeadService supersedes
// whatever designation was previously ACTIVE for the same org unit in the
// same transaction, so "one active head per unit" is enforced BOTH at the
// service level (the same-transaction supersession above) AND, per
// invariant 75(c) (CHECK28, v1.2.1 audit remediation §8), structurally by
// a PostgreSQL partial unique index on (org_unit_code) WHERE status =
// 'ACTIVE' -- migration-authored, same DB-level pattern as
// CounterpartyRestructureRequest's own partial unique index above -- so
// two concurrent approvals racing the same org unit cannot both commit an
// ACTIVE row even if the service-level supersession window is somehow
// beaten. Invariant 74(c): this is the reusable
// "who leads this unit" truth other escalation/routing logic should adopt
// over time, per the CEO's own design note -- built once here, not
// re-approximated per module.
model DepartmentHeadDesignation {
  id                 String                          @id @default(uuid()) @db.Uuid
  orgUnitCode        String                          @map("org_unit_code")
  employeeId         String                          @map("employee_id") @db.Uuid
  status             DepartmentHeadDesignationStatus @default(DRAFT)
  effectiveFrom      DateTime?                       @map("effective_from")
  effectiveTo        DateTime?                       @map("effective_to")
  proposedByUserId   String                          @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?                         @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?                         @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime                        @default(now()) @map("created_at")

  orgUnit    OrgUnit  @relation(fields: [orgUnitCode], references: [code])
  employee   Employee @relation(fields: [employeeId], references: [id])
  proposedBy AppUser  @relation("DepartmentHeadProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy AppUser? @relation("DepartmentHeadApprovedBy", fields: [approvedByUserId], references: [id])

  @@map("department_head_designation")
}

enum DepartmentHeadDesignationStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  REVOKED

  @@map("department_head_designation_status")
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED

  @@map("employee_status")
}

enum EmployeeLifecycleRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("employee_lifecycle_request_status")
}

// Invariant 50(b) (CHECK12): governed employee lifecycle -- a new hire is
// PROPOSED (HR, with the position/org-unit/hire-date already decided) and
// only becomes a real Employee row once a DIFFERENT approver signs off
// (maker!=checker, generic engine). Addendum (CEO, 8-Jul-2026): the
// proposed performanceIncentivePct travels with the SAME approval gate as
// the rest of onboarding -- there is no separate initial-pct approval step
// because the whole request is already approval-gated end to end.
model EmployeeOnboardingRequest {
  id                              String                         @id @default(uuid()) @db.Uuid
  surname                         String
  firstName                       String                         @map("first_name")
  middleName                      String?                        @map("middle_name")
  positionId                      String                         @map("position_id") @db.Uuid
  orgUnitCode                     String                         @map("org_unit_code")
  reportsToId                     String?                        @map("reports_to_id") @db.Uuid
  hireDate                        DateTime                       @map("hire_date")
  proposedPerformanceIncentivePct Decimal                        @default(25.00) @map("proposed_performance_incentive_pct") @db.Decimal(5, 2)
  linkedUserEmail                 String?                        @map("linked_user_email")
  status                          EmployeeLifecycleRequestStatus @default(PENDING)
  requestedByUserId               String                         @map("requested_by_user_id") @db.Uuid
  workflowInstanceId              String?                        @unique @map("workflow_instance_id") @db.Uuid
  resultingEmployeeId             String?                        @unique @map("resulting_employee_id") @db.Uuid
  rejectionNotes                  String?                        @map("rejection_notes")
  createdAt                       DateTime                       @default(now()) @map("created_at")

  position          Position          @relation(fields: [positionId], references: [id])
  requestedBy       AppUser           @relation("EmployeeOnboardingRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance  WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  resultingEmployee Employee?         @relation("EmployeeOnboardingResult", fields: [resultingEmployeeId], references: [id])

  @@map("employee_onboarding_request")
}

// Invariant 50(b): offboarding is governed the same way -- approval is
// what actually flips Employee.status TERMINATED and deactivates
// (SUSPENDED) the linked AppUser login, if one exists. Delegation-grant
// revocation on deactivation is invariant 51(a-iv)'s own, broader primitive
// (applies to ANY user deactivation, not just offboarding) -- built next,
// not duplicated here.
model EmployeeOffboardingRequest {
  id                 String                         @id @default(uuid()) @db.Uuid
  employeeId         String                         @map("employee_id") @db.Uuid
  reason             String
  status             EmployeeLifecycleRequestStatus @default(PENDING)
  requestedByUserId  String                         @map("requested_by_user_id") @db.Uuid
  workflowInstanceId String?                        @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes     String?                        @map("rejection_notes")
  completedAt        DateTime?                      @map("completed_at")
  createdAt          DateTime                       @default(now()) @map("created_at")

  employee         Employee          @relation(fields: [employeeId], references: [id])
  requestedBy      AppUser           @relation("EmployeeOffboardingRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("employee_offboarding_request")
}

// Addendum (CEO, 8-Jul-2026): the amendment side of performanceIncentivePct
// -- HR-proposed, approval-gated, and "never retroactive on a computed
// cycle." Enforced at APPROVAL time (EmployeeLifecycleService.
// decideIncentivePctChange): refused outright if the employee has an
// EmployeeScoreSubmission in a cycle that hasn't reached INCENTIVE_COMPUTED
// yet (scoring already under way under the OLD rate's implicit
// expectation) -- HR must wait for that cycle to close and resubmit, never
// a queued "effective next cycle" auto-apply (kept simple, matches the
// invariant's own "never retroactive" wording rather than inventing an
// effective-dating mechanism nobody asked for).
model EmployeeIncentivePctChangeRequest {
  id                 String                         @id @default(uuid()) @db.Uuid
  employeeId         String                         @map("employee_id") @db.Uuid
  proposedPct        Decimal                        @map("proposed_pct") @db.Decimal(5, 2)
  status             EmployeeLifecycleRequestStatus @default(PENDING)
  requestedByUserId  String                         @map("requested_by_user_id") @db.Uuid
  workflowInstanceId String?                        @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes     String?                        @map("rejection_notes")
  appliedAt          DateTime?                      @map("applied_at")
  createdAt          DateTime                       @default(now()) @map("created_at")

  employee         Employee          @relation(fields: [employeeId], references: [id])
  requestedBy      AppUser           @relation("EmployeeIncentivePctRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("employee_incentive_pct_change_request")
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED

  @@map("marital_status")
}

// Invariant 29(a) PERSONAL RECORDS section — self-editable, PII-scoped
// (employee-self + Corporate Services HR + payroll where relevant, never
// general staff visibility). Holds the CURRENT values; hobbies/children/
// emergency-contact are direct-write (no gate named for them in the CEO
// ruling), marital status/address/next-of-kin only ever change via an
// EmployeePersonalRecordChangeRequest (HR acknowledgment workflow) — this
// table is never written to directly for those three fields outside
// PmsService/ProfileService applying an ACKNOWLEDGED request.
model EmployeePersonalRecord {
  employeeId                   String         @id @map("employee_id") @db.Uuid
  maritalStatus                MaritalStatus? @map("marital_status")
  numberOfChildren             Int?           @map("number_of_children")
  residentialAddress           String?        @map("residential_address")
  nextOfKinName                String?        @map("next_of_kin_name")
  nextOfKinRelationship        String?        @map("next_of_kin_relationship")
  nextOfKinPhone               String?        @map("next_of_kin_phone")
  nextOfKinAddress             String?        @map("next_of_kin_address")
  hobbiesInterests             String?        @map("hobbies_interests")
  emergencyContactName         String?        @map("emergency_contact_name")
  emergencyContactPhone        String?        @map("emergency_contact_phone")
  emergencyContactRelationship String?        @map("emergency_contact_relationship")
  updatedAt                    DateTime       @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_personal_record")
}

enum PersonalRecordChangeStatus {
  PENDING
  ACKNOWLEDGED
  REJECTED

  @@map("personal_record_change_status")
}

// The gated trio (marital status / address / next-of-kin) — "route through
// HR acknowledgment workflow (payroll/benefits implications)." A single
// workflow type covers all three since they share the same HR-visibility
// rationale; the requester supplies only the field(s) actually changing
// (the rest stay null and are left untouched on acknowledgment).
model EmployeePersonalRecordChangeRequest {
  id                            String                     @id @default(uuid()) @db.Uuid
  employeeId                    String                     @map("employee_id") @db.Uuid
  proposedMaritalStatus         MaritalStatus?             @map("proposed_marital_status")
  proposedResidentialAddress    String?                    @map("proposed_residential_address")
  proposedNextOfKinName         String?                    @map("proposed_next_of_kin_name")
  proposedNextOfKinRelationship String?                    @map("proposed_next_of_kin_relationship")
  proposedNextOfKinPhone        String?                    @map("proposed_next_of_kin_phone")
  proposedNextOfKinAddress      String?                    @map("proposed_next_of_kin_address")
  status                        PersonalRecordChangeStatus @default(PENDING)
  workflowInstanceId            String?                    @unique @map("workflow_instance_id")
  requestedByUserId             String                     @map("requested_by_user_id") @db.Uuid
  createdAt                     DateTime                   @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_personal_record_change_request")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
  DEFAULTED

  @@map("task_status")
}

// Invariant 17 Wave-0 skeleton, activated per invariant 25/29(a): "senior
// -> direct-report assignment via org reports_to, time tracking." The
// assignment rule (assigner must be the assignee's own reports_to, unless
// self-assigned) is enforced in TaskService, not here — this table is the
// shape. Escalation fields below (invariant 25(1), Check-6 reminder-ladder
// tranche): amberNotifiedAt is the "fires exactly once per task" dedup
// guard for the 70%-elapsed AMBER notice; defaultedAt is set the one time
// a task transitions OPEN/IN_PROGRESS -> DEFAULTED (an immutable event per
// spec — nothing in TaskService ever clears status or defaultedAt back).
model Task {
  id                 String     @id @default(uuid()) @db.Uuid
  title              String
  description        String?
  assigneeEmployeeId String     @map("assignee_employee_id") @db.Uuid
  assignedByUserId   String     @map("assigned_by_user_id") @db.Uuid
  dueAt              DateTime?  @map("due_at")
  status             TaskStatus @default(OPEN)
  startedAt          DateTime?  @map("started_at")
  completedAt        DateTime?  @map("completed_at")
  amberNotifiedAt    DateTime?  @map("amber_notified_at")
  defaultedAt        DateTime?  @map("defaulted_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  // Invariant 55(c) (CHECK12, CEO directive): "hyperlinked deliverables" --
  // a plain URL/path to whatever the task actually produces (a document, a
  // register row, an external link). Optional, settable at assignment time
  // or later by the assignee as the deliverable becomes known.
  deliverableUrl     String?    @map("deliverable_url")
  // Invariant 37(c)(ii): "MD delegates through the task-management system
  // (delegation chain preserved, roll-up status visible to CS/Board view)"
  // — nullable so ordinary tasks (the overwhelming majority) are unaffected;
  // set on the CS-issued root task AND on any further sub-task the MD (or
  // a delegate) creates against the SAME directive via the ordinary
  // assignTask() flow, so BoardDirectiveService can read the whole chain's
  // status back by querying every Task row sharing one directiveId.
  directiveId        String?    @map("directive_id") @db.Uuid
  // Invariant 64(d)(i): "a task may be tagged to a KPI/KRA from the
  // assignee's ACTIVE scorecard." Validated at assignment/tag time against
  // PmsService.getRoleScorecard(assignee) — never DB-constrained, since the
  // active scorecard is itself a computed resolution (position/tier/org-unit
  // + weight matrix + overrides), not a stored FK set. Nullable: the
  // overwhelming majority of tasks are untagged operational work.
  kpiDefinitionId    String?    @map("kpi_definition_id") @db.Uuid

  assigneeEmployee              Employee                       @relation("TaskAssignee", fields: [assigneeEmployeeId], references: [id])
  assignedBy                    AppUser                        @relation("TaskAssignedBy", fields: [assignedByUserId], references: [id])
  kpiDefinition                 KpiDefinition?                 @relation(fields: [kpiDefinitionId], references: [id])
  // Two DISTINCT relations to BoardDirective (many-tasks-per-directive via
  // this FK, plus the reverse one-directive-per-root-task via
  // BoardDirective.taskId below) — both need explicit names since Prisma
  // can't infer which is which between the same two models.
  directive                     BoardDirective?                @relation("DirectiveTasks", fields: [directiveId], references: [id])
  directiveAsRoot               BoardDirective?                @relation("BoardDirectiveRootTask")
  transmittedDocumentRecipients TransmittedDocumentRecipient[]
  acceptedFromSubmission        TaskSubmission?                @relation("TaskSubmissionAcceptedTask")

  @@index([assigneeEmployeeId, status])
  @@index([kpiDefinitionId])
  @@map("task")
}

// Invariant 64(d)(iii): "a subordinate initiates a SUBMISSION/REQUEST to
// their supervisor ... it lands in the supervisor's workspace to ACCEPT
// into their own task list; never a subordinate-ordered task on a senior."
// Deliberately a SEPARATE model from Task, not a Task with a "proposed"
// status -- TaskService.assignTask's own reports-to check would otherwise
// have to grow an exception for "junior assigning to senior," which is
// exactly the inversion this invariant forbids. A submission only BECOMES
// a Task (assigneeEmployeeId = the supervisor, self-assigned) at accept
// time, and only the supervisor's own acceptance creates it.
model TaskSubmission {
  id                    String               @id @default(uuid()) @db.Uuid
  title                 String
  description           String?
  submittedByEmployeeId String               @map("submitted_by_employee_id") @db.Uuid
  supervisorEmployeeId  String               @map("supervisor_employee_id") @db.Uuid
  deliverableUrl        String?              @map("deliverable_url")
  status                TaskSubmissionStatus @default(PENDING)
  acceptedTaskId        String?              @unique @map("accepted_task_id") @db.Uuid
  decidedAt             DateTime?            @map("decided_at")
  createdAt             DateTime             @default(now()) @map("created_at")

  submittedBy  Employee @relation("TaskSubmissionSubmitter", fields: [submittedByEmployeeId], references: [id])
  supervisor   Employee @relation("TaskSubmissionSupervisor", fields: [supervisorEmployeeId], references: [id])
  acceptedTask Task?    @relation("TaskSubmissionAcceptedTask", fields: [acceptedTaskId], references: [id])

  @@index([supervisorEmployeeId, status])
  @@map("task_submission")
}

enum TaskSubmissionStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@map("task_submission_status")
}

// ============================================================================
// Invariant 64(e) (CHECK17): Leave. Application now; relief AUTOMATION stays
// Wave 1 per invariant 53(a) -- reliefOfficerEmployeeId here is a plain
// captured reference, actioned manually via the existing Delegations page,
// never the full DelegationOfAuthority workflow (53a's own package is a
// heavier maker-checker mechanism this deliberately does not reuse yet).
// ============================================================================
model LeaveType {
  id                String   @id @default(uuid()) @db.Uuid
  code              String   @unique
  name              String
  defaultAnnualDays Decimal  @map("default_annual_days") @db.Decimal(5, 2)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  entitlements LeaveEntitlement[]
  applications LeaveApplication[]

  @@map("leave_type")
}

model LeaveEntitlement {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  leaveTypeCode String   @map("leave_type_code")
  year          Int
  entitledDays  Decimal  @map("entitled_days") @db.Decimal(5, 2)
  usedDays      Decimal  @default(0) @map("used_days") @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeCode], references: [code])

  @@unique([employeeId, leaveTypeCode, year])
  @@map("leave_entitlement")
}

model LeaveApplication {
  id                        String                 @id @default(uuid()) @db.Uuid
  employeeId                String                 @map("employee_id") @db.Uuid
  leaveTypeCode             String                 @map("leave_type_code")
  startDate                 DateTime               @map("start_date")
  endDate                   DateTime               @map("end_date")
  daysRequested             Decimal                @map("days_requested") @db.Decimal(5, 2)
  reliefOfficerEmployeeId   String?                @map("relief_officer_employee_id") @db.Uuid
  reason                    String?
  status                    LeaveApplicationStatus @default(PENDING)
  supervisorDecidedByUserId String?                @map("supervisor_decided_by_user_id") @db.Uuid
  supervisorDecidedAt       DateTime?              @map("supervisor_decided_at")
  supervisorNotes           String?                @map("supervisor_notes")
  hrAcknowledgedByUserId    String?                @map("hr_acknowledged_by_user_id") @db.Uuid
  hrAcknowledgedAt          DateTime?              @map("hr_acknowledged_at")
  createdAt                 DateTime               @default(now()) @map("created_at")

  employee      Employee  @relation("LeaveApplicant", fields: [employeeId], references: [id])
  leaveType     LeaveType @relation(fields: [leaveTypeCode], references: [code])
  reliefOfficer Employee? @relation("LeaveReliefOfficer", fields: [reliefOfficerEmployeeId], references: [id])

  @@index([employeeId, status])
  @@map("leave_application")
}

enum LeaveApplicationStatus {
  PENDING
  SUPERVISOR_APPROVED
  HR_ACKNOWLEDGED
  REJECTED
  CANCELLED

  @@map("leave_application_status")
}

// ============================================================================
// Invariant 40/63(b)/64(c) (CHECK17): AttendanceGateway -- vendor-neutral
// attendance -> PMS behavioural gate. Three brand-agnostic provider slots
// (mirrors PaymentGatewayProvider/BureauProvider's own 1-3 slot pattern);
// adapters are plug-in per brand (TTLockAdapter first) or the universal
// FileImportAdapter. Credentials carry the SAME masked-write-only + MD-
// approved maker!=checker shape as PaymentGatewayProvider (invariant 63a:
// "ICT keys the connection; the business still owns the risk; the MD still
// owns the switch") since this, like Payment Gateway, carries a real OAuth2
// client_id/secret -- unlike Bureau/AI's simpler single-actor shapes.
// ============================================================================
model AttendanceProvider {
  id                 String                @id @default(uuid()) @db.Uuid
  providerSlot       Int                   @unique @map("provider_slot")
  adapterType        AttendanceAdapterType @map("adapter_type")
  name               String
  // OAuth2 client credentials for TTLOCK; unused/null for FILE_IMPORT (no
  // external credentials -- the universal any-brand path is a document
  // upload, not an API connection).
  clientId           String?               @map("client_id")
  clientSecret       String?               @map("client_secret")
  // Invariant 73(b) (CHECK27): TTLock Open Platform's real OAuth2 grant may
  // need more than clientId/clientSecret (e.g. the integrator account's
  // username/password for a password-grant flow) -- a free-form JSON bag
  // for whatever extra fields the credential FORM collects, same
  // convention as BureauProvider.apiConfig; the OAuth2 TOKEN lifecycle
  // itself (obtained by code, never typed by a human) gets its own typed
  // columns below rather than living in this bag.
  credentialConfig   Json?                 @map("credential_config")
  accessToken        String?               @map("access_token")
  refreshToken       String?               @map("refresh_token")
  tokenObtainedAt    DateTime?             @map("token_obtained_at")
  tokenExpiresAt     DateTime?             @map("token_expires_at")
  isActive           Boolean               @default(false) @map("is_active")
  configuredByUserId String?               @map("configured_by_user_id") @db.Uuid

  pendingName              String?  @map("pending_name")
  pendingClientId          String?  @map("pending_client_id")
  pendingClientSecret      String?  @map("pending_client_secret")
  pendingCredentialConfig  Json?    @map("pending_credential_config")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  events   AttendanceEvent[]
  mappings AttendanceLockUserMapping[]

  @@map("attendance_provider")
}

enum AttendanceAdapterType {
  TTLOCK
  FILE_IMPORT

  @@map("attendance_adapter_type")
}

// Invariant 40(a): "ALL downstream logic consumes ONLY this." deviceUserRef
// is the raw pre-mapping identity the provider/file supplies; employeeId
// stays null until AttendanceLockUserMapping resolves it -- an unmapped
// event queues visibly (never guessed) rather than being silently dropped
// or mis-attributed.
model AttendanceEvent {
  id                String   @id @default(uuid()) @db.Uuid
  providerId        String   @map("provider_id") @db.Uuid
  deviceUserRef     String   @map("device_user_ref")
  employeeId        String?  @map("employee_id") @db.Uuid
  locationRef       String?  @map("location_ref")
  occurredAt        DateTime @map("occurred_at")
  method            String
  rawRef            String   @map("raw_ref")
  // Invariant 40(d): "unlock event for a TERMINATED employee raises a
  // SECURITY alert, not an attendance record" -- set at ingestion time when
  // the mapped employee is TERMINATED; such events are excluded from every
  // punctuality/attendance computation, never just flagged-and-counted.
  isTerminatedAlert Boolean  @default(false) @map("is_terminated_alert")
  createdAt         DateTime @default(now()) @map("created_at")

  provider          AttendanceProvider           @relation(fields: [providerId], references: [id])
  employee          Employee?                    @relation(fields: [employeeId], references: [id])
  exceptionRequests AttendanceExceptionRequest[]

  // Idempotency: the provider's own event id (TTLock) or a CSV-row hash
  // (FileImport) -- a retried sync/re-upload never double-books an event.
  @@unique([providerId, rawRef])
  @@index([employeeId, occurredAt])
  @@index([providerId, deviceUserRef, employeeId])
  @@map("attendance_event")
}

// Invariant 40(a): "LOCK-USER<->EMPLOYEE MAPPING TABLE + UI -- the identity
// bridge." Creating/updating a mapping retroactively resolves any already-
// ingested unmapped events for the same (providerId, deviceUserRef) pair --
// see AttendanceService.mapLockUser.
model AttendanceLockUserMapping {
  id             String   @id @default(uuid()) @db.Uuid
  providerId     String   @map("provider_id") @db.Uuid
  deviceUserRef  String   @map("device_user_ref")
  employeeId     String   @map("employee_id") @db.Uuid
  mappedByUserId String   @map("mapped_by_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  provider AttendanceProvider @relation(fields: [providerId], references: [id])
  employee Employee           @relation(fields: [employeeId], references: [id])

  @@unique([providerId, deviceUserRef])
  @@map("attendance_lock_user_mapping")
}

// Invariant 40(b): "clock-in derivation (first qualifying event, grace
// windows, expected hours per org/cadre)" -- governed config, never code.
// orgUnitCode/cadre both null = platform default row.
model AttendanceClockInPolicy {
  id                  String             @id @default(uuid()) @db.Uuid
  orgUnitCode         String?            @map("org_unit_code")
  cadre               String?
  expectedStartTime   String             @map("expected_start_time")
  graceWindowMinutes  Int                @map("grace_window_minutes")
  expectedHoursPerDay Decimal            @map("expected_hours_per_day") @db.Decimal(4, 2)
  status              GovernedItemStatus @default(ACTIVE)
  createdAt           DateTime           @default(now()) @map("created_at")

  @@unique([orgUnitCode, cadre])
  @@map("attendance_clock_in_policy")
}

// Invariant 40(b): "staff EXCEPTION-REQUEST flow (dispute a mark ... ->
// supervisor adjudicates -> audit-trailed) -- no pay consequence ever from
// raw sensor data without the exception window closing." attendanceEventId
// nullable: disputing an absence (no event at all) is equally valid.
model AttendanceExceptionRequest {
  id                String                 @id @default(uuid()) @db.Uuid
  employeeId        String                 @map("employee_id") @db.Uuid
  attendanceEventId String?                @map("attendance_event_id") @db.Uuid
  disputedDate      DateTime               @map("disputed_date")
  reason            String
  status            ExceptionRequestStatus @default(PENDING)
  decidedByUserId   String?                @map("decided_by_user_id") @db.Uuid
  decidedAt         DateTime?              @map("decided_at")
  decisionNotes     String?                @map("decision_notes")
  createdAt         DateTime               @default(now()) @map("created_at")

  employee Employee         @relation(fields: [employeeId], references: [id])
  event    AttendanceEvent? @relation(fields: [attendanceEventId], references: [id])

  @@map("attendance_exception_request")
}

enum ExceptionRequestStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("exception_request_status")
}

// Invariant 40(c): "warning ladder = config thresholds (N lates/period ->
// officer notification -> HR warning task ... -> gate impact per HR policy
// at cycle end)." Same shape as TaskDefaultGatePolicy -- a lateness count
// crossing a configured threshold maps to a PmsGateSeverityConfig severity,
// fed into BehaviouralGateCheck via the identical tighten-only pattern
// PmsService.applyTaskDefaultGate already established.
model AttendanceLatenessGatePolicy {
  id              String   @id @default(uuid()) @db.Uuid
  minLateCount    Int      @map("min_late_count")
  severityCode    String   @map("severity_code")
  isActive        Boolean  @default(true) @map("is_active")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  severityConfig PmsGateSeverityConfig @relation(fields: [severityCode], references: [severity])

  @@unique([minLateCount])
  @@map("attendance_lateness_gate_policy")
}

enum BoardDirectiveStatus {
  ISSUED
  ACKNOWLEDGED
  IN_PROGRESS
  COMPLETED
  REPORTED_BACK

  @@map("board_directive_status")
}

// Invariant 37(c)(ii): "Company Secretary inserts Board/Committee
// directives (tagged Full-Board or per-Committee) -> each directive
// auto-creates a TASK to the MD with the Board's timeline -> MD delegates
// through the task-management system... directive lifecycle (ISSUED->
// ACKNOWLEDGED->IN-PROGRESS->COMPLETED->REPORTED-BACK) audit-trailed;
// links to the resolution register (the same refs AMD-gates consume);
// status feeds SAU tracking (their KRA-3) + CEO dashboard exceptions."
// committeeTag is deliberately a free String, not an enum — no Committee
// registry exists anywhere in this codebase yet (confirmed before this
// build), and inventing one is out of scope for a directive-tracking
// tranche; null means Full-Board, a committee name is config content, not
// code (invariant 10/19). resolutionRef is the SAME free-text convention
// every boardResolutionRef/ssbResolutionRef field already uses elsewhere
// in this schema (there is no backing Resolution TABLE anywhere — those
// fields are all String, matched by ref string, e.g. SsbResolution's own
// resolutionRef) — "links to the resolution register" means this same
// ref-string convention, not a new FK.
model BoardDirective {
  id                   String               @id @default(uuid()) @db.Uuid
  title                String
  description          String
  committeeTag         String?              @map("committee_tag")
  resolutionRef        String?              @map("resolution_ref")
  dueAt                DateTime             @map("due_at")
  issuedByUserId       String               @map("issued_by_user_id") @db.Uuid
  taskId               String?              @unique @map("task_id") @db.Uuid
  status               BoardDirectiveStatus @default(ISSUED)
  acknowledgedAt       DateTime?            @map("acknowledged_at")
  acknowledgedByUserId String?              @map("acknowledged_by_user_id") @db.Uuid
  reportedBackAt       DateTime?            @map("reported_back_at")
  reportedBackByUserId String?              @map("reported_back_by_user_id") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at")

  issuedBy       AppUser  @relation("BoardDirectiveIssuedBy", fields: [issuedByUserId], references: [id])
  acknowledgedBy AppUser? @relation("BoardDirectiveAcknowledgedBy", fields: [acknowledgedByUserId], references: [id])
  reportedBackBy AppUser? @relation("BoardDirectiveReportedBackBy", fields: [reportedBackByUserId], references: [id])
  rootTask       Task?    @relation("BoardDirectiveRootTask", fields: [taskId], references: [id])
  tasks          Task[]   @relation("DirectiveTasks")

  @@map("board_directive")
}

// Invariant 37(c)(iii): "Board Calendar (meetings, committee cycles) w/
// reminder notifications." committeeTag mirrors BoardDirective's own
// free-text convention (null = Full-Board) — same reasoning: no Committee
// registry exists anywhere in this schema. remindedAt is the "fires
// exactly once per event" dedup guard, same pattern as Task's own
// amberNotifiedAt.
model BoardCalendarEvent {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  committeeTag    String?   @map("committee_tag")
  startsAt        DateTime  @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  remindedAt      DateTime? @map("reminded_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  createdBy   AppUser                   @relation("BoardCalendarEventCreatedBy", fields: [createdByUserId], references: [id])
  submissions BoardCalendarSubmission[]

  @@map("board_calendar_event")
}

// Invariant 10: "no hardcoded thresholds" — the reminder lead time is a
// governed config value (CS-editable), same shape as TaskEscalationConfig.
model BoardCalendarReminderConfig {
  id              Int      @id @default(1)
  daysBefore      Int      @default(3) @map("days_before")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("board_calendar_reminder_config")
}

// Invariant 55(b) (CHECK12, CEO directive 8-Jul-2026): "REPORT/PRESENTATION
// SUBMISSION workflow (CEO/MD submits packs against calendar items; CS
// tracks receipt/completeness)." Deliberately its own row, not a field on
// BoardCalendarEvent -- an event can receive more than one submission
// (a pack gets revised/resubmitted before the meeting), and CS's
// receipt/completeness marking is a distinct actor+timestamp from the
// submission itself, same "who did what, when, separately" doctrine as
// every other transmission/acknowledgment pair in this schema.
model BoardCalendarSubmission {
  id                String                        @id @default(uuid()) @db.Uuid
  calendarEventId   String                        @map("calendar_event_id") @db.Uuid
  title             String
  fileReference     String                        @map("file_reference")
  submittedByUserId String                        @map("submitted_by_user_id") @db.Uuid
  submittedAt       DateTime                      @default(now()) @map("submitted_at")
  status            BoardCalendarSubmissionStatus @default(SUBMITTED)
  receivedByUserId  String?                       @map("received_by_user_id") @db.Uuid
  receivedAt        DateTime?                     @map("received_at")
  completenessNote  String?                       @map("completeness_note")

  calendarEvent BoardCalendarEvent @relation(fields: [calendarEventId], references: [id])
  submittedBy   AppUser            @relation("BoardCalendarSubmissionSubmittedBy", fields: [submittedByUserId], references: [id])
  receivedBy    AppUser?           @relation("BoardCalendarSubmissionReceivedBy", fields: [receivedByUserId], references: [id])

  @@index([calendarEventId])
  @@map("board_calendar_submission")
}

enum BoardCalendarSubmissionStatus {
  SUBMITTED
  RECEIVED
  INCOMPLETE

  @@map("board_calendar_submission_status")
}

// Invariant 55(b): "MD DOCUMENT TRANSMISSION -- MD uploads/transmits
// documents into the platform routed to named officers with acknowledgment
// tracking (document register + notification + task)." Same two-table
// widen-and-acknowledge shape as BoardMinutes/BoardMinutesTransmission
// (invariant 37c-v) but generic -- not Board-Minutes-specific -- and with
// the additional "+ task" requirement this invariant names explicitly:
// each recipient gets both a transmission row AND a real Task (via
// TaskService.systemAssignTask, same "system triggers a task for a named
// person" pattern BoardDirectiveService already uses), so the deliverable
// shows up in that officer's ordinary task list, not just a notification.
model TransmittedDocument {
  id                  String   @id @default(uuid()) @db.Uuid
  title               String
  fileReference       String   @map("file_reference")
  docType             String?  @map("doc_type")
  transmittedByUserId String   @map("transmitted_by_user_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  transmittedBy AppUser                        @relation("TransmittedDocumentTransmittedBy", fields: [transmittedByUserId], references: [id])
  recipients    TransmittedDocumentRecipient[]

  @@map("transmitted_document")
}

model TransmittedDocumentRecipient {
  id              String    @id @default(uuid()) @db.Uuid
  documentId      String    @map("document_id") @db.Uuid
  recipientUserId String    @map("recipient_user_id") @db.Uuid
  taskId          String?   @map("task_id") @db.Uuid
  acknowledgedAt  DateTime? @map("acknowledged_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  document  TransmittedDocument @relation(fields: [documentId], references: [id])
  recipient AppUser             @relation("TransmittedDocumentRecipientUser", fields: [recipientUserId], references: [id])
  task      Task?               @relation(fields: [taskId], references: [id])

  @@unique([documentId, recipientUserId])
  @@map("transmitted_document_recipient")
}

// Invariant 37(c)(v): "Board Minutes: CS uploads/delivers through the
// platform -> onward transmission with an acknowledgment/access TRAIL;
// Board-class documents carry a restricted ACL tier (Board/CS/MD only
// unless widened)." A dedicated Section-F model, NOT the generic
// DocumentRegisterEntry — that polymorphic table has no ACL or
// acknowledgment concept at all today, and retrofitting one onto EVERY
// document type it serves is a platform-wide change invariant 37(h)
// gestures at as a future posture, not something this one Board Minutes
// item asks for. fileReference mirrors DocumentRegisterEntry's own
// convention (a reference string, not a binary blob).
model BoardMinutes {
  id               String   @id @default(uuid()) @db.Uuid
  title            String
  fileReference    String   @map("file_reference")
  committeeTag     String?  @map("committee_tag")
  uploadedByUserId String   @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  uploadedBy    AppUser                    @relation("BoardMinutesUploadedBy", fields: [uploadedByUserId], references: [id])
  transmissions BoardMinutesTransmission[]

  @@map("board_minutes")
}

// The restricted ACL tier's "unless widened" clause and the acknowledgment/
// access trail are the SAME table: CS transmitting minutes to a specific
// recipient IS the widening act (that recipient can now view this one
// record, per invariant 37(c)(v)), and the row itself, once
// acknowledgedAt is set, IS the acknowledgment trail entry — no separate
// widen-grant table needed.
model BoardMinutesTransmission {
  id                  String    @id @default(uuid()) @db.Uuid
  minutesId           String    @map("minutes_id") @db.Uuid
  recipientUserId     String    @map("recipient_user_id") @db.Uuid
  transmittedByUserId String    @map("transmitted_by_user_id") @db.Uuid
  transmittedAt       DateTime  @default(now()) @map("transmitted_at")
  acknowledgedAt      DateTime? @map("acknowledged_at")

  minutes       BoardMinutes @relation(fields: [minutesId], references: [id])
  recipient     AppUser      @relation("BoardMinutesTransmissionRecipient", fields: [recipientUserId], references: [id])
  transmittedBy AppUser      @relation("BoardMinutesTransmissionBy", fields: [transmittedByUserId], references: [id])

  @@unique([minutesId, recipientUserId])
  @@map("board_minutes_transmission")
}

// Invariant 25(1): "thresholds = governed config" — the 70%-elapsed AMBER
// trigger is a config value, never a hardcoded 0.7 in TaskService.
model TaskEscalationConfig {
  id                Int      @id @default(1)
  amberThresholdPct Int      @default(70) @map("amber_threshold_pct")
  updatedByUserId   String?  @map("updated_by_user_id") @db.Uuid
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("task_escalation_config")
}

// Invariant 55(c2) (CEO directive, 8-Jul-2026): per-staff calendar --
// auto-plotted entries (task deadlines, Board Calendar items, PMS cycle
// dates, filing-calendar deadlines) are synced in from their OWNING module
// by a scheduled sweep (CalendarService.runSyncSweep, keyed on
// [ownerUserId, sourceType, sourceId] so a repeat sync upserts rather than
// duplicates) and are READ-ONLY here -- the owning module stays the source
// of truth, per 55(c2)(i)'s "no deleting a task deadline from the
// calendar." PERSONAL and MEETING are the only kinds a user creates/edits/
// deletes directly through this table. PERSONAL entries are never visible
// to anyone but ownerUserId (55(c2)(ii): "visible to the owner ONLY -- not
// supervisors, not admins") -- enforced in CalendarService by kind, not by
// a separate isPrivate flag, so there is no privacy state that can drift
// out of sync with what created the row.
model CalendarEntry {
  id                  String            @id @default(uuid()) @db.Uuid
  ownerUserId         String            @map("owner_user_id") @db.Uuid
  kind                CalendarEntryKind
  title               String
  description         String?
  startsAt            DateTime          @map("starts_at")
  endsAt              DateTime?         @map("ends_at")
  isAutoPlotted       Boolean           @default(false) @map("is_auto_plotted")
  // Set only for auto-plotted kinds -- identifies the owning module's row
  // this entry restates from (e.g. sourceType='Task', sourceId=Task.id).
  // NULL for PERSONAL/MEETING, which have no upstream source.
  sourceType          String?           @map("source_type")
  sourceId            String?           @map("source_id")
  // Set only for MEETING (who created/organizes it); NULL for every other
  // kind, where ownerUserId already IS the organizer/owner.
  organizerUserId     String?           @map("organizer_user_id") @db.Uuid
  // NULL = use CalendarReminderConfig.defaultLeadMinutes (55(c2)(iii):
  // "per-entry reminder lead times (config defaults, per-entry override)").
  reminderLeadMinutes Int?              @map("reminder_lead_minutes")
  remindedAt          DateTime?         @map("reminded_at")
  createdAt           DateTime          @default(now()) @map("created_at")

  owner     AppUser                   @relation("CalendarEntryOwner", fields: [ownerUserId], references: [id])
  organizer AppUser?                  @relation("CalendarEntryOrganizer", fields: [organizerUserId], references: [id])
  attendees CalendarMeetingAttendee[]

  // Guards the upsert-on-resync semantics above; Postgres' NULL-distinct
  // unique-index semantics mean NULL/NULL sourceType/sourceId pairs (every
  // PERSONAL/MEETING row) never collide, so this only ever constrains
  // auto-plotted rows.
  @@unique([ownerUserId, sourceType, sourceId])
  @@index([ownerUserId, startsAt])
  @@map("calendar_entry")
}

enum CalendarEntryKind {
  TASK_DEADLINE
  BOARD_EVENT
  PMS_CYCLE
  FILING_DEADLINE
  PERSONAL
  MEETING
  // Invariant 64(e): approved leave auto-plots as busy for its window.
  LEAVE

  @@map("calendar_entry_kind")
}

// 55(c2)(ii): "meetings carry internal attendees (invite -> accept/decline
// -> plots on each attendee's calendar)." One CalendarEntry (kind=MEETING,
// ownerUserId=organizer) is the single source of truth; an attendee's own
// "my calendar" view is a UNION of entries they own and MEETING entries
// they hold an attendee row on (CalendarService.getMyCalendar) -- never a
// denormalized per-attendee copy of the entry itself.
model CalendarMeetingAttendee {
  id              String                 @id @default(uuid()) @db.Uuid
  calendarEntryId String                 @map("calendar_entry_id") @db.Uuid
  attendeeUserId  String                 @map("attendee_user_id") @db.Uuid
  status          CalendarAttendeeStatus @default(PENDING)
  respondedAt     DateTime?              @map("responded_at")
  createdAt       DateTime               @default(now()) @map("created_at")

  calendarEntry CalendarEntry @relation(fields: [calendarEntryId], references: [id])
  attendee      AppUser       @relation(fields: [attendeeUserId], references: [id])

  @@unique([calendarEntryId, attendeeUserId])
  @@map("calendar_meeting_attendee")
}

enum CalendarAttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@map("calendar_attendee_status")
}

// 55(c2)(iv) Phase A: "per-user ICS subscription feed -- a tokenized read-
// only calendar URL... token revocable per user." Same bare-token-in-URL
// convention as MarketingSubscriber.unsubscribeToken (crypto.randomBytes
// hex, plain equality lookup, no hashing) -- this is a read-only feed of a
// user's OWN calendar, not a credential granting any write access, so that
// established precedent's threat model still applies. Revoking DELETES the
// row outright (CalendarService.revokeFeedToken) rather than setting a
// revokedAt flag, so a re-subscribed feed always gets a genuinely fresh
// token, never the one that leaked.
model CalendarFeedToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  user AppUser @relation(fields: [userId], references: [id])

  @@map("calendar_feed_token")
}

// Invariant 73(b) (CHECK27), 55(c2)(iv) Phase B: CalendarGateway, the 5th
// gateway on the standing adapter pattern (Payment/Bureau/AI/Attendance
// precede it) -- the PLATFORM-WIDE app registration (Microsoft Graph/Google
// OAuth client) a tenant's Technology Officer configures once, same
// propose/approve + write-only-masked-secret shape as PaymentGatewayProvider
// and AttendanceProvider. This is NOT a per-user credential -- individual
// staff members separately grant per-user consent (ExternalCalendarConnection
// below) against whichever provider row here is active.
model CalendarGatewayProvider {
  id                 String              @id @default(uuid()) @db.Uuid
  providerSlot       Int                 @unique @map("provider_slot")
  adapterType        CalendarAdapterType @map("adapter_type")
  name               String
  clientId           String?             @map("client_id")
  clientSecret       String?             @map("client_secret")
  // Microsoft Graph only (tenant-specific app registration); null for Google.
  tenantId           String?             @map("tenant_id")
  isActive           Boolean             @default(false) @map("is_active")
  configuredByUserId String?             @map("configured_by_user_id") @db.Uuid

  pendingName              String?  @map("pending_name")
  pendingClientId          String?  @map("pending_client_id")
  pendingClientSecret      String?  @map("pending_client_secret")
  pendingTenantId          String?  @map("pending_tenant_id")
  pendingIsActive          Boolean? @map("pending_is_active")
  pendingProposedByUserId  String?  @map("pending_proposed_by_user_id") @db.Uuid
  configWorkflowInstanceId String?  @unique @map("config_workflow_instance_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  connections ExternalCalendarConnection[]

  @@map("calendar_gateway_provider")
}

enum CalendarAdapterType {
  MICROSOFT_GRAPH
  GOOGLE

  @@map("calendar_adapter_type")
}

// Per-user OAuth2 CONSENT grant against an active CalendarGatewayProvider --
// deliberately separate from the platform-wide provider row above (Layer
// distinction: the tenant configures the APP once; each staff member
// individually consents/revokes their OWN calendar access). Tokens stored
// encrypted at the application layer (never plaintext -- same posture as
// AttendanceProvider.clientSecret's write-only-masked handling); revoking
// sets revokedAt rather than deleting, preserving the consent/revocation
// audit trail (mirrors CalendarFeedToken's own delete-on-revoke EXCEPT this
// is a two-way OAuth grant to an external vendor, not a bare read-only
// feed token, so an auditable revocation record matters more here).
model ExternalCalendarConnection {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  providerId            String    @map("provider_id") @db.Uuid
  accessTokenEncrypted  String    @map("access_token_encrypted")
  refreshTokenEncrypted String?   @map("refresh_token_encrypted")
  scope                 String
  expiresAt             DateTime? @map("expires_at")
  connectedAt           DateTime  @default(now()) @map("connected_at")
  revokedAt             DateTime? @map("revoked_at")
  lastSyncedAt          DateTime? @map("last_synced_at")

  user     AppUser                 @relation(fields: [userId], references: [id])
  provider CalendarGatewayProvider @relation(fields: [providerId], references: [id])

  @@unique([userId, providerId])
  @@map("external_calendar_connection")
}

// Governed singleton, same shape/precedent as TaskEscalationConfig just
// above and BoardCalendarReminderConfig -- exists with a sensible default
// now; a dedicated settings write-path is future work if wanted, same as
// TaskEscalationConfig shipped with no write-path in this same tranche.
model CalendarReminderConfig {
  id                 Int      @id @default(1)
  defaultLeadMinutes Int      @default(30) @map("default_lead_minutes")
  updatedByUserId    String?  @map("updated_by_user_id") @db.Uuid
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("calendar_reminder_config")
}

// Invariant 25(1): "the POLICY (how much a default draws from incentive)
// is HR config on the existing gate machinery, never code." Rows are
// ordered by minDefaultCount ascending; the sweep picks the HIGHEST
// threshold an employee's in-cycle DEFAULTED-task count meets or exceeds,
// then feeds severityCode into the EXISTING PmsGateSeverityConfig lookup
// (invariant 18/Check-5 item 4) — this table only maps "how many defaults"
// to "which severity," it never invents a new outcome/cappedPct itself.
model TaskDefaultGatePolicy {
  id              String   @id @default(uuid()) @db.Uuid
  minDefaultCount Int      @map("min_default_count")
  severityCode    String   @map("severity_code")
  isActive        Boolean  @default(true) @map("is_active")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  severityConfig PmsGateSeverityConfig @relation(fields: [severityCode], references: [severity])

  @@unique([minDefaultCount])
  @@map("task_default_gate_policy")
}

enum NotificationType {
  TASK_ASSIGNED
  PERSONAL_RECORD_CHANGE_DECIDED
  GENERIC
  // RES-001 F-02 (CHECK23, v1.0.2): scheduler-job failure alert, routed
  // through the notification engine to every SCHEDULER_OPERATIONS/
  // SCHEDULER_OVERSIGHT VIEW-holder — closes the "no notification engine
  // exists yet" gap SchedulerService.executeJob's own comment named at
  // Check-5B (the audit_trail row it wrote was never actively pushed to
  // anyone; a human had to know to go look).
  SCHEDULER_JOB_FAILED

  @@map("notification_type")
}

// The "notifications inbox" invariant 29(a) names alongside "my tasks +
// daily schedule" — a plain in-app inbox (persisted rows), distinct from
// the future email/SMTP notification engine referenced elsewhere (inv 24/
// 25/28b) which does not exist yet; this is the queryable inbox the
// profile-hub screen renders today, not a delivery channel.
//
// CHECK16 62(b): widened to a SECOND recipient shape — a portal investor,
// who is a PortalClientUser, not an AppUser, so it cannot reuse
// recipientUserId's FK. Exactly one of recipientUserId/recipientInvestorId
// is set per row (DB-enforced via a CHECK constraint in the migration,
// same "exactly one of two nullable FKs" discipline
// DistributionLineItem.productAccountId/ndMandateAccountId already
// documents) — never both, never neither.
model Notification {
  id                  String           @id @default(uuid()) @db.Uuid
  recipientUserId     String?          @map("recipient_user_id") @db.Uuid
  recipientInvestorId String?          @map("recipient_investor_id")
  type                NotificationType @default(GENERIC)
  title               String
  body                String
  linkPath            String?          @map("link_path")
  isRead              Boolean          @default(false) @map("is_read")
  createdAt           DateTime         @default(now()) @map("created_at")

  recipient         AppUser?  @relation(fields: [recipientUserId], references: [id])
  recipientInvestor Investor? @relation(fields: [recipientInvestorId], references: [investorId])

  @@index([recipientUserId, isRead])
  @@index([recipientInvestorId, isRead])
  @@map("notification")
}

// SDS §2: "emolument_structure (versioned, effective-dated, approval-gated):
// cadre x notch x component -> annual amount in KOBO." Same insert-only
// versioning discipline as ProductParameters/KpiWeightMatrix.
model EmolumentStructure {
  id                 String                 @id @default(uuid()) @db.Uuid
  cadre              String
  notch              Int
  component          String
  annualAmountKobo   BigInt                 @map("annual_amount_kobo")
  componentType      EmolumentComponentType @map("component_type")
  taxable            Boolean                @default(true)
  version            Int                    @default(1)
  status             GovernedItemStatus     @default(DRAFT)
  effectiveFrom      DateTime               @map("effective_from")
  createdByUserId    String?                @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?                @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?                @map("workflow_instance_id") @db.Uuid
  migrationSourceRef String?                @map("migration_source_ref")
  createdAt          DateTime               @default(now()) @map("created_at")

  @@unique([cadre, notch, component, version])
  @@map("emolument_structure")
}

enum EmolumentComponentType {
  SALARY
  ALLOWANCE
  COST_REFUND

  @@map("emolument_component_type")
}

// Build Plan step 8 / SOW D8-D9: ledger skeletons, "to unblock Phase 2."
// Deliberately a skeleton, not the full ledger machinery — Phase 2 owns
// posting rules (balanced-journal validation, approval-before-posting,
// period close). What IS built now, because CLAUDE.md invariant #5 calls
// it structural, not procedural: "no journal can span ledger entities" —
// enforced by a hand-authored DB trigger (see the follow-up migration),
// the same "not just an app-layer check" standard as every other
// non-negotiable invariant in this codebase. Core Schema Skeleton §3.5:
// "gl_journal / gl_journal_line: ... a CHECK/constraint forbids lines
// referencing accounts of another entity."
model LedgerEntity {
  code         String             @id
  name         String
  entityType   LedgerEntityType   @map("entity_type")
  productCode  String?            @map("product_code")
  status       LedgerEntityStatus @default(ACTIVE)
  // AMD-11.2: "Primary basis per ledger entity: COMPANY = IFRS primary (FRC
  // statutory). FUND/POOL = AAOIFI primary ... Basis is a ledger-entity
  // attribute, not global." Enforced by a hand-authored CHECK constraint
  // (see the AMD-11 migration) for COMPANY/FUND/POOL specifically — the spec
  // is silent on MANDATE/CLIENT_MONEY, so those two are left to the caller
  // with no default (see LedgerService.createLedgerEntity; flagged in the
  // AMD-11 reconciliation report as a judgment call, not a guess baked into
  // a default).
  primaryBasis AccountingBasis    @map("primary_basis")
  createdAt    DateTime           @default(now()) @map("created_at")

  product                     Product?                     @relation(fields: [productCode], references: [code])
  chartOfAccounts             ChartOfAccount[]
  pettyCashFloats             PettyCashFloat[]
  journalEntries              JournalEntry[]
  transactions                Txn[]
  cashbookEntries             CashbookEntry[]
  reportRuns                  ReportRun[]
  accountingPeriods           AccountingPeriod[]
  portfolioPositions          PortfolioPosition[]
  feeAccruals                 FeeAccrual[]
  navRecords                  NavRecord[]
  poolIncomeRecords           PoolIncomeRecord[]
  distributions               Distribution[]
  hibahRecords                HibahRecord[]
  budgetLines                 BudgetLine[]
  ndMandateAccounts           NdMandateAccount[]
  halalFundLaunchConfigs      HalalFundLaunchConfig[]
  purchaseOrders              PurchaseOrder[]
  paymentBatches              PaymentBatch[]
  bankStatementLines          BankStatementLine[]
  assetRegisterEntries        AssetRegisterEntry[]
  reconciliationConfigs       LedgerReconciliationConfig[]
  portfolioMarketValueEntries PortfolioMarketValueEntry[]

  @@map("ledger_entity")
}

// AMD-11: the two lenses the platform must produce compliant output under,
// simultaneously, from the same journals (never double-posted per
// framework) — see CLAUDE.md invariant #15 and
// ../../One17_Reporting_Standards_Spec_v1.md.
enum AccountingBasis {
  IFRS
  AAOIFI

  @@map("accounting_basis")
}

enum LedgerEntityType {
  COMPANY
  FUND
  POOL
  MANDATE
  CLIENT_MONEY

  @@map("ledger_entity_type")
}

enum LedgerEntityStatus {
  ACTIVE
  CLOSED

  @@map("ledger_entity_status")
}

// "Template CoA instantiated per ledger entity (company template ≠ fund
// template)" — LedgerService.loadChartOfAccountsTemplate() bulk-inserts a
// product-type's default account set; nothing here prevents a different
// template per entity type, since the rows are just data.
model ChartOfAccount {
  id               String      @id @default(uuid()) @db.Uuid
  ledgerEntityCode String      @map("ledger_entity_code")
  accountCode      String      @map("account_code")
  accountName      String      @map("account_name")
  accountType      AccountType @map("account_type")
  // AMD-11.1: "every chart_of_accounts row carries aaoifi_ref (FAS
  // classification) AND ifrs_ref (statement line / standard reference) ...
  // Journals post ONCE to the shared CoA; framework presentation is derived
  // through mapping, never by double-posting the same event." NOT NULL,
  // not optional — a CoA row created without both is the exact defect this
  // amendment exists to prevent. Free text, not an enum/lookup: the actual
  // FAS/IFRS classification catalogue is FINCON's mapping policy input
  // (Reporting Spec §5), not a fixed platform list.
  aaoifiRef        String      @map("aaoifi_ref")
  ifrsRef          String      @map("ifrs_ref")
  isActive         Boolean     @default(true) @map("is_active")

  ledgerEntity   LedgerEntity            @relation(fields: [ledgerEntityCode], references: [code])
  journalLines   JournalEntryLine[]
  lineMappings   StatementLineMapping[]
  regulatorLines RegulatorTemplateLine[]

  @@unique([ledgerEntityCode, accountCode])
  @@map("chart_of_account")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE

  @@map("account_type")
}

// status is DRAFT-only in practice for now — there is no postJournalEntry
// business method (deliberately: that's a posting RULE — balance
// validation, approval gating — which Build Plan defers to Phase 2). The
// enum and the column exist so Phase 2 has somewhere to transition to,
// not because this phase transitions them.
model JournalEntry {
  id                        String             @id @default(uuid()) @db.Uuid
  ledgerEntityCode          String             @map("ledger_entity_code")
  journalReference          String             @map("journal_reference")
  entryDate                 DateTime           @map("entry_date")
  description               String
  status                    JournalEntryStatus @default(DRAFT)
  postedAt                  DateTime?          @map("posted_at")
  // AMD-11.3: "genuine measurement divergences ... post as tagged adjustment
  // journals (basis_adjustment layer, standard multi-GAAP pattern). Trial
  // balance and statements are producible PER BASIS: base + relevant
  // adjustments." A BASIS_ADJUSTMENT journal is a perfectly ordinary journal
  // (same table, same posting path) carrying two extra tags: which basis it
  // reconciles TO (adjustmentForBasis) and which divergence it represents
  // (divergenceType — free text, e.g. "IFRS9_ECL_VS_FAS30", not an enum: the
  // spec's list — ECL/FAS30, IFRS16/FAS32, UIAH — is illustrative, not
  // closed). CHECK constraint (see AMD-11 migration) ties both fields'
  // nullability to journalClass so a BASE journal can never carry them and a
  // BASIS_ADJUSTMENT journal can never omit them.
  journalClass              JournalClass       @default(BASE) @map("journal_class")
  divergenceType            String?            @map("divergence_type")
  adjustmentForBasis        AccountingBasis?   @map("adjustment_for_basis")
  // Phase 2: "no journal spans ledger entities. Fees flowing from a fund to
  // the company are two mirrored journals ... linked by a common
  // inter_entity_ref" (Company Accounting Design §1/§3; Core Schema
  // Skeleton §2). Nullable — only mirrored-pair journals carry it.
  // Deliberately a free string, not a FK to anything: the two legs are
  // independent JournalEntry rows in two different ledger entities, and
  // linking them via a shared value (not a relation) is the whole point —
  // a real FK across entities would violate invariant #5.
  interEntityRef            String?            @map("inter_entity_ref")
  // Phase 2: journal posting now goes through maker-drafts/checker-approves
  // (WorkflowEngineService, workflow type JOURNAL_POSTING) rather than a
  // single-actor DRAFT->POSTED call — see LedgerService.requestJournalPosting/
  // approveJournalPosting. Unique + nullable: only set once a posting has
  // been requested; a DRAFT never submitted for posting has none.
  postingWorkflowInstanceId String?            @unique @map("posting_workflow_instance_id") @db.Uuid
  createdByUserId           String             @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime           @default(now()) @map("created_at")

  ledgerEntity LedgerEntity       @relation(fields: [ledgerEntityCode], references: [code])
  createdBy    AppUser            @relation(fields: [createdByUserId], references: [id])
  lines        JournalEntryLine[]
  transactions Txn[]

  @@map("journal_entry")
}

enum JournalClass {
  BASE
  BASIS_ADJUSTMENT

  @@map("journal_class")
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED

  @@map("journal_entry_status")
}

// accountId references ChartOfAccount by its surrogate id rather than
// denormalizing (ledgerEntityCode, accountCode) onto every line — the
// entity-separation trigger joins through this FK to compare the
// account's ledger_entity_code against the parent journal's.
model JournalEntryLine {
  id             String  @id @default(uuid()) @db.Uuid
  journalEntryId String  @map("journal_entry_id") @db.Uuid
  accountId      String  @map("account_id") @db.Uuid
  debitKobo      BigInt  @default(0) @map("debit_kobo")
  creditKobo     BigInt  @default(0) @map("credit_kobo")
  description    String?

  journalEntry           JournalEntry       @relation(fields: [journalEntryId], references: [id])
  account                ChartOfAccount     @relation(fields: [accountId], references: [id])
  bankStatementLineMatch BankStatementLine?

  @@map("journal_entry_line")
}

// ============================================================================
// Phase 2 core: posting rules and period close (CHECK2 pass, 2026-07-04).
// ============================================================================

// Company Accounting Design §4: "Finance sign-off (checker role) locks the
// period; post-lock entries only in the next open period." One row per
// (ledger entity, date range). Close is a governed workflow (propose ->
// WorkflowEngineService -> approve), same pattern as every other version/
// state-transition in this codebase. The actual block on posting into a
// CLOSED period is a hand-authored DB TRIGGER on journal_entry (see the
// Phase 2 migration) — not service code, per instruction. Only the
// close/lock mechanism is built here; the substantive monthly checklist
// (§4 items 1-7: engine runs, bank rec, inter-entity reconciliation,
// receivables aging, accruals, purification review, TB/P&L/BS generation)
// is Phase 3+ engine-dependent and explicitly not built now — this is the
// scaffold those depend on, not the checklist itself.
model AccountingPeriod {
  id                      String                 @id @default(uuid()) @db.Uuid
  ledgerEntityCode        String                 @map("ledger_entity_code")
  periodStart             DateTime               @map("period_start") @db.Date
  periodEnd               DateTime               @map("period_end") @db.Date
  status                  AccountingPeriodStatus @default(OPEN)
  openedByUserId          String                 @map("opened_by_user_id") @db.Uuid
  closedByUserId          String?                @map("closed_by_user_id") @db.Uuid
  closedAt                DateTime?              @map("closed_at")
  closeWorkflowInstanceId String?                @unique @map("close_workflow_instance_id") @db.Uuid
  createdAt               DateTime               @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])
  openedBy     AppUser      @relation("AccountingPeriodOpenedBy", fields: [openedByUserId], references: [id])
  closedBy     AppUser?     @relation("AccountingPeriodClosedBy", fields: [closedByUserId], references: [id])

  @@unique([ledgerEntityCode, periodStart, periodEnd])
  @@map("accounting_period")
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED

  @@map("accounting_period_status")
}

// SRS §4.7.1's event -> journal map, as CONFIGURATION (Reporting Spec's
// governing doctrine applied here too: "no statement line, threshold, or
// account code in application code"). Pure reference data — sortOrder 1-12
// below matches the SRS table's own row order. Automatic journal
// GENERATION from real events (placement_status -> FUNDS_RECEIVED, etc.)
// is Phase 3 product-engine work and explicitly not wired here; this table
// only ships the map itself so Phase 3 has governed configuration to read
// from instead of hard-coding it.
model EventJournalConfig {
  id                 String   @id @default(uuid()) @db.Uuid
  sortOrder          Int      @map("sort_order")
  eventType          String   @unique @map("event_type")
  jeReferencePattern String   @map("je_reference_pattern")
  drAccountCode      String   @map("dr_account_code")
  drAccountName      String   @map("dr_account_name")
  crAccountCode      String   @map("cr_account_code")
  crAccountName      String   @map("cr_account_name")
  triggerDescription String   @map("trigger_description")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("event_journal_config")
}

// Core Schema Skeleton §4.2: "One table, discriminated by txn_type ...
// Mandatory dimensions on every row: product_account_id, ledger_entity_id,
// txn_type, value date, amount, status, maker, checker, posted journal
// ref." productAccountId was a bare string through Phase 1/2 (product_account
// didn't exist as a table yet); Phase 3's TPL_04/05 loaders introduce
// ProductAccount, so this is wired as a real FK now. unitsQty/unitPriceKobo
// carry TPL_05's fund-only columns (Migration Data Standards rule 1: "Fund
// transactions must carry units and unit_price; amount ~= units x unit_price
// (tolerance +-0.5%)"; rule 2: "Pool transactions must NOT carry units") —
// both nullable, enforced by MigrationService's per-row gates, not a DB
// CHECK (the rule depends on the txn's product type, which a bare column
// constraint can't see). migrationSourceSystem/migrationSourceDocumentRef
// are the "audit bridge from the old world to the new" the README requires
// on every TPL_05 row (rule 4).
model Txn {
  id                         String    @id @default(uuid()) @db.Uuid
  txnType                    TxnType   @map("txn_type")
  ledgerEntityCode           String    @map("ledger_entity_code")
  productAccountId           String?   @map("product_account_id") @db.Uuid
  valueDate                  DateTime  @map("value_date")
  amountKobo                 BigInt    @map("amount_kobo")
  unitsQty                   Decimal?  @map("units_qty") @db.Decimal(18, 4)
  unitPriceKobo              BigInt?   @map("unit_price_kobo")
  counterpartyId             String?   @map("counterparty_id") @db.Uuid
  status                     TxnStatus @default(PENDING)
  makerUserId                String    @map("maker_user_id") @db.Uuid
  checkerUserId              String?   @map("checker_user_id") @db.Uuid
  postedJournalEntryId       String?   @map("posted_journal_entry_id") @db.Uuid
  migrationSourceSystem      String?   @map("migration_source_system")
  migrationSourceDocumentRef String?   @map("migration_source_document_ref")
  createdAt                  DateTime  @default(now()) @map("created_at")

  ledgerEntity       LedgerEntity      @relation(fields: [ledgerEntityCode], references: [code])
  productAccount     ProductAccount?   @relation(fields: [productAccountId], references: [id])
  counterparty       Counterparty?     @relation(fields: [counterpartyId], references: [id])
  maker              AppUser           @relation("TxnMaker", fields: [makerUserId], references: [id])
  checker            AppUser?          @relation("TxnChecker", fields: [checkerUserId], references: [id])
  postedJournalEntry JournalEntry?     @relation(fields: [postedJournalEntryId], references: [id])
  paymentInflowLog   PaymentInflowLog?

  @@map("txn")
}

enum TxnType {
  SUBSCRIPTION
  REDEMPTION
  PLACEMENT
  PROFIT_ALLOCATION
  DISTRIBUTION
  ROLLOVER
  EARLY_EXIT
  MATURITY_PAYOUT
  FEE
  PURIFICATION
  ADJUSTMENT
  // Formula Library A4 (CEO refinement): FM's voluntary gift to lift
  // investors toward target in shortfall periods, or as commercial
  // smoothing in LOSS periods — funded from the Mudarib share (shortfall)
  // or COMPANY's own funds (loss periods), never from the pool, never
  // booked as pool profit. Distinct txn type per the Formula Library.
  HIBAH

  @@map("txn_type")
}

enum TxnStatus {
  PENDING
  POSTED
  REVERSED
  CANCELLED

  @@map("txn_status")
}

// Build Plan step 8's "cashbook" — no source doc details this beyond the
// name, so kept minimal: a per-ledger-entity cash movement register for
// bank statement matching, distinct from the double-entry journal (this
// is a reconciliation aid, not part of the accounting record itself).
model CashbookEntry {
  id                   String                       @id @default(uuid()) @db.Uuid
  ledgerEntityCode     String                       @map("ledger_entity_code")
  entryDate            DateTime                     @map("entry_date")
  description          String
  amountKobo           BigInt                       @map("amount_kobo")
  bankReference        String?                      @map("bank_reference")
  reconciliationStatus CashbookReconciliationStatus @default(UNRECONCILED) @map("reconciliation_status")
  reconciledAt         DateTime?                    @map("reconciled_at")
  createdAt            DateTime                     @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])

  @@map("cashbook_entry")
}

enum CashbookReconciliationStatus {
  UNRECONCILED
  RECONCILED
  DISPUTED

  @@map("cashbook_reconciliation_status")
}

// Core Schema Skeleton §3.6: "document — polymorphic: attaches to
// investor, account, transaction, approval, SSB resolution." Deliberately
// separate from InvestorKycDocument (step 6/7, already built and tested)
// — that one is investor-specific and stays; this is the general register
// for everything else this step introduces (journal support docs, bank
// statements) and whatever later modules need, without a schema change
// per new entity type.
model DocumentRegisterEntry {
  id                       String   @id @default(uuid()) @db.Uuid
  entityType               String   @map("entity_type")
  entityId                 String   @map("entity_id")
  documentType             String   @map("document_type")
  fileReference            String   @map("file_reference")
  uploadedByUserId         String?  @map("uploaded_by_user_id") @db.Uuid
  // Invariant 44(e) (CHECK10): portal-originated uploads (counterparty
  // facility-application documents) have no AppUser actor behind the
  // session -- exactly one of uploadedByUserId/uploadedByCounterpartyId is
  // set, the same "exactly one of two nullable FKs, enforced in service
  // code not a DB CHECK" shape DistributionLineItem already uses for its
  // productAccountId/ndMandateAccountId pair.
  uploadedByCounterpartyId String?  @map("uploaded_by_counterparty_id") @db.Uuid
  uploadedAt               DateTime @default(now()) @map("uploaded_at")

  uploadedBy             AppUser?      @relation(fields: [uploadedByUserId], references: [id])
  uploadedByCounterparty Counterparty? @relation(fields: [uploadedByCounterpartyId], references: [id])

  @@index([entityType, entityId])
  @@map("document_register_entry")
}

// Invariant 44(e) (CHECK10): "checklist-gated (config-defined
// required-document list per application type; incomplete = cannot submit
// for review)." One row per required document type per application type --
// CounterpartyService.reviewAndSubmitFacilityApplication checks every
// ACTIVE row for applicationType='FACILITY_APPLICATION' has a matching
// DocumentRegisterEntry.documentType before allowing DRAFT->SUBMITTED.
// Deliberately NOT full versioned-governance-workflow weight (unlike
// MetricDefinition/AccountingFrameworkMap) -- this is an admin checklist,
// not a money/Shariah/reporting parameter; ACTIVE/SUPERSEDED via
// DocumentService.retireRequiredDocument()+addRequiredDocument() is enough.
model RequiredDocumentConfig {
  id              String             @id @default(uuid()) @db.Uuid
  applicationType String             @map("application_type")
  documentType    String             @map("document_type")
  status          GovernedItemStatus @default(ACTIVE)
  createdByUserId String             @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")

  createdBy AppUser @relation(fields: [createdByUserId], references: [id])

  @@unique([applicationType, documentType])
  @@map("required_document_config")
}

// ============================================================================
// AMD-11 / One17_Reporting_Standards_Spec_v1.md §2 — dual-framework (IFRS ×
// AAOIFI) reporting skeleton. CLAUDE.md invariant #15, "BINDING ON THE
// LEDGER BUILD IN PROGRESS." Everything below ships now per the spec's
// "[BUILD NOW]" marker; CONTENT (actual mapping rows, statement line seeds,
// SEC templates) is Phase 4/post-go-live — these tables are the shape,
// deliberately empty, "wired" per Reporting Spec §2/§6.
// ============================================================================

// Versioned, effective-dated framework mapping (AMD-11.4): "a new FRC/
// harmonization pronouncement or a new SEC reporting template is
// configuration rows through an approval workflow, never a migration."
// Approval: FINCON proposes -> CEO/Board per DoA (Reporting Spec §2) — routed
// through WorkflowEngineService (workflow type ACCOUNTING_FRAMEWORK_MAP_
// APPROVAL) exactly like every other governed parameter change in this
// codebase, not a bespoke approval path. No v1 is seeded: FINCON's policy
// mapping input (Reporting Spec §5's stated CEO dependency) does not exist
// yet, and inventing one would be exactly the "invent financial logic"
// CLAUDE.md forbids — flagged in the AMD-11 reconciliation report.
model AccountingFrameworkMap {
  id                 String             @id @default(uuid()) @db.Uuid
  version            Int                @unique
  description        String
  status             FrameworkMapStatus @default(DRAFT)
  effectiveFrom      DateTime           @map("effective_from")
  effectiveTo        DateTime?          @map("effective_to")
  createdByUserId    String             @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  createdBy    AppUser                @relation("FrameworkMapCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy   AppUser?               @relation("FrameworkMapApprovedBy", fields: [approvedByUserId], references: [id])
  lineMappings StatementLineMapping[]
  reportRuns   ReportRun[]

  @@map("accounting_framework_map")
}

enum FrameworkMapStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("framework_map_status")
}

// One row per statement per framework (Reporting Spec §3): IFRS set for
// COMPANY, AAOIFI set for FUND/POOL. Ships empty — template seed content is
// explicitly Phase 4 ("statement generation, template seeds" per Reporting
// Spec §5); this phase only needs the shape to exist so StatementLineMapping
// and ReportRun have somewhere to point.
model StatementTemplate {
  id              String                  @id @default(uuid()) @db.Uuid
  basis           AccountingBasis
  statementCode   String                  @map("statement_code")
  name            String
  version         Int                     @default(1)
  status          StatementTemplateStatus @default(DRAFT)
  effectiveFrom   DateTime?               @map("effective_from")
  createdByUserId String                  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at")

  createdBy  AppUser         @relation(fields: [createdByUserId], references: [id])
  lines      StatementLine[]
  reportRuns ReportRun[]

  @@unique([basis, statementCode, version])
  @@map("statement_template")
}

enum StatementTemplateStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("statement_template_status")
}

// Ordered lines per template (Reporting Spec §2): "label, sign convention,
// roll-up parent, computation type." signConvention is deliberately a plain
// string (e.g. "DEBIT_POSITIVE"), not an enum — this row is itself
// configuration, and the spec doesn't fix the convention vocabulary.
model StatementLine {
  id                  String                       @id @default(uuid()) @db.Uuid
  statementTemplateId String                       @map("statement_template_id") @db.Uuid
  lineCode            String                       @map("line_code")
  label               String
  sortOrder           Int                          @map("sort_order")
  signConvention      String?                      @map("sign_convention")
  parentLineId        String?                      @map("parent_line_id") @db.Uuid
  computationType     StatementLineComputationType @map("computation_type")
  formulaExpression   String?                      @map("formula_expression")

  statementTemplate StatementTemplate       @relation(fields: [statementTemplateId], references: [id])
  parentLine        StatementLine?          @relation("StatementLineRollup", fields: [parentLineId], references: [id])
  childLines        StatementLine[]         @relation("StatementLineRollup")
  accountMappings   StatementLineMapping[]
  regulatorLines    RegulatorTemplateLine[]

  @@unique([statementTemplateId, lineCode])
  @@map("statement_line")
}

enum StatementLineComputationType {
  SUM_OF_ACCOUNTS
  SUM_OF_LINES
  FORMULA

  @@map("statement_line_computation_type")
}

// "CoA account -> statement line, PER framework-map version. The only place
// accounts meet statements" (Reporting Spec §2). A new framework-map version
// gets its own mapping rows — remapping an account is inserting a new row
// against the new version, never editing history, which is exactly what
// makes "remapping changes presentation without touching posted journals"
// (UAT-AMD-11) true by construction rather than by extra guard code.
model StatementLineMapping {
  id               String   @id @default(uuid()) @db.Uuid
  frameworkMapId   String   @map("framework_map_id") @db.Uuid
  chartOfAccountId String   @map("chart_of_account_id") @db.Uuid
  statementLineId  String   @map("statement_line_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  frameworkMap   AccountingFrameworkMap @relation(fields: [frameworkMapId], references: [id])
  chartOfAccount ChartOfAccount         @relation(fields: [chartOfAccountId], references: [id])
  statementLine  StatementLine          @relation(fields: [statementLineId], references: [id])

  @@unique([frameworkMapId, chartOfAccountId, statementLineId])
  @@map("statement_line_mapping")
}

// "Immutable snapshot per generated report ... Regulators audit the
// snapshot, not a re-computation" (Reporting Spec §2). Same enforcement
// pattern as audit_trail (AMD-11.f / Reporting Spec Hard Rule #2): a
// hand-authored BEFORE UPDATE/DELETE trigger (see the AMD-11 migration)
// blocks mutation at the database engine level, not just by convention.
model ReportRun {
  id                  String          @id @default(uuid()) @db.Uuid
  ledgerEntityCode    String          @map("ledger_entity_code")
  basis               AccountingBasis
  periodStart         DateTime        @map("period_start")
  periodEnd           DateTime        @map("period_end")
  frameworkMapId      String          @map("framework_map_id") @db.Uuid
  statementTemplateId String?         @map("statement_template_id") @db.Uuid
  figures             Json
  generatedByUserId   String          @map("generated_by_user_id") @db.Uuid
  generatedAt         DateTime        @default(now()) @map("generated_at")

  ledgerEntity      LedgerEntity           @relation(fields: [ledgerEntityCode], references: [code])
  frameworkMap      AccountingFrameworkMap @relation(fields: [frameworkMapId], references: [id])
  statementTemplate StatementTemplate?     @relation(fields: [statementTemplateId], references: [id])
  generatedBy       AppUser                @relation(fields: [generatedByUserId], references: [id])

  @@map("report_run")
}

// SEC Nigeria return registry (Reporting Spec §2, "[SLOT NOW, FILL LATER]").
// Ships EMPTY: "adding One17's first SEC return must require only
// configuration rows + a mapping approval workflow run. If it requires a
// migration, this spec was violated" (Reporting Spec §6). No rows are
// seeded — the AMD-11 smoke suite inserts and deletes a single dummy row to
// prove the registry accepts configuration with zero code change, then
// removes it so the registry ships genuinely empty.
model RegulatorTemplate {
  id              String                  @id @default(uuid()) @db.Uuid
  regulatorCode   String                  @map("regulator_code")
  templateCode    String                  @map("template_code")
  name            String
  filingFrequency String?                 @map("filing_frequency")
  version         Int                     @default(1)
  status          RegulatorTemplateStatus @default(DRAFT)
  effectiveFrom   DateTime?               @map("effective_from")
  effectiveTo     DateTime?               @map("effective_to")
  createdByUserId String                  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at")

  createdBy       AppUser                    @relation(fields: [createdByUserId], references: [id])
  lines           RegulatorTemplateLine[]
  cellMaps        TemplateCellMap[]
  fieldMaps       TemplateFieldMap[]
  filingCalendars RegulatoryFilingCalendar[]
  filingRuns      RegulatoryFilingRun[]

  @@unique([regulatorCode, templateCode, version])
  @@map("regulator_template")
}

enum RegulatorTemplateStatus {
  DRAFT
  ACTIVE
  RETIRED

  @@map("regulator_template_status")
}

model RegulatorTemplateLine {
  id                     String  @id @default(uuid()) @db.Uuid
  regulatorTemplateId    String  @map("regulator_template_id") @db.Uuid
  lineCode               String  @map("line_code")
  label                  String
  sortOrder              Int     @map("sort_order")
  mapsToStatementLineId  String? @map("maps_to_statement_line_id") @db.Uuid
  mapsToChartOfAccountId String? @map("maps_to_chart_of_account_id") @db.Uuid

  regulatorTemplate    RegulatorTemplate @relation(fields: [regulatorTemplateId], references: [id])
  mapsToStatementLine  StatementLine?    @relation(fields: [mapsToStatementLineId], references: [id])
  mapsToChartOfAccount ChartOfAccount?   @relation(fields: [mapsToChartOfAccountId], references: [id])

  @@unique([regulatorTemplateId, lineCode])
  @@map("regulator_template_line")
}

// ============================================================================
// AMD-12 — Governance parameters are ACTIVATION-gated, never build-gated
// (CLAUDE.md invariant #16). "Build and deployment proceed with governed-
// parameter slots EMPTY... the system refuses to ACTIVATE ... the ERM module
// cannot arm live RAG statuses without an approved appetite matrix version."
// The 12 appetite statements (+ orphan row 13, DQ-10) are extracted from the
// ERM Engine (Workbook_Extracts/ERM_Engine/A_VALUES/14_Risk_Appetite.csv) and
// seeded as version 1, DRAFT — numeric green/amber/red bands ship NULL,
// awaiting the Board's activation-time entry, per AMD-12 rule 5 verbatim.
// ============================================================================

// Versioned container — "the Excel Change Log becomes a workflow table"
// (Formula Library, amendment 27). Governed the same way as every other
// Board-approved version in this codebase (ProductParameters,
// AccountingFrameworkMap): propose -> WorkflowEngineService -> approve.
// proposedByUserId is nullable — same reasoning as audit_trail.actorUserId:
// version 1 is Phase-0-extracted BUILD-TIME content (AMD-12 rule 5), not a
// human's runtime workflow submission, so there is no real proposer to
// attribute it to (matches ROLES/FUNCTIONS/ScreeningChecklistItem's own
// seed.ts rows, which carry no actor at all). Every SUBSEQUENT version, real
// proposal, does have a proposer, via RiskService.proposeMatrixVersion.
model RiskAppetiteMatrixVersion {
  id                 String           @id @default(uuid()) @db.Uuid
  version            Int              @unique
  status             RiskMatrixStatus @default(DRAFT)
  boardResolutionRef String?          @map("board_resolution_ref")
  proposedByUserId   String?          @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?          @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?          @unique @map("workflow_instance_id") @db.Uuid
  effectiveFrom      DateTime?        @map("effective_from")
  createdAt          DateTime         @default(now()) @map("created_at")

  proposedBy AppUser?               @relation("RiskAppetiteMatrixProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy AppUser?               @relation("RiskAppetiteMatrixApprovedBy", fields: [approvedByUserId], references: [id])
  categories RiskAppetiteCategory[]

  @@map("risk_appetite_matrix_version")
}

enum RiskMatrixStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("risk_matrix_status")
}

// One row per tbl_risk_appetite_matrix category (Formula Library sheet 14 /
// AMD-06). direction + isZeroTolerance are structural governance metadata
// (how the RAG mechanism works), seeded now; green/amber/red thresholds are
// the Board-governed NUMBERS and ship NULL — see the version model comment.
// The CHECK constraint (hand-authored migration) enforces AMD-06's "three
// distinct thresholds, monotonic per Direction" rule ONLY once all three are
// populated, and exempts isZeroTolerance rows (Shariah/Regulatory, G=0/R>=1)
// from the distinctness requirement, exactly as AMD-06 specifies.
model RiskAppetiteCategory {
  id                String                @id @default(uuid()) @db.Uuid
  matrixVersionId   String                @map("matrix_version_id") @db.Uuid
  sortOrder         Int                   @map("sort_order")
  riskCategory      String                @map("risk_category")
  // Nullable: row 13, the DQ-10 "orphan" (DPD escalation), ships with no
  // appetite statement because the source workbook's row 13 cell is itself
  // blank — the Data Dictionary resolves its CATEGORY NAME but never
  // supplies statement text, and none is invented here.
  appetiteStatement String?               @map("appetite_statement")
  appetiteLevel     String?               @map("appetite_level")
  direction         RiskAppetiteDirection
  isZeroTolerance   Boolean               @default(false) @map("is_zero_tolerance")
  escalationOwner   String?               @map("escalation_owner")
  greenThreshold    Decimal?              @map("green_threshold") @db.Decimal(12, 4)
  amberThreshold    Decimal?              @map("amber_threshold") @db.Decimal(12, 4)
  redThreshold      Decimal?              @map("red_threshold") @db.Decimal(12, 4)

  matrixVersion RiskAppetiteMatrixVersion @relation(fields: [matrixVersionId], references: [id])

  @@unique([matrixVersionId, sortOrder])
  @@map("risk_appetite_category")
}

enum RiskAppetiteDirection {
  HIGHER_BETTER
  LOWER_BETTER

  @@map("risk_appetite_direction")
}

// Corporate Strategy — Top Risk Review workbook (Risk Management/Top Risks -
// Board Approved/*.csv), extracted directly, not re-derived: category,
// subCategory, description, inherentRiskRating/residualRiskRating (the
// workbook's own qualitative Low/Medium/High assessments — these are
// extracted content, not Board-governed numeric bands, so they ship as-is,
// unlike the appetite matrix's thresholds) and riskAppetiteStatement (one
// per top-level category). Blank cells in the source ship as NULL here —
// nothing is invented to fill a gap the workbook itself left open.
model RiskRegisterEntry {
  id                    String             @id @default(uuid()) @db.Uuid
  sortOrder             Int                @map("sort_order")
  riskCategory          String             @map("risk_category")
  subCategory           String?            @map("sub_category")
  description           String?
  inherentRiskRating    String?            @map("inherent_risk_rating")
  residualRiskRating    String?            @map("residual_risk_rating")
  riskAppetiteStatement String?            @map("risk_appetite_statement")
  status                RiskRegisterStatus @default(DRAFT)
  approvedByUserId      String?            @map("approved_by_user_id") @db.Uuid
  boardResolutionRef    String?            @map("board_resolution_ref")
  createdAt             DateTime           @default(now()) @map("created_at")

  approvedBy AppUser? @relation("RiskRegisterApprovedBy", fields: [approvedByUserId], references: [id])

  @@map("risk_register_entry")
}

enum RiskRegisterStatus {
  DRAFT
  ACTIVE

  @@map("risk_register_status")
}

// ============================================================================
// Phase 3 sealed engines (Check-3 pass, 2026-07-04). Invariant 6 is absolute:
// no shared CALCULATION CODE between the Halal Fund (unit-NAV) engine and
// the PSR-waterfall (Mudarabah) engine — src/engine-halal-fund/ and
// src/engine-psr-waterfall/ never import from each other or from a shared
// "engine-common" module; small helpers (day-count, rounding) are
// deliberately duplicated in each rather than factored out. This is a
// DATA-layer note, not a code-sharing one: Distribution/DistributionLineItem
// below are used by BOTH engines (matching SRS §5.6's single distributions/
// distribution_line_items table design, AMD-08's added `method` enum), but
// each engine computes and writes its own rows via its own independent code
// path — sharing the table is not sharing the calculation.
// ============================================================================

// Formula Library Part B, F-HF-03 (Portfolio Investments sheet). One row per
// underlying position the Halal Fund holds — fixed/PLS (straight-line accrual)
// or equity (mark-to-market). Halal-Fund-scoped in this pass; the Mudarabah
// pool's own profit figure is sourced from PoolIncomeRecord instead (see that
// model's comment) — a deliberate scope boundary, not an oversight.
model PortfolioPosition {
  id               String                  @id @default(uuid()) @db.Uuid
  ledgerEntityCode String                  @map("ledger_entity_code")
  contractType     String                  @map("contract_type")
  isEquity         Boolean                 @default(false) @map("is_equity")
  principalKobo    BigInt                  @map("principal_kobo")
  ratePct          Decimal?                @map("rate_pct") @db.Decimal(6, 4)
  entryDate        DateTime                @map("entry_date") @db.Date
  maturityDate     DateTime?               @map("maturity_date") @db.Date
  repaidKobo       BigInt                  @default(0) @map("repaid_kobo")
  markPriceKobo    BigInt?                 @map("mark_price_kobo")
  markQty          Decimal?                @map("mark_qty") @db.Decimal(18, 4)
  status           PortfolioPositionStatus @default(ACTIVE)
  createdAt        DateTime                @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])

  @@map("portfolio_position")
}

enum PortfolioPositionStatus {
  ACTIVE
  MATURED
  EXITED

  @@map("portfolio_position_status")
}

// AMD-03 hard constraint: "for ledger_entity of type POOL, no fee_accruals
// rows exist at all" — enforced by a hand-authored DB trigger (see the
// Phase 3 engine migration), not application code, per the established
// defense-in-depth standard. Five fee types accrue daily against Halal Fund
// NAV (F-HF-04); zero rows ever exist for a POOL ledger entity.
model FeeAccrual {
  id                   String   @id @default(uuid()) @db.Uuid
  ledgerEntityCode     String   @map("ledger_entity_code")
  feeType              String   @map("fee_type")
  accrualDate          DateTime @map("accrual_date") @db.Date
  dailyAmountKobo      BigInt   @map("daily_amount_kobo")
  cumulativeAmountKobo BigInt   @map("cumulative_amount_kobo")
  paidAmountKobo       BigInt   @default(0) @map("paid_amount_kobo")
  createdAt            DateTime @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])

  @@unique([ledgerEntityCode, feeType, accrualDate])
  @@map("fee_accrual")
}

// Formula Library F-HF-01/F-HF-02: the authoritative daily NAV + unit-pricing
// record. "PUBLICATION: locked rows are hardcoded published values ... in
// software: INSERT + LOCK at publish; published NAV never drifts" — isLocked
// flips once and a DB trigger (see migration) then blocks any further UPDATE,
// same immutability standard as audit_trail/report_run.
model NavRecord {
  id                    String    @id @default(uuid()) @db.Uuid
  ledgerEntityCode      String    @map("ledger_entity_code")
  valuationDate         DateTime  @map("valuation_date") @db.Date
  portfolioMktValKobo   BigInt    @map("portfolio_mkt_val_kobo")
  uninvestedCashKobo    BigInt    @map("uninvested_cash_kobo")
  accruedUnpaidFeesKobo BigInt    @map("accrued_unpaid_fees_kobo")
  totalNavKobo          BigInt    @map("total_nav_kobo")
  unitsOutstanding      Decimal   @map("units_outstanding") @db.Decimal(18, 4)
  navPerUnit            Decimal   @map("nav_per_unit") @db.Decimal(14, 4)
  offerPrice            Decimal   @map("offer_price") @db.Decimal(14, 4)
  bidPrice              Decimal   @map("bid_price") @db.Decimal(14, 4)
  isLocked              Boolean   @default(false) @map("is_locked")
  lockedAt              DateTime? @map("locked_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])

  @@unique([ledgerEntityCode, valuationDate])
  @@map("nav_record")
}

// CHECK16 62(c): the governed per-date portfolio-market-value override the
// Fund Accountant enters/corrects, feeding computeDailyNav — maker≠checker
// on entry, since a price input moves NAV. Versioned (not edited in place)
// so a "correction" is a new proposal, never a silent overwrite of an
// already-approved value; HalalFundEngineService.computeDailyNav reads the
// latest ACTIVE row for (ledgerEntityCode, valuationDate) and, if present,
// uses it INSTEAD of the bottom-up PortfolioPosition sum — the bottom-up
// path stays the untouched default wherever no manual entry exists. The
// external-feed integration itself remains roadmap (invariant 62l).
model PortfolioMarketValueEntry {
  id               String             @id @default(uuid()) @db.Uuid
  ledgerEntityCode String             @map("ledger_entity_code")
  valuationDate    DateTime           @map("valuation_date") @db.Date
  version          Int
  marketValueKobo  BigInt             @map("market_value_kobo")
  status           GovernedItemStatus @default(DRAFT)
  proposedByUserId String             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId String?            @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?          @map("approved_at")
  createdAt        DateTime           @default(now()) @map("created_at")

  ledgerEntity   LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])
  proposedByUser AppUser      @relation("PortfolioMarketValueEntryProposedBy", fields: [proposedByUserId], references: [id])
  approvedByUser AppUser?     @relation("PortfolioMarketValueEntryApprovedBy", fields: [approvedByUserId], references: [id])

  @@unique([ledgerEntityCode, valuationDate, version])
  @@map("portfolio_market_value_entry")
}

// Check-6A item 1: the governed config CHECK5_EVIDENCE.md §7 reported
// missing — computeDailyNav()/accrueFees() need launchDate/launchPrice/
// offer+bidSpreadPct/feeRates, which until this pass existed ONLY as
// hardcoded smoke-test fixtures (halal-fund-engine.smoke.ts), so the daily
// accrual could never be auto-scheduled without fabricating them. Same
// versioned/governance-gated shape as ProductParameters (invariant 7):
// first version for a fund needs no Board/SSB refs (nothing to change
// FROM); a change to an ACTIVE fund's ACTIVE config requires BOTH
// boardResolutionRef and ssbResolutionRef, mirroring
// ParameterService.checkGovernanceGate exactly — fee rates move investor
// NAV the same way a PSR constant does.
model HalalFundLaunchConfig {
  id                 String             @id @default(uuid()) @db.Uuid
  ledgerEntityCode   String             @map("ledger_entity_code")
  version            Int
  status             GovernedItemStatus @default(ACTIVE)
  launchDate         DateTime           @map("launch_date") @db.Date
  launchPrice        Decimal            @map("launch_price") @db.Decimal(14, 4)
  offerSpreadPct     Decimal            @map("offer_spread_pct") @db.Decimal(6, 4)
  bidSpreadPct       Decimal            @map("bid_spread_pct") @db.Decimal(6, 4)
  // Formula Library B0/F-HF-04: 5 fee types, annual rate on NAV base.
  // [{ feeType: string; annualRatePct: number }] — JSON because the fee
  // TYPES themselves are config vocabulary (invariant 10), not a fixed
  // struct this table should hardcode a column per type for.
  feeRates           Json               @map("fee_rates")
  boardResolutionRef String?            @map("board_resolution_ref")
  ssbResolutionRef   String?            @map("ssb_resolution_ref")
  createdByUserId    String             @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])
  createdBy    AppUser      @relation("HFLaunchConfigCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy   AppUser?     @relation("HFLaunchConfigApprovedBy", fields: [approvedByUserId], references: [id])

  @@unique([ledgerEntityCode, version])
  @@map("halal_fund_launch_config")
}

// PSR-waterfall engine's confirmed-income input (BR-PAE-01: "distribution
// basis = confirmed income only ... no projections, no provisional PLS, no
// unrealised gains"). pool_profit = incomeReceivedKobo + accruedIncomeKobo
// (Formula Library A3) — FinCon/Portfolio confirm the figures that land
// here; the underlying obligor-level position/accrual ledger for the pool's
// own deployments is a documented scope boundary for this pass (see the
// engine module comment), not silently omitted.
model PoolIncomeRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  ledgerEntityCode   String   @map("ledger_entity_code")
  periodStart        DateTime @map("period_start") @db.Date
  periodEnd          DateTime @map("period_end") @db.Date
  incomeReceivedKobo BigInt   @map("income_received_kobo")
  accruedIncomeKobo  BigInt   @map("accrued_income_kobo")
  confirmedByUserId  String   @map("confirmed_by_user_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  ledgerEntity LedgerEntity @relation(fields: [ledgerEntityCode], references: [code])
  confirmedBy  AppUser      @relation(fields: [confirmedByUserId], references: [id])

  @@map("pool_income_record")
}

// SRS §5.6 + AMD-08: ONE distributions table shared by both product engines
// (method distinguishes Halal Fund's Method A/B from the Mudarabah pool's
// PSR waterfall, which leaves it null) — see this section's header comment
// on why this is not a violation of invariant 6.
model Distribution {
  id                        String              @id @default(uuid()) @db.Uuid
  ledgerEntityCode          String              @map("ledger_entity_code")
  productCode               String              @map("product_code")
  method                    DistributionMethod?
  periodStart               DateTime            @map("period_start") @db.Date
  periodEnd                 DateTime            @map("period_end") @db.Date
  recordDate                DateTime            @map("record_date") @db.Date
  netAvailableKobo          BigInt              @map("net_available_kobo")
  toParticipantsKobo        BigInt              @map("to_participants_kobo")
  retainedOrMudaribBaseKobo BigInt              @map("retained_or_mudarib_base_kobo")
  status                    DistributionStatus  @default(DRAFT)
  boardResolutionRef        String?             @map("board_resolution_ref")
  ssbResolutionRef          String?             @map("ssb_resolution_ref")
  workflowInstanceId        String?             @unique @map("workflow_instance_id") @db.Uuid
  declaredAt                DateTime?           @map("declared_at")
  paidAt                    DateTime?           @map("paid_at")
  createdByUserId           String              @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime            @default(now()) @map("created_at")

  ledgerEntity LedgerEntity           @relation(fields: [ledgerEntityCode], references: [code])
  createdBy    AppUser                @relation(fields: [createdByUserId], references: [id])
  lineItems    DistributionLineItem[]
  hibahRecords HibahRecord[]

  @@map("distribution")
}

enum DistributionMethod {
  INCOME
  NAV
  // Formula Library PART E §E5: ND Mandate engine's own two modes, sharing
  // the Distribution/DistributionLineItem tables per the Check-3 §4
  // data-sharing precedent (invariant 6 is about calculation CODE, not
  // these tables).
  ND_MUDARABAH
  ND_WAKALAH

  @@map("distribution_method")
}

enum DistributionStatus {
  DRAFT
  DECLARED
  PAID

  @@map("distribution_status")
}

// One row per participating ProductAccount within a Distribution. Fields
// left null by whichever engine doesn't use them (e.g. dpsKobo/dripUnits
// are Halal-Fund-only; twe/entitlementKobo are PSR-waterfall-only).
model DistributionLineItem {
  id                 String   @id @default(uuid()) @db.Uuid
  distributionId     String   @map("distribution_id") @db.Uuid
  // Nullable + an alternative ndMandateAccountId: the ND Mandate engine
  // (Formula Library PART E §E5) writes to this SAME table per the Check-3
  // §4 data-sharing precedent, but its per-account participations are not
  // ProductAccount rows (a FUND/POOL participant per §E6 has no Investor
  // identity to hang a ProductAccount off of) — exactly one of the two FKs
  // is set per row, enforced in each engine's own service code, not a DB
  // CHECK (Postgres can't express "exactly one of two nullable FKs" cleanly
  // without a redundant discriminator column this table doesn't otherwise
  // need).
  productAccountId   String?  @map("product_account_id") @db.Uuid
  ndMandateAccountId String?  @map("nd_mandate_account_id") @db.Uuid
  capitalKobo        BigInt   @map("capital_kobo")
  targetRatePct      Decimal? @map("target_rate_pct") @db.Decimal(6, 4)
  activeDays         Int?     @map("active_days")
  entitlementKobo    BigInt?  @map("entitlement_kobo")
  twe                Decimal? @map("twe") @db.Decimal(10, 8)
  priorityPayoutKobo BigInt?  @map("priority_payout_kobo")
  surplusPayoutKobo  BigInt?  @map("surplus_payout_kobo")
  hibahKobo          BigInt   @default(0) @map("hibah_kobo")
  unitsAtRecord      Decimal? @map("units_at_record") @db.Decimal(18, 4)
  dpsAmount          Decimal? @map("dps_amount") @db.Decimal(14, 4)
  dripUnits          Decimal? @map("drip_units") @db.Decimal(18, 4)
  dripAmountKobo     BigInt?  @map("drip_amount_kobo")
  totalPayoutKobo    BigInt   @map("total_payout_kobo")
  createdAt          DateTime @default(now()) @map("created_at")

  distribution     Distribution      @relation(fields: [distributionId], references: [id])
  productAccount   ProductAccount?   @relation(fields: [productAccountId], references: [id])
  ndMandateAccount NdMandateAccount? @relation(fields: [ndMandateAccountId], references: [id])

  @@map("distribution_line_item")
}

// Formula Library A4 (CEO refinement): the FM's voluntary gift, recorded
// distinctly from pool profit, disclosed on statements. isLossPeriod flags
// the case funded from COMPANY's own books rather than the Mudarib share.
model HibahRecord {
  id               String   @id @default(uuid()) @db.Uuid
  distributionId   String?  @map("distribution_id") @db.Uuid
  productAccountId String?  @map("product_account_id")
  ledgerEntityCode String   @map("ledger_entity_code")
  amountKobo       BigInt   @map("amount_kobo")
  isLossPeriod     Boolean  @default(false) @map("is_loss_period")
  reason           String
  approvedByUserId String   @map("approved_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  distribution Distribution? @relation(fields: [distributionId], references: [id])
  ledgerEntity LedgerEntity  @relation(fields: [ledgerEntityCode], references: [code])
  approvedBy   AppUser       @relation(fields: [approvedByUserId], references: [id])

  @@map("hibah_record")
}

// ============================================================================
// Budget Management (invariant 20, CLAUDE.md; full spec: Budget_Procurement_
// Spec_v1.md). Schema-only per the build sequencing in §5 — budget core
// ACTIVATES with Phase 4 (task 54 wires F-BZ-01/04/05 to read it). §5a's
// TPL_11 v2 driver model: every budget_line carries its own phasing method
// and driver attributes so the Planning module can re-forecast when actual
// FUM/mobilization diverges from plan, without a code change — the whole
// point of capturing DRIVERS, not just values.
// ============================================================================

model BudgetVersion {
  id                   String              @id @default(uuid()) @db.Uuid
  fiscalYear           Int                 @map("fiscal_year")
  scenarioLabel        String              @map("scenario_label")
  status               BudgetVersionStatus @default(DRAFT)
  boardResolutionRef   String?             @map("board_resolution_ref")
  proposedByUserId     String?             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId     String?             @map("approved_by_user_id") @db.Uuid
  workflowInstanceId   String?             @unique @map("workflow_instance_id") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at")
  // Invariant 28(c): "annual Budget (budget_version references strategic
  // objectives)" — a plain code array rather than a join table, since this
  // is a light linkage (which objectives this year's budget serves), not a
  // relation any query here needs to join through.
  linkedObjectiveCodes String[]            @default([]) @map("linked_objective_codes")

  proposedBy AppUser?       @relation("BudgetVersionProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy AppUser?       @relation("BudgetVersionApprovedBy", fields: [approvedByUserId], references: [id])
  lines      BudgetLine[]
  targets    BudgetTarget[]

  @@unique([fiscalYear, scenarioLabel])
  @@map("budget_version")
}

enum BudgetVersionStatus {
  DRAFT
  PROPOSED
  BOARD_APPROVED
  ACTIVE

  @@map("budget_version_status")
}

// TPL_11 v2's driver model (Budget Spec §5a): phasingMethod + driverBasis +
// driverRateOrFactor are what let the Planning module RE-FORECAST a line
// from an actual FUM/mobilization figure instead of just replaying a static
// monthly number — the whole payoff of extracting drivers, not values.
model BudgetLine {
  id                   String              @id @default(uuid()) @db.Uuid
  budgetVersionId      String              @map("budget_version_id") @db.Uuid
  ledgerEntityCode     String              @map("ledger_entity_code")
  budgetLineGroup      String              @map("budget_line_group")
  lineDescription      String              @map("line_description")
  class                BudgetLineClass
  phasingMethod        BudgetPhasingMethod @map("phasing_method")
  // e.g. "FUM_MONTHLY" (sheet 02 row 25) / "MOBILIZATION_MONTHLY" (row 23) —
  // free text since the driver basis catalogue is extraction content, not a
  // fixed platform vocabulary (same "config not code" reasoning as
  // EventJournalConfig's account codes).
  driverBasis          String?             @map("driver_basis")
  driverRateOrFactor   Decimal?            @map("driver_rate_or_factor") @db.Decimal(10, 6)
  // ESCALATING_MONTHLY's month-over-month factor series, preserved exactly
  // as extracted rather than collapsed into a single rate (Budget Spec
  // §5a: "escalator series preserved as factors").
  escalatorFactorsJson Json?               @map("escalator_factors_json")
  sourceSheetRef       String              @map("source_sheet_ref")
  // BQ-8: the Commission line loads but cannot ACTIVATE until FinCon
  // resolves the 45% narrative vs 0.2% formula discrepancy — staged,
  // flagged, never silently defaulted to either figure.
  isActive             Boolean             @default(true) @map("is_active")
  flaggedReason        String?             @map("flagged_reason")
  // BQ-9: cells sourced from the unexported 'Existing Investors 2025' sheet
  // load values-as-given — the VALUES export carries the resolved number,
  // but the driver source itself is unverifiable from what was supplied.
  valuesAsGiven        Boolean             @default(false) @map("values_as_given")
  createdAt            DateTime            @default(now()) @map("created_at")

  budgetVersion  BudgetVersion             @relation(fields: [budgetVersionId], references: [id])
  ledgerEntity   LedgerEntity              @relation(fields: [ledgerEntityCode], references: [code])
  monthlyAmounts BudgetLineMonthlyAmount[]
  encumbrances   Encumbrance[]

  @@map("budget_line")
}

enum BudgetLineClass {
  OPEX
  CAPEX
  REVENUE
  STAFF

  @@map("budget_line_class")
}

// TPL_11 v2's phasing_method vocabulary, verbatim from Budget Spec §5a.
enum BudgetPhasingMethod {
  ACTUAL_PHASED
  EVEN_12
  DRIVER_PCT_OF_FUM
  DRIVER_PCT_OF_MOBILIZATION
  PRIOR_YEAR_UPLIFT
  ESCALATING_MONTHLY
  FIXED_MONTHLY

  @@map("budget_phasing_method")
}

// One row per (budget_line, month). amountKobo is the value AS EXPORTED
// (ground truth); recomputedAmountKobo is populated by the driver-
// recomputation validation gate (task 47) — the two must agree to within
// N1 for the line's driver capture to be considered proven, "same
// discipline as the NAV replay."
model BudgetLineMonthlyAmount {
  id                   String   @id @default(uuid()) @db.Uuid
  budgetLineId         String   @map("budget_line_id") @db.Uuid
  month                Int
  amountKobo           BigInt   @map("amount_kobo")
  recomputedAmountKobo BigInt?  @map("recomputed_amount_kobo")
  createdAt            DateTime @default(now()) @map("created_at")

  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id])

  @@unique([budgetLineId, month])
  @@map("budget_line_monthly_amount")
}

// Non-GL Board benchmarks (Budget Spec §2): FUM, monthly mobilization by
// source, expected returns, product income — the reference values ERM KRIs
// and PMS KPIs score against. value is a plain Decimal (not kobo BigInt)
// since several target types are percentages/ratios/unit-counts, not
// settlement amounts (same reasoning as ProductParameters' rate fields).
model BudgetTarget {
  id              String   @id @default(uuid()) @db.Uuid
  budgetVersionId String   @map("budget_version_id") @db.Uuid
  targetType      String   @map("target_type")
  month           Int?
  value           Decimal  @db.Decimal(20, 6)
  unit            String
  sourceSheetRef  String   @map("source_sheet_ref")
  createdAt       DateTime @default(now()) @map("created_at")

  budgetVersion BudgetVersion @relation(fields: [budgetVersionId], references: [id])

  @@map("budget_target")
}

// Commitment accounting (Budget Spec §2/§3): encumber at requisition,
// released or converted at invoice. Ships EMPTY per invariant 20's "schema
// only" build-now scope — the expenditure workflow itself is Wave 1+.
model Encumbrance {
  id                String            @id @default(uuid()) @db.Uuid
  budgetLineId      String            @map("budget_line_id") @db.Uuid
  description       String
  amountKobo        BigInt            @map("amount_kobo")
  status            EncumbranceStatus @default(OPEN)
  requestedByUserId String            @map("requested_by_user_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")

  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id])
  requestedBy   AppUser        @relation(fields: [requestedByUserId], references: [id])
  purchaseOrder PurchaseOrder?

  @@map("encumbrance")
}

enum EncumbranceStatus {
  OPEN
  RELEASED
  CONVERTED

  @@map("encumbrance_status")
}

// Check-6B: Budget Spec §4 (Admin/Procurement, Corporate Services module),
// Wave-1 scope brought forward on the CEO's explicit go-ahead. A vendor is
// a distinct master (never merged with investor/counterparty — invariant
// 4's "one identity once" is about people/entities the platform has a
// financial claim ON; a vendor is who the COMPANY owes, a structurally
// different relationship).
model Vendor {
  id                String       @id @default(uuid()) @db.Uuid
  vendorCode        String       @unique @map("vendor_code")
  legalName         String       @map("legal_name")
  rcNumber          String?      @map("rc_number")
  tin               String?
  bankName          String?      @map("bank_name")
  bankAccountNumber String?      @map("bank_account_number")
  bankAccountName   String?      @map("bank_account_name")
  status            VendorStatus @default(ACTIVE)
  // "Feeds CorpServices KRA-2 KPIs" (Budget Spec §4) — CORP-KRA2 is a
  // STRATEGIC-class, self-scored PMS KPI (seed.ts), not an AUTO feed, so
  // this is descriptive reference data the scoring officer consults, not a
  // computed pipeline into PMS.
  performanceRating Decimal?     @map("performance_rating") @db.Decimal(4, 2)
  createdByUserId   String       @map("created_by_user_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")

  createdBy      AppUser         @relation(fields: [createdByUserId], references: [id])
  purchaseOrders PurchaseOrder[]
  vendorInvoices VendorInvoice[]

  @@map("vendor")
}

enum VendorStatus {
  ACTIVE
  SUSPENDED

  @@map("vendor_status")
}

// A PO may only be issued against an encumbrance whose EXPENDITURE_
// REQUISITION workflow instance has reached APPROVED (Budget Spec §3's
// "encumbrance raised -> procurement executes") — ProcurementService
// checks this via WorkflowInstance, not a stored status flag here, since
// WorkflowInstance is already the one source of truth for approval state.
model PurchaseOrder {
  id               String              @id @default(uuid()) @db.Uuid
  poNumber         String              @unique @map("po_number")
  vendorId         String              @map("vendor_id") @db.Uuid
  encumbranceId    String              @unique @map("encumbrance_id") @db.Uuid
  ledgerEntityCode String              @map("ledger_entity_code")
  description      String
  totalAmountKobo  BigInt              @map("total_amount_kobo")
  status           PurchaseOrderStatus @default(DRAFT)
  createdByUserId  String              @map("created_by_user_id") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at")
  issuedAt         DateTime?           @map("issued_at")

  vendor               Vendor               @relation(fields: [vendorId], references: [id])
  encumbrance          Encumbrance          @relation(fields: [encumbranceId], references: [id])
  ledgerEntity         LedgerEntity         @relation(fields: [ledgerEntityCode], references: [code])
  createdBy            AppUser              @relation(fields: [createdByUserId], references: [id])
  lines                PurchaseOrderLine[]
  goodsReceipts        GoodsReceipt[]
  vendorInvoices       VendorInvoice[]
  assetRegisterEntries AssetRegisterEntry[]

  @@map("purchase_order")
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  RECEIVED
  MATCHED
  CLOSED
  CANCELLED

  @@map("purchase_order_status")
}

model PurchaseOrderLine {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @map("purchase_order_id") @db.Uuid
  description     String
  quantity        Decimal @db.Decimal(14, 4)
  unitPriceKobo   BigInt  @map("unit_price_kobo")
  lineAmountKobo  BigInt  @map("line_amount_kobo")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_line")
}

model GoodsReceipt {
  id                 String   @id @default(uuid()) @db.Uuid
  purchaseOrderId    String   @map("purchase_order_id") @db.Uuid
  receivedAmountKobo BigInt   @map("received_amount_kobo")
  receivedByUserId   String   @map("received_by_user_id") @db.Uuid
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedBy    AppUser       @relation(fields: [receivedByUserId], references: [id])

  @@map("goods_receipt")
}

// 3-way match (Budget Spec §4): PO amount, cumulative goods-receipt amount,
// and this invoice amount must agree within ProcurementMatchToleranceConfig
// — checked by ProcurementService.matchInvoice(), never a hardcoded %
// (invariant 10). journalEntryId/paidJournalEntryId are plain UUID refs,
// not Prisma relations — same pattern as every other workflowInstanceId
// column in this schema (a soft cross-reference, not a reverse-relation
// array on JournalEntry).
model VendorInvoice {
  id                         String              @id @default(uuid()) @db.Uuid
  purchaseOrderId            String              @map("purchase_order_id") @db.Uuid
  vendorId                   String              @map("vendor_id") @db.Uuid
  invoiceNumber              String              @map("invoice_number")
  invoiceAmountKobo          BigInt              @map("invoice_amount_kobo")
  invoiceDate                DateTime            @map("invoice_date") @db.Date
  status                     VendorInvoiceStatus @default(PENDING_MATCH)
  matchVarianceNote          String?             @map("match_variance_note")
  matchedAt                  DateTime?           @map("matched_at")
  journalEntryId             String?             @map("journal_entry_id") @db.Uuid
  paidJournalEntryId         String?             @map("paid_journal_entry_id") @db.Uuid
  // Invariant 65(c)(ii) (CHECK18): INPUT VAT recognition on a procurement
  // vendor invoice -- distinct from FeeInvoice's OUTPUT VAT on One17's own
  // billing. Nullable/zero until a VAT rate applies (not every vendor
  // invoice carries VAT); recognizedVatRateVersionId records which
  // effective-dated version computed it, so a later rate change never
  // alters an already-recognized invoice's figure.
  vatKobo                    BigInt              @default(0) @map("vat_kobo")
  recognizedVatRateVersionId String?             @map("recognized_vat_rate_version_id") @db.Uuid
  createdByUserId            String              @map("created_by_user_id") @db.Uuid
  createdAt                  DateTime            @default(now()) @map("created_at")

  purchaseOrder            PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  vendor                   Vendor             @relation(fields: [vendorId], references: [id])
  createdBy                AppUser            @relation(fields: [createdByUserId], references: [id])
  paymentBatchLines        PaymentBatchLine[]
  recognizedVatRateVersion TaxRateVersion?    @relation(fields: [recognizedVatRateVersionId], references: [id])

  @@unique([vendorId, invoiceNumber])
  @@map("vendor_invoice")
}

enum VendorInvoiceStatus {
  PENDING_MATCH
  MATCHED
  DISPUTED
  PAID

  @@map("vendor_invoice_status")
}

model PaymentBatch {
  id                 String             @id @default(uuid()) @db.Uuid
  batchNumber        String             @unique @map("batch_number")
  ledgerEntityCode   String             @map("ledger_entity_code")
  totalAmountKobo    BigInt             @map("total_amount_kobo")
  status             PaymentBatchStatus @default(DRAFT)
  createdByUserId    String             @map("created_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")
  paidAt             DateTime?          @map("paid_at")
  journalEntryId     String?            @map("journal_entry_id") @db.Uuid
  workflowInstanceId String?            @unique @map("workflow_instance_id") @db.Uuid

  ledgerEntity LedgerEntity       @relation(fields: [ledgerEntityCode], references: [code])
  createdBy    AppUser            @relation(fields: [createdByUserId], references: [id])
  lines        PaymentBatchLine[]

  @@map("payment_batch")
}

enum PaymentBatchStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID

  @@map("payment_batch_status")
}

model PaymentBatchLine {
  id              String @id @default(uuid()) @db.Uuid
  paymentBatchId  String @map("payment_batch_id") @db.Uuid
  vendorInvoiceId String @map("vendor_invoice_id") @db.Uuid
  amountKobo      BigInt @map("amount_kobo")

  paymentBatch  PaymentBatch  @relation(fields: [paymentBatchId], references: [id])
  vendorInvoice VendorInvoice @relation(fields: [vendorInvoiceId], references: [id])

  @@map("payment_batch_line")
}

// Budget Spec §4: "Asset register (CAPEX lines -> company assets, dual-
// framework depreciation via AMD-11 mapping)." "Dual-framework" here means
// the depreciation event posts through the SAME event_journal_config /
// accounting_framework_map machinery every other journal uses (invariant
// 15b: one economic event, classified twice) — not a second set of asset
// fields; the dual classification already lives in the CoA/framework map,
// not on the asset itself.
model AssetRegisterEntry {
  id                          String      @id @default(uuid()) @db.Uuid
  assetCode                   String      @unique @map("asset_code")
  description                 String
  purchaseOrderId             String?     @map("purchase_order_id") @db.Uuid
  ledgerEntityCode            String      @map("ledger_entity_code")
  costKobo                    BigInt      @map("cost_kobo")
  acquisitionDate             DateTime    @map("acquisition_date") @db.Date
  usefulLifeMonths            Int         @map("useful_life_months")
  accumulatedDepreciationKobo BigInt      @default(0) @map("accumulated_depreciation_kobo")
  status                      AssetStatus @default(ACTIVE)
  createdByUserId             String      @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime    @default(now()) @map("created_at")
  disposedAt                  DateTime?   @map("disposed_at")

  purchaseOrder    PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  ledgerEntity     LedgerEntity           @relation(fields: [ledgerEntityCode], references: [code])
  createdBy        AppUser                @relation(fields: [createdByUserId], references: [id])
  depreciationRuns AssetDepreciationRun[]

  @@map("asset_register_entry")
}

enum AssetStatus {
  ACTIVE
  FULLY_DEPRECIATED
  DISPOSED

  @@map("asset_status")
}

model AssetDepreciationRun {
  id                     String   @id @default(uuid()) @db.Uuid
  assetRegisterEntryId   String   @map("asset_register_entry_id") @db.Uuid
  periodMonth            Int      @map("period_month")
  periodYear             Int      @map("period_year")
  depreciationAmountKobo BigInt   @map("depreciation_amount_kobo")
  journalEntryId         String?  @map("journal_entry_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at")

  assetRegisterEntry AssetRegisterEntry @relation(fields: [assetRegisterEntryId], references: [id])

  @@unique([assetRegisterEntryId, periodMonth, periodYear])
  @@map("asset_depreciation_run")
}

// Versioned config (ParameterService pattern) — invariant 10: the 3-way
// match tolerance is never a hardcoded %. First version seeds a
// conservative operational default pending Finance/CEO ratification, same
// "seed the slot, don't block the build" precedent as complaint_sla_config.
model ProcurementMatchToleranceConfig {
  id           String             @id @default(uuid()) @db.Uuid
  version      Int
  status       GovernedItemStatus @default(ACTIVE)
  tolerancePct Decimal            @map("tolerance_pct") @db.Decimal(5, 2)
  createdAt    DateTime           @default(now()) @map("created_at")

  @@map("procurement_match_tolerance_config")
}

// Invariant 50(a) (CHECK12): petty cash = IMPREST module, deliberately NOT
// procurement/3-way match. Float establishment/adjustment happens via the
// EXISTING manual Journal Entries maker-checker flow (JOURNAL_ENTRIES,
// JOURNAL_POSTING) -- this row is the register entry, not itself a money
// movement. floatCeilingKobo/singleVoucherCapKobo are the governed caps
// invariant 50(a) calls for, scoped per float since different
// custodians/offices plausibly need different limits (a judgment call --
// no single global cap makes sense across offices of different size).
model PettyCashFloat {
  id                   String               @id @default(uuid()) @db.Uuid
  floatCode            String               @unique @map("float_code")
  custodianUserId      String               @map("custodian_user_id") @db.Uuid
  officeLabel          String               @map("office_label")
  ledgerEntityCode     String               @default("COMPANY") @map("ledger_entity_code")
  floatCeilingKobo     BigInt               @map("float_ceiling_kobo")
  singleVoucherCapKobo BigInt               @map("single_voucher_cap_kobo")
  status               PettyCashFloatStatus @default(ACTIVE)
  establishedByUserId  String               @map("established_by_user_id") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at")

  ledgerEntity LedgerEntity                  @relation(fields: [ledgerEntityCode], references: [code])
  vouchers     PettyCashVoucher[]
  claims       PettyCashReplenishmentClaim[]
  spotChecks   PettyCashSpotCheck[]

  @@map("petty_cash_float")
}

enum PettyCashFloatStatus {
  ACTIVE
  CLOSED

  @@map("petty_cash_float_status")
}

// One row per spend event, captured as it happens -- the receipt link is
// via the existing generic DocumentRegisterEntry (entityType:
// 'petty_cash_voucher', entityId: this row's id), same pattern every other
// attach-a-document screen uses (DocumentAttachments widget), not a
// dedicated FK column. Status flips OUTSTANDING -> REIMBURSED only when
// the replenishment claim it's bundled into is actually DISBURSED --
// "float balance = float - unclaimed vouchers" means every OUTSTANDING
// voucher (spent, not yet reimbursed) reduces the visible available
// balance, whether or not a claim has been initiated for it yet.
model PettyCashVoucher {
  id                 String                 @id @default(uuid()) @db.Uuid
  floatId            String                 @map("float_id") @db.Uuid
  voucherDate        DateTime               @map("voucher_date")
  payee              String
  expenseAccountCode String                 @map("expense_account_code")
  amountKobo         BigInt                 @map("amount_kobo")
  status             PettyCashVoucherStatus @default(OUTSTANDING)
  claimId            String?                @map("claim_id") @db.Uuid
  createdByUserId    String                 @map("created_by_user_id") @db.Uuid
  createdAt          DateTime               @default(now()) @map("created_at")

  float PettyCashFloat               @relation(fields: [floatId], references: [id])
  claim PettyCashReplenishmentClaim? @relation(fields: [claimId], references: [id])

  @@map("petty_cash_voucher")
}

enum PettyCashVoucherStatus {
  OUTSTANDING
  REIMBURSED

  @@map("petty_cash_voucher_status")
}

// The 3-actor chain invariant 50(a) names: Admin/custodian initiates ->
// SAU Internal Control verifies (BUDGET_CONTROL_REVIEW, reused not
// cloned) -> DoA approval (BUDGET_MANAGEMENT, reused, amount-tiered) ->
// Finance disburses (new PETTY_CASH_DISBURSEMENT function, the only truly
// novel capability this module needs) -- see PETTY_CASH_REPLENISHMENT_
// APPROVAL's 3-step ApprovalRule in seed.ts. "No journal at claim
// approval -- only at replenishment disbursement": the eventJournal call
// is PARKED (see PettyCashService.decideReplenishmentClaim) pending
// FinCon's confirmed PETTY_CASH_REPLENISHMENT event_journal_config
// mapping (Mapping 6 on the advisor's sheet), same standing discipline as
// the five CHECK9/CHECK11 parked wirings.
model PettyCashReplenishmentClaim {
  id                 String               @id @default(uuid()) @db.Uuid
  floatId            String               @map("float_id") @db.Uuid
  totalVoucherKobo   BigInt               @map("total_voucher_kobo")
  status             PettyCashClaimStatus @default(DRAFT)
  initiatedByUserId  String               @map("initiated_by_user_id") @db.Uuid
  workflowInstanceId String?              @unique @map("workflow_instance_id") @db.Uuid
  disbursedByUserId  String?              @map("disbursed_by_user_id") @db.Uuid
  disbursedAt        DateTime?            @map("disbursed_at")
  rejectionNotes     String?              @map("rejection_notes")
  createdAt          DateTime             @default(now()) @map("created_at")

  float    PettyCashFloat     @relation(fields: [floatId], references: [id])
  vouchers PettyCashVoucher[]

  @@map("petty_cash_replenishment_claim")
}

enum PettyCashClaimStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  DISBURSED

  @@map("petty_cash_claim_status")
}

// "Count/reconciliation action for IC spot checks" -- a control action in
// its own right (SAU Internal Control physically counting the float), not
// something needing further approval; expectedKobo is the live balance
// calc snapshotted at check time so the variance is reproducible after
// the fact even as later vouchers/claims change the running balance.
model PettyCashSpotCheck {
  id              String   @id @default(uuid()) @db.Uuid
  floatId         String   @map("float_id") @db.Uuid
  countedKobo     BigInt   @map("counted_kobo")
  expectedKobo    BigInt   @map("expected_kobo")
  varianceKobo    BigInt   @map("variance_kobo")
  notes           String?
  checkedByUserId String   @map("checked_by_user_id") @db.Uuid
  checkedAt       DateTime @default(now()) @map("checked_at")

  float PettyCashFloat @relation(fields: [floatId], references: [id])

  @@map("petty_cash_spot_check")
}

// Budget Review Pack (queue item 2, Budget Spec §5b): "RAG per governed
// thresholds in config (invariant 10 — no hardcoded breakpoints)." Simple
// versioned single-row config so a threshold change is a new row, not a
// code change — same "config not code" doctrine as
// RiskAppetiteCategory/KpiWeightMatrix, deliberately lighter-weight since
// this isn't a Board-governed matrix, just an operational display
// threshold FinCon can tune.
model BudgetVarianceRagThreshold {
  id            String   @id @default(uuid()) @db.Uuid
  version       Int      @unique
  amberPct      Decimal  @map("amber_pct") @db.Decimal(6, 4)
  redPct        Decimal  @map("red_pct") @db.Decimal(6, 4)
  effectiveFrom DateTime @default(now()) @map("effective_from")

  @@map("budget_variance_rag_threshold")
}

// ============================================================================
// ND Mandate engine (third sealed engine, CLAUDE.md invariant 6 / Formula
// Library PART E). Per-account computation, NO pooling — each row here is
// its own independent contract, never combined with another mandate's
// figures the way the PSR-waterfall pool combines investors.
// ============================================================================

// Formula Library PART E §E6: "mandate_participation.participant_type =
// INVESTOR | FUND | POOL." exactly one of investorId /
// participantLedgerEntityCode is set, matching participantType.
// surplusTreatment is nullable at DRAFT but REQUIRED before ACTIVATE (§E4,
// AMD-12 named-missing-parameter refusal) — enforced in service code, not a
// DB NOT NULL, since a mandate must be draftable before that election is
// made.
model NdMandateAccount {
  id                           String                     @id @default(uuid()) @db.Uuid
  mandateRef                   String                     @unique @map("mandate_ref")
  ledgerEntityCode             String                     @map("ledger_entity_code")
  participantType              NdMandateParticipantType   @map("participant_type")
  investorId                   String?                    @map("investor_id")
  participantLedgerEntityCode  String?                    @map("participant_ledger_entity_code")
  sharingMode                  NdMandateSharingMode       @map("sharing_mode")
  investorRatio                Decimal?                   @map("investor_ratio") @db.Decimal(6, 4)
  mudaribRatio                 Decimal?                   @map("mudarib_ratio") @db.Decimal(6, 4)
  wakalahFeeRatePa             Decimal?                   @map("wakalah_fee_rate_pa") @db.Decimal(6, 4)
  surplusTreatment             NdMandateSurplusTreatment? @map("surplus_treatment")
  sharedRatio                  Decimal?                   @map("shared_ratio") @db.Decimal(6, 4)
  targetReturnPct              Decimal?                   @map("target_return_pct") @db.Decimal(6, 4)
  status                       NdMandateStatus            @default(DRAFT)
  startDate                    DateTime                   @map("start_date")
  maturityDate                 DateTime?                  @map("maturity_date")
  // Invariant 43(a) (CHECK10): the ND Mandate engine was built as a
  // per-account SHARING computation engine ("no pooling") -- capital was
  // never persisted as mandate state, only ever passed transiently as a
  // parameter into computeWakalah/computeMudarabahPsr calls. That made
  // "Total AUM must include all product types" structurally impossible to
  // fix without this field: the committed amount already flows through
  // SubscriptionService (SubscriptionRequest.amountKobo) at approval time
  // but was being discarded rather than stored. Nullable because
  // participantType=FUND/POOL mandates (inter-entity, invariant 6a) don't
  // have an investor-side capital figure the same way -- their AUM lives
  // on the participant entity's own books, not here.
  committedCapitalKobo         BigInt?                    @map("committed_capital_kobo")
  createdByUserId              String                     @map("created_by_user_id") @db.Uuid
  createdAt                    DateTime                   @default(now()) @map("created_at")
  // Invariant 42(c) (CHECK9): createMandate opens this workflow instance
  // (ND_MANDATE_ACTIVATION, initiated by the creator); activateMandate can
  // only proceed by calling workflow.approveNextStep against it, which
  // enforces maker!=checker structurally -- the same "through the workflow
  // engine" pattern as JournalEntry.postingWorkflowInstanceId. Nullable
  // only because it's set in the same create() call it's declared for
  // (never actually null once createMandate returns).
  activationWorkflowInstanceId String?                    @unique @map("activation_workflow_instance_id") @db.Uuid
  // Invariant 65(a) (CHECK18): set in the SAME FA deposit-confirmation
  // step as targetReturnPct/maturityDate above (invariant 62h).
  profitPaymentInterval        ProfitPaymentInterval?     @map("profit_payment_interval")

  ledgerEntity           LedgerEntity                  @relation(fields: [ledgerEntityCode], references: [code])
  investor               Investor?                     @relation(fields: [investorId], references: [investorId])
  createdBy              AppUser                       @relation(fields: [createdByUserId], references: [id])
  activationWorkflow     WorkflowInstance?             @relation(fields: [activationWorkflowInstanceId], references: [id])
  provisionalAccruals    NdMandateProvisionalAccrual[]
  distributionLines      DistributionLineItem[]
  certificates           Certificate[]
  letterInstances        LetterInstance[]
  payoutCompilationLines PayoutCompilationLine[]

  @@map("nd_mandate_account")
}

enum NdMandateParticipantType {
  INVESTOR
  FUND
  POOL

  @@map("nd_mandate_participant_type")
}

enum NdMandateSharingMode {
  MUDARABAH_PSR
  WAKALAH

  @@map("nd_mandate_sharing_mode")
}

enum NdMandateSurplusTreatment {
  CLIENT_ALL
  AGENT_RETAINS
  SHARED

  @@map("nd_mandate_surplus_treatment")
}

enum NdMandateStatus {
  DRAFT
  ACTIVE
  MATURED
  CLOSED

  @@map("nd_mandate_status")
}

// F-ND-03 (§E7): daily provisional accrual, auto-reversed and trued on
// actual declaration — NEVER a distribution basis (BR-PAE-01 unchanged).
model NdMandateProvisionalAccrual {
  id                    String                     @id @default(uuid()) @db.Uuid
  ndMandateAccountId    String                     @map("nd_mandate_account_id") @db.Uuid
  accrualDate           DateTime                   @map("accrual_date") @db.Date
  capitalKobo           BigInt                     @map("capital_kobo")
  expectedRatePct       Decimal                    @map("expected_rate_pct") @db.Decimal(6, 4)
  provisionalAmountKobo BigInt                     @map("provisional_amount_kobo")
  status                NdMandateProvisionalStatus @default(PROVISIONAL)
  trueUpJournalRef      String?                    @map("true_up_journal_ref")
  reversedAt            DateTime?                  @map("reversed_at")
  createdAt             DateTime                   @default(now()) @map("created_at")

  ndMandateAccount NdMandateAccount @relation(fields: [ndMandateAccountId], references: [id])

  @@unique([ndMandateAccountId, accrualDate])
  @@map("nd_mandate_provisional_accrual")
}

enum NdMandateProvisionalStatus {
  PROVISIONAL
  REVERSED
  TRUED_UP

  @@map("nd_mandate_provisional_status")
}

// ==========================================================================
// TPL_13 Shariah Governance (Mandatory Integrity Review correction 21a-ii).
// Four record types share one flat CSV shape (record_type discriminator,
// generic columns reinterpreted per type — same convention as every other
// TPL); promoted here into four purpose-built tables rather than one
// generic row, since each has genuinely distinct downstream consumers
// (SSB register screens, purification/charity ledger, compliance tracker
// feeding SC-001..010 config). RES-2025-003 is the AMD-03R/AMD-12
// attachment evidence for the pool parameter seed — linked to
// ProductParameters.ssbResolutionRef by matching ref string, not an FK
// (that field predates this register and is intentionally a plain string).
// ==========================================================================
model SsbMember {
  id                 String    @id @default(uuid()) @db.Uuid
  memberRef          String    @unique @map("member_ref")
  name               String
  credentials        String?
  status             String    @default("ACTIVE")
  effectiveFrom      DateTime? @map("effective_from") @db.Date
  migrationSourceRef String?   @unique @map("migration_source_ref")
  createdAt          DateTime  @default(now()) @map("created_at")

  resolutions      SsbResolution[]
  complianceChecks ComplianceCheck[]

  @@map("ssb_member")
}

model SsbResolution {
  id                 String    @id @default(uuid()) @db.Uuid
  resolutionRef      String    @unique @map("resolution_ref")
  resolutionDate     DateTime? @map("resolution_date") @db.Date
  proposedByMemberId String?   @map("proposed_by_member_id") @db.Uuid
  summary            String
  standardApplied    String?   @map("standard_applied")
  voteResult         String?   @map("vote_result")
  effectiveDate      DateTime? @map("effective_date") @db.Date
  status             String    @default("APPROVED")
  documentRef        String?   @map("document_ref")
  notes              String?
  migrationSourceRef String?   @unique @map("migration_source_ref")
  createdAt          DateTime  @default(now()) @map("created_at")

  proposedByMember SsbMember? @relation(fields: [proposedByMemberId], references: [id])

  @@map("ssb_resolution")
}

model PurificationRecord {
  id                 String    @id @default(uuid()) @db.Uuid
