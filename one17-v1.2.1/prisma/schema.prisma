// ==========================================================================
// Phase 4 §1: KRI engine (CLAUDE.md invariant 16, Phase4 Directive §1).
// kri_definitions seeds the C6 authoritative roster (29 instrumented + 11
// reserved = 40) plus platform-added rows ruled in separately (Hibah,
// Pool Servicing Cost Ratio, provisional-accrual aging, capital-transition).
// Only a subset carries REAL computation this pass (computeStatus =
// INSTRUMENTED); the rest load NOT_YET_INSTRUMENTED/RESERVED — "N/A", never
// a fake green, per the ERM v2.0 changelog standard this spec itself cites.
// ==========================================================================
model KriDefinition {
  code                    String                @id
  name                    String
  category                String
  direction               RiskAppetiteDirection
  isZeroTolerance         Boolean               @default(false) @map("is_zero_tolerance")
  // Nullable: not every KRI maps to one of the matrix's 13 rows (e.g. Hibah
  // frequency is informational, not RAG-banded against an appetite
  // statement) — see riskCategory matching notes in kri-engine.service.ts.
  riskAppetiteCategoryRef String?               @map("risk_appetite_category_ref")
  computeStatus           KriComputeStatus      @default(NOT_YET_INSTRUMENTED) @map("compute_status")
  notes                   String?
  createdAt               DateTime              @default(now()) @map("created_at")

  readings KriReading[]

  @@map("kri_definition")
}

enum KriComputeStatus {
  INSTRUMENTED
  NOT_YET_INSTRUMENTED
  RESERVED

  @@map("kri_compute_status")
}

enum KriRagStatus {
  GREEN
  AMBER
  RED
  AWAITING_MATRIX
  NOT_INSTRUMENTED
  INFORMATIONAL

  @@map("kri_rag_status")
}

// Yearly-partitioned per CLAUDE.md Stack Decisions ("yearly partitions on
// audit_trail and kri_readings") — hand-authored migration, same pattern as
// audit_trail (see 20260704000000_init_audit_trail). Invariant 11 /
// amendment 25e: compute per ledger entity, THEN aggregate with labels —
// isAggregate distinguishes the rolled-up row from its per-entity inputs,
// both live in this one table so a dashboard query never has to guess.
model KriReading {
  id               String       @default(uuid()) @db.Uuid
  kriCode          String       @map("kri_code")
  ledgerEntityCode String?      @map("ledger_entity_code")
  isAggregate      Boolean      @default(false) @map("is_aggregate")
  readingDate      DateTime     @map("reading_date") @db.Date
  value            Decimal?     @db.Decimal(24, 6)
  ragStatus        KriRagStatus @map("rag_status")
  matrixVersionId  String?      @map("matrix_version_id") @db.Uuid
  detail           Json?
  computedAt       DateTime     @default(now()) @map("computed_at")

  definition KriDefinition @relation(fields: [kriCode], references: [code])

  // Partitioned by reading_date (yearly, hand-authored migration) — Postgres
  // requires the partition key in every unique/primary key, hence the
  // composite id, same pattern as audit_trail's (id, occurred_at).
  @@id([id, readingDate])
  @@map("kri_reading")
}

// Invariant "RED reading -> escalation row + notification within 5 minutes".
// This build has no real scheduler/notification transport (same honestly-
// documented limitation as every other "batch job" in this codebase, which
// are all *.run.ts scripts, not cron) — the escalation ROW is written
// synchronously as part of the same computation that produced the RED
// reading, which is the part that's actually testable; notifiedAt stays
// null until a real notification channel exists. kriReadingId is a plain
// reference (no DB FK): Postgres requires every unique/PK index on a
// partitioned table to include its partition key, so kri_reading's (id,
// reading_date) composite PK cannot be FK-referenced by id alone — the same
// reason nothing FK-references audit_trail either.
model KriEscalation {
  id               String       @id @default(uuid())
  kriReadingId     String       @map("kri_reading_id")
  kriCode          String       @map("kri_code")
  ledgerEntityCode String?      @map("ledger_entity_code")
  ragStatus        KriRagStatus @map("rag_status")
  ownerLabel       String?      @map("owner_label")
  escalatedAt      DateTime     @default(now()) @map("escalated_at")
  notifiedAt       DateTime?    @map("notified_at")

  @@map("kri_escalation")
}

// Singleton config (id=1) — same "editable operational config, not a full
// Board-workflow-gated version" pattern as AuthPolicy/BudgetVarianceRag
// Threshold in this codebase. PART E §E7's aging KRI names this "config
// threshold" without prescribing its home; this is the lightest-weight
// honest home for it (a real row, never a hardcoded literal in code).
model KriEngineConfig {
  id                          Int      @id @default(1)
  provisionalAccrualAgingDays Int      @default(30) @map("provisional_accrual_aging_days")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("kri_engine_config")
}

// Invariant 13 / C3 finding 4: SEC capital requirement is real governed
// data (₦150m now, ₦2bn from Jun-2027 per the funding-plan milestones), not
// a hardcoded literal — versioned, effective-dated rows; "active" = latest
// effectiveFrom <= today. Feeds TR-03 CAR / TR-04 Capital Surplus.
model RegulatoryCapitalRequirement {
  id              String   @id @default(uuid())
  requirementKobo BigInt   @map("requirement_kobo")
  effectiveFrom   DateTime @map("effective_from") @db.Date
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("regulatory_capital_requirement")
}

// ==========================================================================
// Phase 4 §2: six stress models as parameterized services. ALL scenario
// magnitudes (redemption %, delay days, expense surge, shock matrices,
// client-loss factors, AUM-decline %, fee compression) live in `parameters`
// JSONB here — zero literals in the service code (DQ-11/13, invariant 10;
// CHECK4 adversarial: grep for scenario literals = zero findings). Amendment
// 27: baseline scenario definitions are Board-governed (RSK proposes -> CEO
// endorses -> Board/Risk Committee approves, same shape as
// RiskAppetiteMatrixVersion); ad-hoc "what-if" edits run in SANDBOX without
// touching these rows.
// ==========================================================================
model StressScenarioConfig {
  id                 String             @id @default(uuid()) @db.Uuid
  modelType          StressModelType    @map("model_type")
  scenarioCode       String             @map("scenario_code")
  scenarioLabel      String             @map("scenario_label")
  version            Int
  status             StressConfigStatus @default(DRAFT)
  parameters         Json
  boardResolutionRef String?            @map("board_resolution_ref")
  proposedByUserId   String?            @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?            @map("approved_by_user_id") @db.Uuid
  effectiveFrom      DateTime?          @map("effective_from")
  createdAt          DateTime           @default(now()) @map("created_at")

  @@unique([modelType, scenarioCode, version])
  @@map("stress_scenario_config")
}

enum StressModelType {
  LIQUIDITY
  CAPITAL_ADEQUACY
  REVENUE_SENSITIVITY
  COUNTERPARTY_DEFAULT
  PORTFOLIO_SHOCK
  REVERSE_STRESS

  @@map("stress_model_type")
}

enum StressConfigStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("stress_config_status")
}

// SANDBOX mode (C2 amendment 27): ad-hoc runs are DRAFT/UNAPPROVED and never
// touch the approved baseline; publishing a baseline requires the
// STRESS_BASELINE_PUBLICATION workflow (isApprovedBaseline flips true only
// on APPROVE). Every run persists inputs+outputs verbatim for audit replay.
model StressTestRun {
  id                         String          @id @default(uuid()) @db.Uuid
  modelType                  StressModelType @map("model_type")
  runMode                    StressRunMode   @map("run_mode")
  ledgerEntityCode           String          @map("ledger_entity_code")
  scenarioConfigId           String?         @map("scenario_config_id") @db.Uuid
  inputs                     Json
  outputs                    Json
  ranByUserId                String          @map("ran_by_user_id") @db.Uuid
  ranAt                      DateTime        @default(now()) @map("ran_at")
  isApprovedBaseline         Boolean         @default(false) @map("is_approved_baseline")
  approvalWorkflowInstanceId String?         @unique @map("approval_workflow_instance_id") @db.Uuid

  @@map("stress_test_run")
}

enum StressRunMode {
  SANDBOX
  BASELINE_CANDIDATE
  BASELINE

  @@map("stress_run_mode")
}

// ==========================================================================
// CHECK5 item 1: dashboard reconciliation against the real ERM workbook
// extracts (Workbook_Extracts/ERM_Engine/11_CEO_Dashboard + 12_Board_
// Dashboard). Several CEO/Board fields are, in the SOURCE workbook itself,
// plain manual input cells ('02_Assumptions'!C46/C47/C48 — not formulas) —
// Regulatory Filings, Shariah SSB Compliance, Operational Risk status, plus
// the Reputational risk category which the source explicitly annotates
// "Manual input — no live model yet." This table is the honest home for
// those fields: a governed, editable status, never a fabricated live
// computation for something the source itself doesn't compute either.
// ==========================================================================
model DashboardManualStatus {
  id                           Int      @id @default(1)
  regulatoryFilingsStatus      String   @default("GREEN") @map("regulatory_filings_status")
  shariahSsbComplianceStatus   String   @default("GREEN") @map("shariah_ssb_compliance_status")
  operationalRiskStatus        String   @default("GREEN") @map("operational_risk_status")
  kycComplianceStatus          String   @default("GREEN") @map("kyc_compliance_status")
  amlStatus                    String   @default("GREEN") @map("aml_status")
  reputationalRiskScore        Int      @default(1) @map("reputational_risk_score")
  reputationalRagStatus        String   @default("GREEN") @map("reputational_rag_status")
  secInspectionReadinessStatus String   @default("GREEN") @map("sec_inspection_readiness_status")
  // Source: CEO Dashboard "Revenue Sensitivity — AUM Growth Needed" =
  // MAX(0, 500,000,000 - AUM) — the ₦500m target is a literal in the
  // source formula; here it's governed config instead (invariant 10).
  growthTargetAumKobo          BigInt   @default(50000000000) @map("growth_target_aum_kobo")
  updatedAt                    DateTime @updatedAt @map("updated_at")
  updatedByUserId              String?  @map("updated_by_user_id") @db.Uuid

  @@map("dashboard_manual_status")
}

// Invariant 43(a) (CHECK10): the governed metric definition catalog. Every
// dashboard/report metric gets a versioned row here BEFORE it ships --
// name, business meaning, exact source tables/joins, inclusion/exclusion
// rules, owner, ledger-reconcilable Y/N. "No metric ships without one" is
// the standing rule; DashboardService reads FROM these definitions'
// documented behavior (this table doesn't drive computation itself --
// it's the governed RECORD of what each metric means, so a reviewer can
// check the code against a written definition rather than reverse-
// engineering intent from a query).
model MetricDefinition {
  id                      String             @id @default(uuid()) @db.Uuid
  metricCode              String             @map("metric_code")
  version                 Int
  displayLabel            String             @map("display_label")
  screenCode              String             @map("screen_code")
  businessMeaning         String             @map("business_meaning")
  sourceTablesAndJoins    String             @map("source_tables_and_joins")
  inclusionExclusionRules String             @map("inclusion_exclusion_rules")
  ownerRoleCode           String             @map("owner_role_code")
  ledgerReconcilable      Boolean            @map("ledger_reconcilable")
  status                  GovernedItemStatus @default(ACTIVE)
  supersededByMetricId    String?            @map("superseded_by_metric_id") @db.Uuid
  createdByUserId         String             @map("created_by_user_id") @db.Uuid
  createdAt               DateTime           @default(now()) @map("created_at")

  // Invariant 73(a) (CHECK27): Dashboard Composer eligibility. Both null =
  // documentation-only row (the pre-existing CEO_DASHBOARD.* rows, already
  // consumed by their own hand-built dashboard service, never composer-
  // pickable). Both set = composer-eligible: requiredFunctionCode is the
  // VIEW-level capability gate checked at BOTH compose time (picker filter)
  // and render time (never trust a saved tile's config), mirroring
  // DataPointCatalog.requiredFunctionCode's same "config carries the gate,
  // code enforces it" precedent (invariant 57b(v)). composerResolverKey is
  // a key into DashboardComposerService's own small, explicit, hand-
  // maintained resolver whitelist -- never a free-form query -- matching
  // One17AIService.LIVE_QUERY_RESOLVERS' identical shape.
  requiredFunctionCode String? @map("required_function_code")
  composerResolverKey  String? @map("composer_resolver_key")

  createdBy AppUser @relation(fields: [createdByUserId], references: [id])

  @@unique([metricCode, version])
  @@map("metric_definition")
}

enum DashboardScope {
  PERSONAL
  DEPARTMENT

  @@map("dashboard_scope")
}

enum TilePresentation {
  KPI_TILE
  TREND_LINE
  PIE
  BAR
  TABLE

  @@map("tile_presentation")
}

// Invariant 73(a) (CHECK27): a staff-composed dashboard. PERSONAL is the
// composer's own view; DEPARTMENT publishes to orgUnitCode (gated on a
// manage-dashboards capability held by HoD/chief seats -- no HoD FK exists
// on OrgUnit, so department-publish authority is a standing capability
// grant, not a live "are you the head of X" lookup). No approval workflow
// (a view moves no money, per the CEO's own wording) -- every create/edit/
// publish is audit-logged instead.
model SavedDashboard {
  id          String         @id @default(uuid()) @db.Uuid
  name        String
  scope       DashboardScope
  ownerUserId String         @map("owner_user_id") @db.Uuid
  orgUnitCode String?        @map("org_unit_code")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  owner AppUser         @relation(fields: [ownerUserId], references: [id])
  tiles DashboardTile[]

  @@map("saved_dashboard")
}

// metricCode is a plain string, deliberately not an FK into
// MetricDefinition — that catalog is versioned (metricCode + version is
// the real unique key), so a tile resolves "whichever version is
// currently ACTIVE" at render time, the same pattern
// ReconciliationService.reconcile() already uses
// (findFirst({metricCode, status: 'ACTIVE'}, orderBy: {version: 'desc'}))
// rather than pinning a tile to one specific historical version row.
model DashboardTile {
  id           String           @id @default(uuid()) @db.Uuid
  dashboardId  String           @map("dashboard_id") @db.Uuid
  metricCode   String           @map("metric_code")
  presentation TilePresentation
  position     Int
  createdAt    DateTime         @default(now()) @map("created_at")

  dashboard SavedDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@map("dashboard_tile")
}

// Invariant 43(b) (CHECK10): "money metrics marked ledger-reconcilable get
// an automated recon: operational-table figure vs ledger balance, variance
// surfaced as a visible recon tile + KRI-style alert on breach (tolerance
// in governed config)." This table IS that governed config -- versioned
// like MetricDefinition/RiskAppetiteMatrixVersion, insert-only. A row here
// only takes effect once its metricCode's MetricDefinition is ALSO marked
// ledgerReconcilable=true; ReconciliationService.reconcile() checks both.
// glAccountCodes names the chart_of_accounts rows (by account_code, scoped
// to ledgerEntityCode when given) whose posted balance represents this
// metric's ledger-side truth. No row currently exists ACTIVE for any
// metric -- see QUESTIONS_FOR_REVIEW.md: activating one against a metric
// whose ledger coverage is known-incomplete (pre-CHECK11) would produce a
// permanent, non-actionable breach rather than a genuine control, so this
// is left for FinCon/CEO to activate once CHECK11 journal wiring closes
// the known gaps.
model LedgerReconciliationConfig {
  id               String             @id @default(uuid()) @db.Uuid
  metricCode       String             @map("metric_code")
  version          Int
  ledgerEntityCode String?            @map("ledger_entity_code")
  glAccountCodes   String[]           @map("gl_account_codes")
  toleranceKobo    BigInt             @map("tolerance_kobo")
  status           GovernedItemStatus @default(DRAFT)
  createdByUserId  String             @map("created_by_user_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")

  createdBy    AppUser       @relation(fields: [createdByUserId], references: [id])
  ledgerEntity LedgerEntity? @relation(fields: [ledgerEntityCode], references: [code])

  @@unique([metricCode, version])
  @@map("ledger_reconciliation_config")
}

// BOARD PANEL 1 — Enterprise Risk Profile. Inherent score is explicitly
// "Board judgement" in the source (not a formula) — governed config here
// too; Residual/RAG/Trend are computed live from the matching KRIs' latest
// readings (see dashboard.service.ts's category-group aggregation), never
// stored.
model EnterpriseRiskProfileEntry {
  id            String   @id @default(uuid()) @db.Uuid
  riskCategory  String   @unique
  inherentScore Int
  sortOrder     Int
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("enterprise_risk_profile_entry")
}

// PANEL 6 / ACTION TRACKER: the source workbook's own content for these two
// panels is plain manually-typed text, not a formula — confirmed by reading
// 11_CEO_Dashboard_FORMULAS.csv.csv and 12_Board_Dashboard_FORMULAS.csv.csv
// directly (the cells contain literal strings, not "="-prefixed formulas).
// This is a lightweight content register, not a workflow-derived feed.
model DashboardActionItem {
  id        String   @id @default(uuid()) @db.Uuid
  audience  String // CEO | BOARD
  title     String
  detail    String
  owner     String
  dueLabel  String   @map("due_label")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dashboard_action_item")
}

// ==========================================================================
// CHECK5 item 2: Regulatory Reporting module (invariant 22, spec §2). Fills
// the AMD-11 `regulator_template` registry (already exists, ships empty)
// with the file-level rendering concern the original AMD-11 pass didn't
// need: template_cell_map (XLSX, in-place fill) and template_field_map
// (PDF, AcroForm or coordinate overlay — the SEC layout is NEVER redrawn).
// sourceKey is a SYMBOLIC key, never a raw expression/SQL string — the
// resolver (RegulatoryReportingService) maps a small, documented, code-
// reviewed set of keys to live queries, same "config carries the
// vocabulary, code carries the resolution" split as event_journal_config's
// account-code mapping. This keeps AUTO cells config-not-code (invariant
// 10/15) without opening an expression-injection surface.
// ==========================================================================
enum CellClass {
  AUTO
  ENTRY
  STATIC

  @@map("cell_class")
}

model TemplateCellMap {
  id                  String    @id @default(uuid()) @db.Uuid
  regulatorTemplateId String    @map("regulator_template_id") @db.Uuid
  sheetName           String    @map("sheet_name")
  cellAddress         String    @map("cell_address")
  label               String?
  cellClass           CellClass @map("cell_class")
  sourceKey           String?   @map("source_key")
  staticValue         String?   @map("static_value")
  mapVersion          Int       @default(1) @map("map_version")
  createdAt           DateTime  @default(now()) @map("created_at")

  regulatorTemplate RegulatorTemplate @relation(fields: [regulatorTemplateId], references: [id])

  @@unique([regulatorTemplateId, sheetName, cellAddress, mapVersion])
  @@map("template_cell_map")
}

// PDF equivalent — fieldName for AcroForm-bearing PDFs; xPt/yPt/widthPt/
// heightPt for flat PDFs needing a text overlay (spec §2.1: "visual click-
// to-place calibration in ops UI, stored as config").
model TemplateFieldMap {
  id                  String    @id @default(uuid()) @db.Uuid
  regulatorTemplateId String    @map("regulator_template_id") @db.Uuid
  page                Int
  fieldName           String?   @map("field_name")
  xPt                 Float?    @map("x_pt")
  yPt                 Float?    @map("y_pt")
  fontSizePt          Float?    @default(9) @map("font_size_pt")
  label               String?
  cellClass           CellClass @map("cell_class")
  sourceKey           String?   @map("source_key")
  staticValue         String?   @map("static_value")
  mapVersion          Int       @default(1) @map("map_version")
  createdAt           DateTime  @default(now()) @map("created_at")

  regulatorTemplate RegulatorTemplate @relation(fields: [regulatorTemplateId], references: [id])

  @@unique([regulatorTemplateId, page, fieldName, mapVersion])
  @@map("template_field_map")
}

// Spec §2 item 4: template x entity x frequency x deadline rule. Feeds the
// Compliance dashboard "due this week" queue and, once overdue, flips
// KRI-CPL-01 (Open Regulatory Breaches) RED automatically.
model RegulatoryFilingCalendar {
  id                  String   @id @default(uuid()) @db.Uuid
  regulatorTemplateId String   @map("regulator_template_id") @db.Uuid
  ledgerEntityCode    String   @map("ledger_entity_code")
  frequency           String
  deadlineDayOfMonth  Int?     @map("deadline_day_of_month")
  deadlineRule        String?  @map("deadline_rule")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")

  regulatorTemplate RegulatorTemplate @relation(fields: [regulatorTemplateId], references: [id])

  @@map("regulatory_filing_calendar")
}

// Spec §2 item 3: the immutable per-submission snapshot. `figures` holds
// every resolved cell/field value (AUTO-computed at generation time +
// ENTRY values as typed) keyed by map id — the exact numbers the exported
// file was built from, frozen the moment CO submits for certification.
model RegulatoryFilingRun {
  id                  String                 @id @default(uuid()) @db.Uuid
  regulatorTemplateId String                 @map("regulator_template_id") @db.Uuid
  ledgerEntityCode    String                 @map("ledger_entity_code")
  periodStart         DateTime               @map("period_start")
  periodEnd           DateTime               @map("period_end")
  status              RegulatoryFilingStatus @default(DRAFT)
  figures             Json
  preparedByUserId    String                 @map("prepared_by_user_id") @db.Uuid
  certifiedByUserId   String?                @map("certified_by_user_id") @db.Uuid
  workflowInstanceId  String?                @unique @map("workflow_instance_id") @db.Uuid
  secPortalAckRef     String?                @map("sec_portal_ack_ref")
  submittedAt         DateTime?              @map("submitted_at")
  generatedAt         DateTime               @default(now()) @map("generated_at")

  regulatorTemplate RegulatorTemplate @relation(fields: [regulatorTemplateId], references: [id])

  @@map("regulatory_filing_run")
}

enum RegulatoryFilingStatus {
  DRAFT
  ENTRY_IN_PROGRESS
  SUBMITTED_FOR_CERTIFICATION
  CERTIFIED
  FILED

  @@map("regulatory_filing_status")
}

// ============================================================================
// CHECK5 item 3 — Wealth Management v1.1 (invariant 23, spec
// One17_Wealth_Management_Spec_v1.md §2/§7/§6a). PRIME BOUNDARY (§1,
