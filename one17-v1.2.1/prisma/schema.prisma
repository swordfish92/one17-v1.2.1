  // Item 4a (HTTP + Auth layer, CLAUDE.md Stack Decisions): argon2id hash;
  // nullable because every user seeded before this pass has no password yet
  // (service-level access only) — a null hash can never authenticate (see
  // AuthService.login, which checks for null before verifying).
  passwordHash        String?    @map("password_hash")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  // Invariant 68(c) H-02 (CHECK22 v1.0.1 remediation): TOTP MFA, staff
  // realm only (portal MFA is roadmap/Phase-2 mobile biometrics per the
  // charter). totpSecret is set the moment enrollment BEGINS (unconfirmed
  // — a scanned-but-not-yet-verified QR code); mfaEnabledAt is set only
  // once the user proves possession by submitting one valid code, and is
  // the actual "MFA is ON for this account" flag everywhere else in the
  // codebase checks.
  totpSecret          String?    @map("totp_secret")
  mfaEnabledAt        DateTime?  @map("mfa_enabled_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  sessions       UserSession[]
