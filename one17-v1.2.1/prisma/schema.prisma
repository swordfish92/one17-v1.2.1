enum UserStatus {
  ACTIVE
  SUSPENDED

  @@map("user_status")
}

// Item 4a (HTTP + Auth layer): DB-backed server session, per CLAUDE.md
// Stack Decisions — the cookie holds only an opaque random token; this row
// stores a SHA-256 hash of it (tokenHash), never the token itself, so a DB
// read alone can't be replayed as a session. Revocation is immediate
// (revokedAt set, no separate blocklist needed) — same "unilateral emergency
// stop" reasoning as DelegationService's revoke path (invariant 9a).
model UserSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  // Invariant 68(c) H-02: true from the moment a password check succeeds
  // for an MFA-applicable user until the second factor is verified — the
  // session cookie exists (so the client can call the MFA endpoints
  // themselves) but SessionAuthGuard rejects every OTHER route while this
  // is true (see @AllowMfaPending()). Cleared (false) + expiresAt
  // extended to the full policy TTL only by MfaService.verifyCode()
  // succeeding.
  mfaPending Boolean   @default(false) @map("mfa_pending")

  user AppUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_session")
}

// Invariant 68(c) H-02: single-use recovery codes issued once, at TOTP
// enrollment confirmation (10 codes) — the standard fallback for a lost
// authenticator device. Hashed at rest (argon2id, same as passwordHash)
// since a leaked backup-code table is otherwise a direct MFA bypass.
model MfaBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user AppUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("mfa_backup_code")
}

// Invariant 68(c) H-02: "enforcement tiers in governed config" — the
// MANDATORY floor itself (SUPER_ADMIN, MD_CEO) is fixed in code
// (MfaService.MANDATORY_ROLE_CODES), not configurable away by an admin
// action; this table governs the EXPANSION of that floor to every role
// that holds APPROVE on a function the platform owner has tagged
// financial (park-don't-invent: starts with a reviewed seed set per
// CHECK22_EVIDENCE.md, growable without a code change).
model MfaFinancialCapability {
  functionCode  String   @id @map("function_code")
  addedByUserId String   @map("added_by_user_id") @db.Uuid
  addedAt       DateTime @default(now()) @map("added_at")

  @@map("mfa_financial_capability")
}

// Invariant 68(c) H-02: "optional-until-flipped for the rest" — the
// global switch a SUPER_ADMIN can flip later to make MFA mandatory for
// every staff seat, not just the two fixed tiers + financial-approval
// holders. Singleton (id always 1), off by default at go-live per the
// charter's own default framing.
model MfaGlobalEnforcement {
  id                Int      @id @default(1)
  allStaffMandatory Boolean  @default(false) @map("all_staff_mandatory")
  updatedByUserId   String?  @map("updated_by_user_id") @db.Uuid
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("mfa_global_enforcement")
}

// Singleton config row (id=1) — password/lockout/session policy is
// governed config per invariant 10 (no hardcoded thresholds), but this is
// an ops/security setting, not Board/SSB-governed content, so it is a
// plain editable row rather than a versioned-approval-workflow table like
// RiskAppetiteMatrixVersion. mfaRequired is a config slot to enforce MFA
// later without a migration (CLAUDE.md Stack Decisions item 2).
model AuthPolicy {
  id                Int      @id @default(1)
  maxFailedAttempts Int      @default(5) @map("max_failed_attempts")
  lockoutMinutes    Int      @default(15) @map("lockout_minutes")
  sessionTtlMinutes Int      @default(480) @map("session_ttl_minutes")
  minPasswordLength Int      @default(12) @map("min_password_length")
  mfaRequired       Boolean  @default(false) @map("mfa_required")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("auth_policy")
}

// code is the natural key (SRS §3.1 MVP: SUPER_ADMIN, MD_CEO, PORT_MGR,
// PORT_OFF, FIN_ADMIN, COMPLIANCE, SHARIAH_REV, INVESTOR, AUDITOR) — plain
// string, not enum, so a 10th role (BD, RSK, OPS, HR, CS, FINCON, SAU,
// Board/Committee, ...) is a data row, not a schema change.
//
// isExclusive / excludesAnyApprover generalize what step 3 originally wrote
// as hard-coded string checks (roleCode === 'ADM', roleCode === 'OPS') into
// data, per CLAUDE.md: "the RBAC engine itself must not hard-code any role
// name." See RbacService.findConflictReason.
model Role {
  code                String  @id
  name                String
  description         String?
  // Holding this role excludes holding any other role, in either direction
  // (SRS §3.3: "Super Admin cannot approve financial transactions ...
  // separated at database level" — modeled here rather than as a string
  // check so a future exclusive role needs no code change).
  isExclusive         Boolean @default(false) @map("is_exclusive")
  // Holding this role excludes combining with ANY role that holds an
  // APPROVE permission on any function. Not used by the SRS MVP seed (SRS
  // has no such rule) — kept for when OPS-style roles return; see
  // Roles & Workflows §3 rule 1 for the rule this generalizes.
  excludesAnyApprover Boolean @default(false) @map("excludes_any_approver")
  // AMD-09 §4d: "Auditor-class roles (SAU, AUDITOR) are structurally
  // read-only — the engine refuses write permissions mapped to them." Data,
  // not a role-name check — enforced by a hand-authored DB trigger on
  // RolePermission (see the AMD-09 migration): any role flagged isReadOnly
  // can only ever hold VIEW-level permissions.
  isReadOnly          Boolean @default(false) @map("is_read_only")

  userRoles    UserRole[]
  permissions  RolePermission[]
  conflictsAsA RoleConflict[]   @relation("ConflictRoleA")
  conflictsAsB RoleConflict[]   @relation("ConflictRoleB")

  @@map("role")
}

// One user, many roles (§0 design reality: "one person may hold multiple
// roles"). assignedBy is nullable only for the bootstrap seed; every
// subsequent assignment must carry a real actor for the audit trail.
model UserRole {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  roleCode     String   @map("role_code")
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById String?  @map("assigned_by_id") @db.Uuid

  user       AppUser  @relation("UserRoles", fields: [userId], references: [id])
  role       Role     @relation(fields: [roleCode], references: [code])
  assignedBy AppUser? @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, roleCode])
  @@map("user_role")
}

// Permission matrix rows (SRS §3.2 module column, e.g. INVESTOR_ONBOARDING,
// DISTRIBUTION_APPROVAL, JOURNAL_ENTRIES). code is a natural key, not an
// enum, for the same "matrix is data" reason as Role.
model PlatformFunction {
  code        String  @id
  description String?

  permissions       RolePermission[]
  approvalSteps     ApprovalRuleStep[]
  initiatorForRules ApprovalRule[]
  delegations       DelegationOfAuthority[]

  @@map("platform_function")
}

// One row per (role, function, level) cell in the matrix that isn't "—".
// A role can hold more than one level on the same function (e.g. a role
// holding both APPROVE and VIEW on the same row in the source matrix).
model RolePermission {
  roleCode          String          @map("role_code")
  functionCode      String          @map("function_code")
  level             PermissionLevel
  // Footnote conditions from the matrix (e.g. "own records only") — free
  // text, not enforced in code yet.
  condition         String?
  // Monetary ceiling on this role's STANDING APPROVE authority for this
  // function, in kobo (invariant #2: BIGINT kobo everywhere). NULL = no
  // ceiling. This is the default/baseline; CEO instruction 2026-07-04:
  // approval limits must be governed by Delegation of Authority, not fixed
  // solely to a role, so the workflow engine also checks
  // DelegationOfAuthority for a time-bound override/grant before falling
  // back to this baseline — see WorkflowEngineService.isApproverEligible.
  approvalLimitKobo BigInt?         @map("approval_limit_kobo")

  role     Role             @relation(fields: [roleCode], references: [code])
  function PlatformFunction @relation(fields: [functionCode], references: [code])

  @@id([roleCode, functionCode, level])
  @@map("role_permission")
}

enum PermissionLevel {
  INITIATE
  APPROVE
  VIEW

  @@map("permission_level")
}

// Explicit named-pair conflicts that aren't derivable from Role.isExclusive
// or Role.excludesAnyApprover (e.g. a future PM+FA style rule once those
// roles exist). Empty for the current SRS MVP seed — SRS's only static
// conflict is SUPER_ADMIN exclusivity, already covered by isExclusive.
model RoleConflict {
  roleACode String @map("role_a_code")
  roleBCode String @map("role_b_code")
  reason    String

  roleA Role @relation("ConflictRoleA", fields: [roleACode], references: [code])
  roleB Role @relation("ConflictRoleB", fields: [roleBCode], references: [code])

  @@id([roleACode, roleBCode])
  @@map("role_conflict")
}

// Build Plan step 4 / SOW D4: the single initiate→verify→approve→execute→
// record machine, with the approval matrix (SRS §6.2) as configuration.
// "verify" (SRS's automated DC-01..08 style control checks) and the
// business effect of "execute" (posting a journal, releasing a payment)
// belong to the product/ledger modules that don't exist yet (Phase 2/3) —
// this engine owns sequencing, capability-based authorization, maker≠checker,
// and the audit trail of who decided what, when. Every workflow type reuses
// it; product-specific behavior is the ApprovalRule/ApprovalRuleStep data,
// not new engine code, per Build Plan's "configuration, not code."
model WorkflowType {
  code        String  @id
  description String?

  approvalRules         ApprovalRule[]
  approvalChainVersions ApprovalChainVersion[]
  instances             WorkflowInstance[]

  @@map("workflow_type")
}

// Invariant 54(e)(v) (CEO directive, 8-Jul-2026): the versioning SUBSTRATE
// for the future Approval Chain Editor (54(e)(i)-(iv), Wave 1/post-go-live —
// NOT built here). "Per workflow type — create/modify approval RULES and
// their ordered STEPS... propose (DRAFT, side-by-side diff of current vs
// proposed CHAIN) -> MD_CEO approval -> ACTIVE from a stated effective
// date; prior version retained." The versioning grain is the WHOLE rule set
// for one workflow type (its tier/scenario variants together), not a
// single ApprovalRule row — mirrors RiskAppetiteMatrixVersion's own
// wrapper-row-groups-children shape (version/status/proposedBy/approvedBy/
// workflowInstanceId/effectiveFrom), the established pattern for every
// other governed-versioned config in this codebase. Every ApprovalRule
// existing before this substrate landed is backfilled into a version-1
// ACTIVE row per workflowTypeCode (migration data step) so the substrate is
// genuinely consistent today, not just schema-shaped with null FKs.
model ApprovalChainVersion {
  id                 String              @id @default(uuid()) @db.Uuid
  workflowTypeCode   String              @map("workflow_type_code")
  version            Int
  status             ApprovalChainStatus @default(ACTIVE)
  proposedByUserId   String?             @map("proposed_by_user_id") @db.Uuid
  approvedByUserId   String?             @map("approved_by_user_id") @db.Uuid
  workflowInstanceId String?             @unique @map("workflow_instance_id") @db.Uuid
  effectiveFrom      DateTime?           @map("effective_from")
  createdAt          DateTime            @default(now()) @map("created_at")

  workflowType WorkflowType   @relation(fields: [workflowTypeCode], references: [code])
  proposedBy   AppUser?       @relation("ApprovalChainVersionProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy   AppUser?       @relation("ApprovalChainVersionApprovedBy", fields: [approvedByUserId], references: [id])
  rules        ApprovalRule[]

  @@unique([workflowTypeCode, version])
  @@map("approval_chain_version")
}

enum ApprovalChainStatus {
  DRAFT
  ACTIVE
  SUPERSEDED

  @@map("approval_chain_status")
}

// One row per distinct row of SRS §6.2's table: four amount-tiered rules
// (<₦1M, ₦1M–10M, >₦10M, and the amount-agnostic "Loss Scenario") plus
// "Penalty to Charity" as a named scenario with its own initiator/approver
// chain. minAmountKobo/maxAmountKobo select a rule by transaction amount;
// scenario selects a rule outside the amount-tier logic entirely (a rule
// row sets one selector or the other, not both).
model ApprovalRule {
  id                    String  @id @default(uuid()) @db.Uuid
  // M1 condition (closes D8): a stable natural key so seed.ts can `upsert`
  // instead of delete-and-recreate — the old pattern broke with a foreign
  // key violation the moment a real WorkflowInstance/WorkflowStepApproval
  // existed against a seeded rule. Nullable so pre-existing rows (seeded
  // before this column existed) are left alone rather than force-matched;
  // Postgres's UNIQUE allows multiple NULLs, so old rows coexist safely
  // with new ruleKey-upserted ones going forward — see M1_EVIDENCE.md D8.
  ruleKey               String? @unique @map("rule_key")
  workflowTypeCode      String  @map("workflow_type_code")
  // Invariant 54(e)(v): which ApprovalChainVersion this rule belongs to.
  // Required (not nullable) — every rule, seeded or future-edited, belongs
  // to exactly one chain version; resolveApprovalRule() only ever matches
  // against the ACTIVE version, so a future DRAFT chain never leaks into
  // live workflow initiation before its own approval lands.
  chainVersionId        String  @map("chain_version_id") @db.Uuid
  scenario              String?
  minAmountKobo         BigInt? @map("min_amount_kobo")
  maxAmountKobo         BigInt? @map("max_amount_kobo")
  // Capability required to call initiate() under this rule — a plain
  // string function code, not a role name, since e.g. "Penalty to Charity"
  // is initiated by FIN_ADMIN while standard distributions are initiated by
  // PORT_OFF/PORT_MGR (SRS §6.2): different rules, different capability.
  initiatorFunctionCode String  @map("initiator_function_code")
  requiredChecksNote    String? @map("required_checks_note")
  description           String?

  workflowType      WorkflowType         @relation(fields: [workflowTypeCode], references: [code])
  chainVersion      ApprovalChainVersion @relation(fields: [chainVersionId], references: [id])
  initiatorFunction PlatformFunction     @relation(fields: [initiatorFunctionCode], references: [code])
  steps             ApprovalRuleStep[]
  instances         WorkflowInstance[]

  @@map("approval_rule")
}

// One ordered step = one required capability (a PlatformFunction this
// step's approver must hold at APPROVE level), not a role name — this is
// what makes SRS §6.2's "Level 1 Approver" / "Level 2 Approver" columns
// data instead of hard-coded role checks. requiresAmountLimitCheck marks
// steps where the approver's RolePermission.approvalLimitKobo must cover
// the instance amount (the <1M/1M-10M/>10M escalation); Shariah-style
// second-approver steps leave it false since SRS doesn't tier SHARIAH_REV's
// authority by amount.
model ApprovalRuleStep {
  id                       String  @id @default(uuid()) @db.Uuid
  approvalRuleId           String  @map("approval_rule_id") @db.Uuid
  stepOrder                Int     @map("step_order")
  requiredFunctionCode     String  @map("required_function_code")
  requiresAmountLimitCheck Boolean @default(false) @map("requires_amount_limit_check")
  // Invariant 54(e)(ii)/(v): "charter-mandated seats are LOCKED rows the
  // editor renders but cannot remove ... each locked seat cites its
  // invariant number in the UI." Flag + citation live on the step now so
  // the future editor has no schema migration left to do; population of
  // WHICH existing steps are the five named charter seats (Shariah
  // sign-off >₦10M/loss scenarios, IC review on onboarding chains,
  // Compliance's terminal facility-review seat, the three-hand payroll
  // chain, ND's separate initiator/approver) is editor-adjacent content
  // work, not schema readiness — left false/null here by design.
  isLockedSeat             Boolean @default(false) @map("is_locked_seat")
  lockedSeatRationale      String? @map("locked_seat_rationale")
  description              String?

  approvalRule     ApprovalRule           @relation(fields: [approvalRuleId], references: [id])
  requiredFunction PlatformFunction       @relation(fields: [requiredFunctionCode], references: [code])
  stepApprovals    WorkflowStepApproval[]

  @@unique([approvalRuleId, stepOrder])
  @@map("approval_rule_step")
}

// A single in-flight (or decided) workflow instance — e.g. one distribution
// run's approval chain. approvalRuleId is resolved once at initiate() time
// from workflowTypeCode + scenario/amountKobo and does not change even if
// the matrix is edited later, so an in-flight instance can't have its rules
// swapped out from under it mid-approval.
model WorkflowInstance {
  id                String         @id @default(uuid()) @db.Uuid
  workflowTypeCode  String         @map("workflow_type_code")
  approvalRuleId    String         @map("approval_rule_id") @db.Uuid
  entityType        String         @map("entity_type")
  entityId          String         @map("entity_id")
  amountKobo        BigInt?        @map("amount_kobo")
  scenario          String?
  status            WorkflowStatus @default(INITIATED)
  initiatedByUserId String         @map("initiated_by_user_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  workflowType WorkflowType @relation(fields: [workflowTypeCode], references: [code])
  approvalRule ApprovalRule @relation(fields: [approvalRuleId], references: [id])
  initiatedBy  AppUser      @relation(fields: [initiatedByUserId], references: [id])

  stepApprovals                     WorkflowStepApproval[]
  delegationGrant                   DelegationOfAuthority?
  subscriptionRequest               SubscriptionRequest?
  ndMandateActivation               NdMandateAccount?
  productSetup                      Product?
  bankAccountChangeRequest          InvestorBankAccountChangeRequest?
  employeeOnboardingRequest         EmployeeOnboardingRequest?
  employeeOffboardingRequest        EmployeeOffboardingRequest?
  employeeIncentivePctChangeRequest EmployeeIncentivePctChangeRequest?
  investorContactAmendmentRequest   InvestorContactAmendmentRequest?
  investorExitRequest               InvestorExitRequest?
  counterpartyWriteOffRequest       CounterpartyWriteOffRequest?
  investorMandateAmendmentRequest   InvestorMandateAmendmentRequest?
  paymentGatewayProviderConfig      PaymentGatewayProvider?
  productCustodianAccountConfig     ProductCustodianAccount?
  paymentGatewayInflowDecision      PaymentGatewayInflow?
  payoutCompilationBatch            PayoutCompilationBatch?
  taxRateVersion                    TaxRateVersion?
  taxRemittanceBatch                TaxRemittanceBatch?
  prospectusSheetApproval           ProductParameters?

  @@index([workflowTypeCode, entityType, entityId])
  @@map("workflow_instance")
}

enum WorkflowStatus {
  INITIATED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
  CANCELLED

  @@map("workflow_status")
}

// One row per approval decision on one step of one instance. maker≠checker
// (SRS §3.3: "No user may initiate AND approve the same distribution") is
// enforced in WorkflowEngineService against WorkflowInstance.initiatedByUserId
// before this row is ever created, not by a DB constraint here — the check
// needs the instance's initiator, which a table constraint can't see.
model WorkflowStepApproval {
  id                 String           @id @default(uuid()) @db.Uuid
  workflowInstanceId String           @map("workflow_instance_id") @db.Uuid
  approvalRuleStepId String           @map("approval_rule_step_id") @db.Uuid
  approverUserId     String           @map("approver_user_id") @db.Uuid
  decision           ApprovalDecision
  decidedAt          DateTime         @default(now()) @map("decided_at")
  notes              String?

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id])
  approvalRuleStep ApprovalRuleStep @relation(fields: [approvalRuleStepId], references: [id])
  approver         AppUser          @relation(fields: [approverUserId], references: [id])

  @@unique([workflowInstanceId, approvalRuleStepId])
  @@map("workflow_step_approval")
}

enum ApprovalDecision {
  APPROVE
  REJECT

  @@map("approval_decision")
}

// CEO instruction 2026-07-04: "Approval limits should be set and governed
// by Delegation of Authority ... needs flexibility in the frame and
// structure." RolePermission.approvalLimitKobo is the standing/default
// authority a role carries; this table is the governed override layer —
// time-bound, revocable, and delegated from a specific person to a
// specific person (e.g. Roles & Workflows §6: CEO delegates workflow
// approval authority to the CIO during an absence, "audit log records the
// approval as delegated"). A delegation can grant MORE authority than the
// delegate's own standing role (limitKobo NULL = uncapped), less, or the
// same — it's a distinct grant, not a role change.
//
// CLAUDE.md 9a: a grant starts PENDING and is inert (DelegationService.
// findEligibleGrant only matches ACTIVE) until the linked WorkflowInstance
// (workflowTypeCode DELEGATION_GRANT) is approved by a second authority —
// see DelegationService.requestGrant/activate and WorkflowEngineService.
// boardInstrumentRef, when present, is what let the grant bypass the
// "grantor's own effective authority must cover limitKobo" check.
model DelegationOfAuthority {
  id                 String           @id @default(uuid()) @db.Uuid
  functionCode       String           @map("function_code")
  delegateUserId     String           @map("delegate_user_id") @db.Uuid
  delegatedByUserId  String           @map("delegated_by_user_id") @db.Uuid
  limitKobo          BigInt?          @map("limit_kobo")
  effectiveFrom      DateTime         @map("effective_from")
  effectiveTo        DateTime?        @map("effective_to")
  status             DelegationStatus @default(PENDING)
  reason             String?
  boardInstrumentRef String?          @map("board_instrument_ref")
  workflowInstanceId String?          @unique @map("workflow_instance_id") @db.Uuid
  revokedAt          DateTime?        @map("revoked_at")
  revokedByUserId    String?          @map("revoked_by_user_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at")

  function         PlatformFunction  @relation(fields: [functionCode], references: [code])
  delegate         AppUser           @relation("DelegationDelegate", fields: [delegateUserId], references: [id])
  delegatedBy      AppUser           @relation("DelegationGrantor", fields: [delegatedByUserId], references: [id])
  revokedBy        AppUser?          @relation("DelegationRevoker", fields: [revokedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([delegateUserId, functionCode, status])
  @@map("delegation_of_authority")
}

enum DelegationStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED

  @@map("delegation_status")
}

// Build Plan step 5 / SOW D5: product catalogue. Kept deliberately minimal
// here — full product-factory provisioning (auto-instantiating a ledger
// entity + CoA per product, per Core Schema Skeleton §3.4) waits on
// ledger_entity/chart_of_accounts, which don't exist until Build Plan step
// 8. This step's job is the PARAMETER SET a product carries, not the
// ledger machinery.
model Product {
  code                    String            @id
  name                    String
  engineType              ProductEngineType @map("engine_type")
  status                  ProductStatus     @default(DRAFT)
  createdAt               DateTime          @default(now()) @map("created_at")
  // Invariant 42(a)/44(b): SubscriptionService refuses initiation on a
  // product lacking Shariah approval — AMD-12's "activation-gated, never
  // build-gated" doctrine applied to the product factory. Ships EMPTY
  // (null) by default; the full governed create->approve->Shariah-gate->
  // ACTIVE product-factory workflow (invariant 44b) populates this. Never
  // set by inference from a product's ACTIVE status — the two are
  // independent gates, checked together by SubscriptionService.
  shariahApprovedAt       DateTime?         @map("shariah_approved_at")
  shariahApprovalRef      String?           @map("shariah_approval_ref")
  // Invariant 44(b) (CHECK10): the product-factory create step's own
  // workflow gate — mirrors NdMandateAccount.activationWorkflowInstanceId's
  // pattern. createProduct() creates the row DRAFT and stores the
  // PRODUCT_SETUP workflow instance here; ProductFactoryService.
  // approveProductSetup() only auto-provisions the ledger entity + CoA
  // template once THIS instance reaches APPROVED (a different user than
  // the initiator, enforced by WorkflowEngineService). Null for every
  // product that predates this pass (the two walkthrough products) — never
  // backfilled, since there is no real approval event to record for them.
  setupWorkflowInstanceId String?           @unique @map("setup_workflow_instance_id") @db.Uuid

  parameterVersions    ProductParameters[]
  ledgerEntities       LedgerEntity[]
  productAccounts      ProductAccount[]
  subscriptionRequests SubscriptionRequest[]
  setupWorkflow        WorkflowInstance?         @relation(fields: [setupWorkflowInstanceId], references: [id])
  custodianAccounts    ProductCustodianAccount[]

  @@map("product")
}

enum ProductEngineType {
  UNIT_NAV
  PSR_WATERFALL
  MANDATE

  @@map("product_engine_type")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  RETIRED

  @@map("product_status")
}

// Versioned, never updated in place — ParameterService always inserts a new
// version rather than mutating the current one, so a parameter's history
// is the table itself, not a separate audit reconstruction (AMD-01:
// "parameter change after first placement requires Board + SSB approval
// workflow"). psrPoolMudaribShare/surplusInvestorShare/surplusMudaribShare
// are pool-level constants (AMD-01/02: default 60:40 base split, 40:60
// inverse surplus split), fixed at pool opening, nullable because they only
// apply to PSR_WATERFALL products.
//
// feesAllowedOnPool (AMD-03): CEO instruction 2026-07-04 makes this a
// governed PARAMETER, not the hard schema-level CHECK constraint AMD-03
// originally specified — "in case SEC changes rules in the future given
// regulatory activities." Defaults to false (today's correct, zero-fee
// position per AMD-03/CLAUDE.md invariant #7) but is now something a future
// Board-approved parameter change can flip, without a migration. See
// CLAUDE.md's amendment note for the reasoning and what this does NOT
// change (the default behavior today is unchanged).
model ProductParameters {
  id                   String      @id @default(uuid()) @db.Uuid
  productCode          String      @map("product_code")
  version              Int
  psrPoolMudaribShare  Decimal?    @map("psr_pool_mudarib_share") @db.Decimal(6, 4)
  surplusInvestorShare Decimal?    @map("surplus_investor_share") @db.Decimal(6, 4)
  surplusMudaribShare  Decimal?    @map("surplus_mudarib_share") @db.Decimal(6, 4)
  feesAllowedOnPool    Boolean     @default(false) @map("fees_allowed_on_pool")
  dripDefault          DripDefault @default(NONE) @map("drip_default")
  // AMD-01 Board + SSB approval workflow, as scoped by CEO instruction
  // 2026-07-04: required (both, non-null) on any version that changes
  // feesAllowedOnPool or a PSR constant on an ACTIVE product — see
  // ParameterService.setPoolParameters. Not required for a product's first
  // parameter version (nothing to "change" from yet).
  boardResolutionRef   String?     @map("board_resolution_ref")
  ssbResolutionRef     String?     @map("ssb_resolution_ref")
  effectiveFrom        DateTime    @default(now()) @map("effective_from")
  createdByUserId      String      @map("created_by_user_id") @db.Uuid
  approvedByUserId     String?     @map("approved_by_user_id") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at")

  // ==========================================================================
  // Invariant 70(a) (CEO directive, 12-Jul-2026): the Unified Prospectus
  // Parameter Sheet EXTENDS this table rather than duplicating it — the
  // CEO's own spec text for the PSR class calls the base distribution ratio
  // above "existing," i.e. this row already IS the sheet for that class;
  // these are the new per-class fields the sheet framework adds. Every
  // field below is nullable — a given version only fills in the group(s)
  // relevant to Product.engineType, enforced at the SERVICE layer
  // (ProspectusSheetService), never a DB-level per-class CHECK constraint,
  // since a product's engineType never changes after creation.
  //
  // Lock-on-approval (70b) reuses the EXISTING approvedByUserId nullability
  // as the lock signal (null = DRAFT, freely re-editable; non-null =
  // LOCKED, immutable — a change after that point is a NEW version through
  // the amendment chain, invariant 70g) — no separate status enum needed,
  // consistent with how every other versioned-config table in this codebase
  // (ProductParameters itself, InvestmentMemoThresholdConfig, etc.) already
  // encodes "approved" as "approvedByUserId is set." sheetWorkflowInstanceId
  // is the NEW dedicated PORT_MGR-initiate -> CIO-review -> MD-approve chain
  // (workflowTypeCode PROSPECTUS_SHEET_APPROVAL) that gates the lock --
  // distinct from Product.setupWorkflowInstanceId, which only ever gates the
  // product's own IDENTITY creation, not subsequent parameter-sheet versions.
  sheetWorkflowInstanceId String? @unique @map("sheet_workflow_instance_id") @db.Uuid
  prospectusRef           String? @map("prospectus_ref")

  // --- Mutual Fund (UNIT_NAV) mechanics ---
  authorizedUnits                 Decimal? @map("authorized_units") @db.Decimal(20, 6)
  fundSizeCapKobo                 BigInt?  @map("fund_size_cap_kobo")
  offerSpreadPct                  Decimal? @map("offer_spread_pct") @db.Decimal(6, 4)
  bidSpreadPct                    Decimal? @map("bid_spread_pct") @db.Decimal(6, 4)
  valuationFrequency              String?  @map("valuation_frequency")
  minimumSubscriptionKobo         BigInt?  @map("minimum_subscription_kobo")
  minimumAdditionalInvestmentKobo BigInt?  @map("minimum_additional_investment_kobo")
  minimumRedemptionKobo           BigInt?  @map("minimum_redemption_kobo")
  minimumHoldingKobo              BigInt?  @map("minimum_holding_kobo")

  // --- Fee stack (Mutual Fund) ---
  managementFeeRatePct Decimal? @map("management_fee_rate_pct") @db.Decimal(6, 4)
  adminFeeRatePct      Decimal? @map("admin_fee_rate_pct") @db.Decimal(6, 4)
  custodianFeeRatePct  Decimal? @map("custodian_fee_rate_pct") @db.Decimal(6, 4)
  secFeeRatePct        Decimal? @map("sec_fee_rate_pct") @db.Decimal(6, 4)
  auditFeeRatePct      Decimal? @map("audit_fee_rate_pct") @db.Decimal(6, 4)

  // --- Distribution policy (Mutual Fund + PSR pool share this group; the
  // PSR ratio itself stays in psrPoolMudaribShare/surplus* above) ---
  distributionMethod     String?  @map("distribution_method")
  // Invariant 70(a): "distribution frequency (feeds the Obligations
  // Calendar)" for PSR pools; also the Mutual Fund distribution cadence.
  distributionFrequency  String?  @map("distribution_frequency")
  // SEC floor enforced at the SERVICE layer (ParameterService/
  // ProspectusSheetService), never a DB CHECK — same "governed config, not
  // a hard constraint, in case the regulator's own rule moves" reasoning
  // feesAllowedOnPool's own comment above already establishes for this file.
  distributableIncomePct Decimal? @map("distributable_income_pct") @db.Decimal(6, 4)

  // --- Private Mudarabah Pool (PSR) additions ---
  minimumParticipationKobo BigInt? @map("minimum_participation_kobo")
  poolTenorMonths          Int?    @map("pool_tenor_months")
  // CEO ruling 12-Jul-2026: the above-benchmark inverse split is an
  // explicit PROVISION, never automatic. surplusInvestorShare/
  // surplusMudaribShare above ARE the inverse ratio fields (already on this
  // table) — this flag is the ONLY new field the surplus tier needs; the
  // engine (PsrWaterfallEngineService) must read THIS flag, not merely the
  // presence of non-null surplus shares, before applying the inverse split.
  // Defaults false: a pool with no explicit election runs base PSR on all
  // profit, exactly as every pool does today.
  surplusSharingEnabled    Boolean @default(false) @map("surplus_sharing_enabled")

  // --- Investment Mandate additions ---
  mandateRoleModel           MandateRoleModel? @map("mandate_role_model")
  mandateFeeRatePct          Decimal?          @map("mandate_fee_rate_pct") @db.Decimal(6, 4)
  // Benchmark-only label, structural per invariant 44(a)/70(a) — never a
  // promised/guaranteed rate; enforced at render time (Offers tab, 70c),
  // not by this field's mere presence.
  targetedReturnBenchmarkPct Decimal?          @map("targeted_return_benchmark_pct") @db.Decimal(6, 4)
  investmentType             String?           @map("investment_type")
  tenorLockInMonths          Int?              @map("tenor_lock_in_months")
  minimumInvestmentKobo      BigInt?           @map("minimum_investment_kobo")
  fundingStructure           FundingStructure? @map("funding_structure")

  // --- Offer narrative (client-facing content, invariant 70c's Offers &
  // Opportunities cards render these verbatim) ---
  offerNarrativeBrief            String? @map("offer_narrative_brief") @db.Text
  offerNarrativeOpportunity      String? @map("offer_narrative_opportunity") @db.Text
  offerNarrativeDynamics         String? @map("offer_narrative_dynamics") @db.Text
  offerNarrativeRiskSummary      String? @map("offer_narrative_risk_summary") @db.Text
  offerNarrativeModelDescription String? @map("offer_narrative_model_description") @db.Text

  product       Product           @relation(fields: [productCode], references: [code])
  createdBy     AppUser           @relation("ParamsCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy    AppUser?          @relation("ParamsApprovedBy", fields: [approvedByUserId], references: [id])
  sheetWorkflow WorkflowInstance? @relation(fields: [sheetWorkflowInstanceId], references: [id])

  @@unique([productCode, version])
  @@map("product_parameters")
}

enum MandateRoleModel {
  MUDARABAH_PSR
  WAKALAH

  @@map("mandate_role_model")
}

enum FundingStructure {
  LUMP_SUM
  PERIODIC_CALL

  @@map("funding_structure")
}

enum DripDefault {
  AUTO
  MANUAL
  NONE

  @@map("drip_default")
}

// Build Plan step 6 / SOW D6: investor master, SRS §5.2, "one identity,
// once" (CLAUDE.md invariant #4). Soft delete only (isDeleted) — SRS: "Hard
// delete prohibited." investorId is a natural key in the SRS's own format
// (INV-YYYYMMDD-NNN), generated by InvestorService, not a DB default —
// Postgres has no clean way to express "sequence reset daily" as a column
// default, and the format needs to survive review either way.
model Investor {
  investorId                 String                  @id @map("investor_id")
  fullLegalName              String                  @map("full_legal_name")
  entityType                 InvestorEntityType      @map("entity_type")
  nationality                String
  // Nullable (invariant 27a, was required): Stage-1 Express onboarding
  // captures identity core + BVN/RC + contact only — TIN and registered
  // address are Stage-2 fields, genuinely absent until Stage-2 completes.
  // Flow A's existing full-KYC onboard() still populates both immediately.
  taxIdentificationNumber    String?                 @map("tax_identification_number")
  dateOfBirthOrIncorporation DateTime?               @map("date_of_birth_or_incorporation")
  contactEmail               String                  @unique @map("contact_email")
  contactPhone               String                  @map("contact_phone")
  registeredAddress          String?                 @map("registered_address")
  kycStatus                  InvestorKycStatus       @default(PENDING_KYC) @map("kyc_status")
  kycExpiryDate              DateTime?               @map("kyc_expiry_date")
  amlStatus                  InvestorAmlStatus       @default(PENDING) @map("aml_status")
  // Migration Data Standards §"Deduplication — the overlap rule": BVN
  // (individuals, primary) / RC number (corporates, primary) are the
  // matching keys that make "one investor = ONE row in TPL_01" enforceable
  // even when the same person holds both the Halal Fund and the Mudarabah
  // pool — see MigrationService's TPL_01 overlap gate (Reconciliation Gate
  // 6). NIN/TIN are secondary matching keys, kept for traceability only.
  bvn                        String?                 @unique
  nin                        String?
  rcNumber                   String?                 @unique @map("rc_number")
  pepStatus                  Boolean?                @map("pep_status")
  occupationOrBusinessNature String?                 @map("occupation_or_business_nature")
  relationshipOfficer        String?                 @map("relationship_officer")
  // Invariant 39(d): the "client's DESIGNATED Relationship Management
  // Officer (assignment = data row, org-linked, reassignable)" invariant
  // 35(a) requires for portal messaging routing, for ALL investors — not
  // just WM clients (who already have this via WmClientProfile.
  // advisorUserId). Deliberately separate from the pre-existing
  // relationshipOfficer field above (free text, migration-carryover,
  // untouched) since messaging needs a real FK to notify/route to.
  relationshipManagerUserId  String?                 @map("relationship_manager_user_id") @db.Uuid
  // TPL_01's temp_investor_ref, retained per the Migration Data Standards'
  // "your refs are kept as migration_source_ref for traceability back to
  // Navision/paper" rule — nullable since only migration-loaded investors
  // carry one.
  migrationSourceRef         String?                 @unique @map("migration_source_ref")
  // Onboarding Design Stage 5's AML risk rating instrument: "driven by
  // investor type, geography, PEP status, source-of-funds clarity, product
  // mix. Drives KYC tier, review frequency (e.g., 3y/2y/1y), and approval
  // level." Nullable — unset until Stage 5 runs; InvestorService requires
  // it populated before KYC submission can proceed (mirrors the existing
  // screening-record gate), so approveKyc() can always compute the correct
  // tiered expiry once it actually approves.
  amlRiskRating              InvestorAmlRiskRating?  @map("aml_risk_rating")
  fundStatus                 InvestorFundStatus      @default(PENDING_KYC) @map("fund_status")
  // Nullable for the same Stage-1 Express reason as TIN/address above.
  sourceOfFunds              String?                 @map("source_of_funds")
  authorisedSignatories      Json?                   @map("authorised_signatories")
  // Invariant 27(a): every investor now enters at STAGE_1_EXPRESS by
  // default; stage1IssuedAt marks customer-number issuance (the mandatory
  // sanctions screen having cleared), stage2DeadlineAt is issuedAt +
  // InvestorOnboardingConfig.stage2CompletionDeadlineDays.
  onboardingStage            InvestorOnboardingStage @default(STAGE_1_EXPRESS) @map("onboarding_stage")
  stage1IssuedAt             DateTime?               @map("stage1_issued_at")
  stage2DeadlineAt           DateTime?               @map("stage2_deadline_at")
  onboardedByUserId          String                  @map("onboarded_by_user_id") @db.Uuid
  complianceApprovedByUserId String?                 @map("compliance_approved_by_user_id") @db.Uuid
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  isDeleted                  Boolean                 @default(false) @map("is_deleted")

  onboardedBy                  AppUser                            @relation("InvestorOnboardedBy", fields: [onboardedByUserId], references: [id])
  complianceApprovedBy         AppUser?                           @relation("InvestorComplianceApprovedBy", fields: [complianceApprovedByUserId], references: [id])
  relationshipManager          AppUser?                           @relation("InvestorRelationshipManager", fields: [relationshipManagerUserId], references: [id])
  mandate                      InvestorMandate?
  kycDocuments                 InvestorKycDocument[]
  screeningRecords             InvestorScreeningRecord[]
  bankAccounts                 InvestorBankAccount[]
  productAccounts              ProductAccount[]
  ndMandateAccounts            NdMandateAccount[]
  wmClientProfile              WmClientProfile?
  portalClientUser             PortalClientUser?
  leadOrigin                   Lead?
  onboardingCase               InvestorOnboardingCase?
  communications               ClientCommunication[]
  paymentInflows               PaymentInflowLog[]
  complaints                   Complaint[]
  certificates                 Certificate[]
  privacyNoticeAcknowledgments PrivacyNoticeAcknowledgment[]
  letterInstances              LetterInstance[]
  zakatSubscription            ZakatClientSubscription?
  zakatSubscriptionRequests    ZakatSubscriptionRequest[]
  subscriptionRequests         SubscriptionRequest[]
  bankAccountChangeRequests    InvestorBankAccountChangeRequest[]
  contactAmendmentRequests     InvestorContactAmendmentRequest[]
  exitRequests                 InvestorExitRequest[]
  mandateAmendmentRequests     InvestorMandateAmendmentRequest[]
  // Distinct from paymentInflows (PaymentInflowLog) above: that table
  // records WHO paid for an already-approved subscription's Txn (invariant
  // 27a/28a own-account/third-party attribution, collected at checker
  // approval). This one is invariant 55(a)'s webhook-originated staging
  // row, which EXISTS BEFORE any SubscriptionRequest does -- it's what
  // creates one, not what documents one after the fact.
  paymentGatewayInflows        PaymentGatewayInflow[]
  execOversightSessions        ExecOversightSession[]
  notifications                Notification[]
  payoutCompilationLines       PayoutCompilationLine[]
  taxExemptions                InvestorTaxExemption[]
  feeInvoices                  FeeInvoice[]

  @@map("investor")
}

// SRS §5.2 exact enum sets.
enum InvestorEntityType {
  HNWI_INDIVIDUAL
  CORPORATE
  TRUST
  COOPERATIVE
  PENSION
  FAMILY_OFFICE
  OTHER

  @@map("investor_entity_type")
}

enum InvestorKycStatus {
  PENDING_KYC
  KYC_COMPLETE
  LAPSED
  SUSPENDED
  EXEMPT

  @@map("investor_kyc_status")
}

enum InvestorAmlStatus {
  PENDING
  CLEARED
  UNDER_REVIEW
  FLAGGED

  @@map("investor_aml_status")
}

// Onboarding Design Stage 5: "AML risk rating (LOW | MEDIUM | HIGH) ...
// drives KYC tier, review frequency (e.g., 3y/2y/1y), and approval level."
enum InvestorAmlRiskRating {
  LOW
  MEDIUM
  HIGH

  @@map("investor_aml_risk_rating")
}

// SRS §4.1.4: "Statuses: Pending_KYC → KYC_Complete → Active → Matured →
// Exited. Forward-only transitions" (enforced in InvestorService, not the
// database — Postgres has no clean "forward only" enum constraint).
enum InvestorFundStatus {
  PENDING_KYC
  ACTIVE
  MATURED
  EXITED
  SUSPENDED
  WATCH_LIST
  // Invariant 51(b-v) (CHECK13): passive activity-detection status, not a
  // punitive one -- InvestorExitService.runDormancySweep flips ACTIVE ->
  // DORMANT after a governed months-inactive threshold, and reverses it
  // automatically the moment new Txn activity appears, with no maker-
  // checker step either direction (nothing is being approved, only
  // observed).
  DORMANT

  @@map("investor_fund_status")
}

// SRS §5.3, amended by AMD-01/08: investorBaseRatio/mudaribBaseRatio are
// retired for POOL participation (NULL) and remain valid ONLY for
// Non-Discretionary mandates (mandateType DIRECT_DEAL or
// RESTRICTED_PLUS_DIRECT) — enforced in InvestorService, mirrored by a DB
// CHECK constraint (see the follow-up migration) since this is exactly the
// kind of rule the charter wants enforced at the database engine, not just
// documented.
model InvestorMandate {
  id                      String          @id @default(uuid()) @db.Uuid
  investorId              String          @unique @map("investor_id")
  mandateType             MandateType     @map("mandate_type")
  targetReturnRate        Decimal         @map("target_return_rate") @db.Decimal(6, 4)
  investorBaseRatio       Decimal?        @map("investor_base_ratio") @db.Decimal(6, 4)
  mudaribBaseRatio        Decimal?        @map("mudarib_base_ratio") @db.Decimal(6, 4)
  restrictedSectors       String[]        @map("restricted_sectors")
  restrictedContracts     String[]        @map("restricted_contracts")
  directDealInvestmentId  String?         @map("direct_deal_investment_id")
  rolloverDefault         RolloverDefault @default(AUTO) @map("rollover_default")
  earlyExitWaiver         Boolean         @default(false) @map("early_exit_waiver")
  ssbWaiverResolutionRef  String?         @map("ssb_waiver_resolution_ref")
  effectiveDate           DateTime        @map("effective_date")
  approvedByUserId        String          @map("approved_by_user_id") @db.Uuid
  shariahReviewedByUserId String?         @map("shariah_reviewed_by_user_id") @db.Uuid
  version                 Int             @default(1)
  createdAt               DateTime        @default(now()) @map("created_at")

  investor          Investor @relation(fields: [investorId], references: [investorId])
  approvedBy        AppUser  @relation("MandateApprovedBy", fields: [approvedByUserId], references: [id])
  shariahReviewedBy AppUser? @relation("MandateShariahReviewedBy", fields: [shariahReviewedByUserId], references: [id])

  @@map("investor_mandate")
}

enum MandateType {
  UNRESTRICTED
  RESTRICTED
  DIRECT_DEAL
  RESTRICTED_PLUS_DIRECT

  @@map("mandate_type")
}

enum RolloverDefault {
  AUTO
  MANUAL
  NONE

  @@map("rollover_default")
}

// Invariant 51(c) Tier-3 (CHECK13, "verify then build only if absent" --
// confirmed absent: InvestorMandate.version already anticipated this but no
// service method ever amends a mandate post-creation). Scoped to the three
// scalar fields a governed post-approval amendment plausibly covers
// (targetReturnRate, rolloverDefault, earlyExitWaiver) -- deliberately
// EXCLUDES mandateType (a product-class change, not an amendment) and the
// two array fields restrictedSectors/restrictedContracts (Prisma String[]
// has no null state to distinguish "not proposed" from "propose clearing
// the list," and resolving that ambiguity honestly would need its own
// dedicated UI, out of scope for this pass -- flagged in
// QUESTIONS_FOR_REVIEW.md). Same shape as InvestorContactAmendmentRequest:
// BD proposes, Compliance approves, truthy-only partial patch, version
// increments on approval.
model InvestorMandateAmendmentRequest {
  id                       String                         @id @default(uuid()) @db.Uuid
  investorId               String                         @map("investor_id")
  proposedTargetReturnRate Decimal?                       @map("proposed_target_return_rate") @db.Decimal(6, 4)
  proposedRolloverDefault  RolloverDefault?               @map("proposed_rollover_default")
  proposedEarlyExitWaiver  Boolean?                       @map("proposed_early_exit_waiver")
  status                   InvestorMandateAmendmentStatus @default(PENDING)
  requestedByUserId        String                         @map("requested_by_user_id") @db.Uuid
  workflowInstanceId       String?                        @unique @map("workflow_instance_id") @db.Uuid
  rejectionNotes           String?                        @map("rejection_notes")
  createdAt                DateTime                       @default(now()) @map("created_at")

  investor         Investor          @relation(fields: [investorId], references: [investorId])
  requestedBy      AppUser           @relation("InvestorMandateAmendmentRequestedBy", fields: [requestedByUserId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@map("investor_mandate_amendment_request")
}

enum InvestorMandateAmendmentStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("investor_mandate_amendment_status")
}

// Data Dictionary §1 "kyc_documents" (TPL_03). Onboarding Design §Stage 3:
// "expiry date (IDs expire — expiry drives re-KYC triggers), and
// verification status." documentType is a plain string, not an enum/lookup
// table — the checklist per investor type is configuration the onboarding
// UI drives, not a fixed platform list.
model InvestorKycDocument {
  id                 String                     @id @default(uuid()) @db.Uuid
  investorId         String                     @map("investor_id")
  documentType       String                     @map("document_type")
