enum WmVerificationTag {
  DECLARED
  VERIFIED

  @@map("wm_verification_tag")
}

enum WmShariahScreenTag {
  SCREENED_COMPLIANT
  SCREENED_NON_COMPLIANT
  UNSCREENED

  @@map("wm_shariah_screen_tag")
}

// v1.1 refinement #2 — wealth-pyramid segmentation. Band thresholds are
// governed config (invariant 10/16): never a hardcoded tier-cutoff in code.
// Invariant (Visualization Standard item 2): the 10-tier Nigerian Wealth
// Classification Standard (NWCS) SUPERSEDES the earlier 4-tier MASS_MARKET/
// AFFLUENT/HNI/VHNI model everywhere. Bands are stored in USD (the
// standard's own anchor unit) — naira cutoffs are NEVER stored here; they
// are DERIVED at read time from WmFxConfig's governed rate (invariant 26b:
// "adjustable to market reality... never hardcoded"), so a rate change
// alone re-tiers every client without touching this table.
model WmClientTierConfig {
  id                String       @id @default(uuid()) @db.Uuid
  tier              WmClientTier
